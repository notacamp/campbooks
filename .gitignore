# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files — but ship the documented template.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Native push credentials (APNs .p8 key, FCM service-account JSON). Never commit.
/config/credentials/*.p8
/config/credentials/*-service-account.json


/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore Claude Code temporary files.
.claude/scheduled_tasks.lock
.playwright-mcp/
# Private cloud ops context, written by campbooks-cloud/install.sh.
/CLAUDE.local.md

# Private cloud analytics overlay (Matomo), dropped into the public checkout by
# campbooks-cloud/install.sh + deploy.yml. Analytics code must never land in the
# open-source core — it is inert here unless MATOMO_URL/MATOMO_SITE_ID are set.
/config/initializers/cloud_analytics.rb

# Kotlin/Gradle build artifacts (native app).
.kotlin/
native/**/.kotlin/

# Ignore screenshots and test artifacts (developer captures live in the repo root).
/*.png
/*.jpeg
/*.jpg
!/public/icon.png
test-results/

# Local Netlify folder
.netlify
