# Copy this file to `keystore.properties` (git-ignored) and fill it in after creating
# your Play upload keystore. NEVER commit the real keystore.properties or the .jks.
#
# Create the upload keystore once (keep the .jks + both passwords somewhere safe —
# e.g. 1Password. If you enrol in Play App Signing, Google holds the real signing key
# and this is only your *upload* key, which Google can reset if lost):
#
#   keytool -genkeypair -v -keystore campbooks-upload.jks -alias campbooks \
#     -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=/absolute/path/to/campbooks-upload.jks
storePassword=CHANGE_ME
keyAlias=campbooks
keyPassword=CHANGE_ME
