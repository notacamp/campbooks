# ============================================================================
# Campbooks — environment configuration
# ============================================================================
# Copy this file to .env, then run `bin/generate-secrets` to fill in the
# required secrets. Everything under "REQUIRED" must be set; everything else is
# optional and unlocks a specific integration. Full guide: docs/self-hosting.md
#
#   cp .env.example .env
#   bin/generate-secrets
#   docker compose up -d --build
#
# Compose reads this file automatically. Lines you leave blank/commented fall
# back to sensible defaults (see docker-compose.yml).
# ============================================================================

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Generated by `bin/generate-secrets`. Without these the app will not boot.
# Generate manually with:  openssl rand -hex 64   (and -hex 16 for the AR keys)
SECRET_KEY_BASE=
ACTIVE_RECORD_PRIMARY_KEY=
ACTIVE_RECORD_DETERMINISTIC_KEY=
ACTIVE_RECORD_KEY_DERIVATION_SALT=

# Password for the bundled Postgres container (also generated by the script).
CAMPBOOKS_DATABASE_PASSWORD=

# The hostname you'll reach the app on. Must match the Host header you use
# (localhost, an IP, or a domain) — requests for other hosts are rejected.
APP_HOST=localhost

# Plain HTTP is fine for local use. Set to true ONLY when the app sits behind a
# TLS-terminating reverse proxy (otherwise it redirects http→https and marks
# cookies secure-only, which breaks login over http). See docs/self-hosting.md.
FORCE_SSL=false

# ── Installation mode ─────────────────────────────────────────────────────────
# Self-hosted mode: open registration, AI keys read from this env, no cloud
# admin gating. Leave set for self-hosting.
SELF_HOSTED=1
# Who may create an account: open | beta_code | approval | invite_only
# (self-hosted defaults to "open" — the first visitor registers the workspace).
# SIGNUP_MODE=open

# A demo workspace + admin@example.com / partner@example.com are seeded on first
# boot. Set this to choose the seeded password (otherwise it's "changeme123" —
# change it after first login). Has no effect once the users exist.
# SEED_PASSWORD=

# ── AI providers ──────────────────────────────────────────────────────────────
# AI features (triage, Scout chat, draft replies, document analysis, semantic
# search) are OPTIONAL — the app runs without any key, those features just stay
# off. Configure at least one TEXT provider to use Scout/triage. OpenAI also
# powers document/vision analysis and embeddings (semantic search). Without an
# embeddings provider, search falls back to keyword (ILIKE) matching.
#
# You can also leave these blank and let each user enter their own key in
# Settings → AI (stored encrypted per workspace).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ── Mailbox & OAuth providers ─────────────────────────────────────────────────
# Each provider is OPTIONAL — set the pair only for the providers you want users
# to be able to connect. Register an OAuth app with each and whitelist the
# callback URL  <APP_HOST>/oauth/<provider>/callback  (http://localhost:3000/...
# for local). See docs/self-hosting.md for per-provider setup + scopes.

# Google — "Sign in with Google" + Gmail/Calendar connect.
#   Callback: /oauth/gmail/callback   Console: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Drive — interactive "Send to Drive". SEPARATE Google project (uses the
# restricted full `drive` scope).  Callback: /oauth/google/callback
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Zoho Mail. Callback: /oauth/zoho/callback   Console: https://api-console.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Data center your Zoho account lives in: eu, us, in, au, jp, ca, cn, sa (default eu)
ZOHO_REGION=eu

# Microsoft 365 / Entra — "Sign in with Microsoft" + Outlook mailbox connect.
#   Callback: /oauth/microsoft/callback   Console: https://entra.microsoft.com
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Microsoft isn't production-ready yet, so EVERY Microsoft surface (the
# "Sign in with Microsoft" button, "Connect Microsoft 365", and the OAuth
# callbacks) is hidden by default. Toggle it under "Feature flags" below.

# Notion — interactive "Send to Notion" + workflow/Scout actions. Public
# integration OAuth. Callback: /oauth/notion/callback
#   Register: https://www.notion.so/my-integrations  (type: Public)
# When unset, users can still paste a Notion internal integration token.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Feature flags (not production-ready; opt-in) ──────────────────────────────
# These features are built but not yet production-ready, so they ship OFF by
# default. Set to 1 to enable (e.g. for evaluation); they graduate over time.
#   ENABLE_WORKFLOWS    — Workflow automation engine (builder UI, triggers,
#                         webhook ingress, public API).
#   ENABLE_EMAIL_BOARD  — the inbox "Board" (status kanban) layout.
#   ENABLE_MICROSOFT    — all Microsoft 365 surfaces (sign-in + mailbox connect).
#                         Legacy name ENABLE_MICROSOFT_MAILBOX is still honored.
#   ENABLE_EMAIL_SCHEDULING — snoozed-email visibility on the calendar + scheduled
#                             email sending with Liquid template variables.
# ENABLE_WORKFLOWS=
# ENABLE_EMAIL_BOARD=
# ENABLE_MICROSOFT=
# ENABLE_EMAIL_SCHEDULING=

# ── Outbound email (SMTP) ─────────────────────────────────────────────────────
# OPTIONAL. Without SMTP_USERNAME, the app sends no mail (OTP codes, reports,
# notifications are skipped). Set these to enable transactional email.
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_DOMAIN=example.com
# SMTP_AUTHENTICATION=plain
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAILER_FROM=Campbooks <no-reply@example.com>

# ── File storage ──────────────────────────────────────────────────────────────
# OPTIONAL. By default, uploaded files (email attachments → Documents) are stored
# on local disk in the `storage` volume. To use S3-compatible object storage
# instead, set these (works with AWS S3, MinIO, Hetzner Object Storage, …).
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=campbooks-storage
# S3_REGION=eu-central-1
# S3_ENDPOINT=                 # set for non-AWS providers (e.g. MinIO)
# S3_FORCE_PATH_STYLE=true     # usually required for MinIO/self-hosted S3

# ── Full-text search (OpenSearch) ─────────────────────────────────────────────
# OPTIONAL. Powers Contact full-text autocomplete only (email/document search
# and the Cmd+K palette use Postgres + pgvector regardless). To enable, set this
# and start the bundled OpenSearch with the `search` profile:
#   docker compose --profile search up -d
# OPENSEARCH_URL=http://opensearch:9200

# ── Error monitoring ──────────────────────────────────────────────────────────
# OPTIONAL. Sentry-compatible DSN (e.g. self-hosted GlitchTip). Disabled if unset.
# SENTRY_DSN=

# ── Push notifications (native iOS/Android apps) ──────────────────────────────
# OPTIONAL. Only needed if you build/ship the native apps. Disabled if unset.
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.example.campbooks
# APNS_KEY_PATH=config/credentials/apns.p8
# APNS_ENVIRONMENT=development
# FCM_PROJECT_ID=
# FCM_CREDENTIALS_PATH=config/credentials/fcm-service-account.json

# ── GitHub issue sync for in-app bug reports ──────────────────────────────────
# OPTIONAL. When set, in-app bug reports are mirrored to GitHub issues.
# GITHUB_TOKEN=
# GITHUB_BUG_REPORT_REPO=owner/repo

# ── Performance tuning ────────────────────────────────────────────────────────
# All OPTIONAL — defaults are fine for a small instance.
# WEB_CONCURRENCY=2          # Puma worker processes (web container)
# RAILS_MAX_THREADS=5        # Puma threads + DB pool size
# JOB_CONCURRENCY=1          # Solid Queue worker processes
# RAILS_LOG_LEVEL=info
# WEB_PORT=3000              # host port mapped to the web container

# Disable Google Calendar push webhooks (recommended unless this instance has a
# public HTTPS URL Google can reach). Polling still keeps calendars in sync.
# DISABLE_CALENDAR_PUSH=1
