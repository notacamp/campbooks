#!/usr/bin/env bash
#
# Generate the secrets a self-hosted Campbooks instance needs, and write them
# into .env (creating it from .env.example on first run). Safe to re-run — it
# only fills values that are empty or still set to a placeholder.
#
#   bin/generate-secrets
#
# Generates: SECRET_KEY_BASE, the three ACTIVE_RECORD_* encryption keys, and a
# random CAMPBOOKS_DATABASE_PASSWORD. Everything else (AI keys, OAuth, SMTP, …)
# is optional and added by hand — see .env.example and docs/self-hosting.md.
set -euo pipefail
cd "$(dirname "$0")/.."

ENV_FILE=".env"

if ! command -v openssl >/dev/null 2>&1; then
  echo "error: openssl is required but not installed." >&2
  exit 1
fi

if [ ! -f "$ENV_FILE" ]; then
  if [ ! -f .env.example ]; then
    echo "error: neither .env nor .env.example found." >&2
    exit 1
  fi
  cp .env.example "$ENV_FILE"
  echo "Created $ENV_FILE from .env.example"
fi

# Set KEY=VALUE in .env, but only if the current value is empty or a placeholder.
set_secret() {
  key="$1"; value="$2"
  if grep -qE "^${key}=" "$ENV_FILE"; then
    current="$(grep -E "^${key}=" "$ENV_FILE" | head -1 | cut -d= -f2-)"
    case "$current" in
      ""|change_me*|your_*|replace_*|REPLACE_*)
        tmp="$(mktemp)"
        sed "s|^${key}=.*|${key}=${value}|" "$ENV_FILE" > "$tmp" && mv "$tmp" "$ENV_FILE"
        echo "  set  ${key}"
        ;;
      *)
        echo "  keep ${key} (already set)"
        ;;
    esac
  else
    printf '%s=%s\n' "$key" "$value" >> "$ENV_FILE"
    echo "  add  ${key}"
  fi
}

echo "Generating secrets into ${ENV_FILE}…"
set_secret SECRET_KEY_BASE                   "$(openssl rand -hex 64)"
set_secret ACTIVE_RECORD_PRIMARY_KEY         "$(openssl rand -hex 16)"
set_secret ACTIVE_RECORD_DETERMINISTIC_KEY   "$(openssl rand -hex 16)"
set_secret ACTIVE_RECORD_KEY_DERIVATION_SALT "$(openssl rand -hex 16)"
set_secret CAMPBOOKS_DATABASE_PASSWORD       "$(openssl rand -hex 24)"

echo
echo "Done. Review ${ENV_FILE}, set APP_HOST, and add any API keys you want."
echo "Then: docker compose up -d --build"
