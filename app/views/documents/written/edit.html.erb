<% content_for :main_class, "px-4 sm:px-6 lg:px-8 py-6" %>

<%= render Campbooks::PageHeader.new(title: t(".title")) do |header| %>
  <% header.with_actions do %>
    <%= link_to written_document_path(@document), class: "text-sm text-muted-foreground hover:text-foreground transition-colors" do %>
      ← <%= t(".back_to_document") %>
    <% end %>
  <% end %>
<% end %>

<%= form_with model: @document, url: written_document_path(@document), method: :patch, class: "space-y-4" do |f| %>
  <%= f.text_field :title, placeholder: t(".title_placeholder"),
      class: "block w-full text-xl sm:text-2xl font-bold tracking-tight border-0 border-b border-gray-200
              bg-transparent px-0 py-2 focus:ring-0 focus:border-accent-500",
      autofocus: true, required: true %>

  <%= render Campbooks::RichTextEditor.new(
    input_name: "authored_document[html_content]",
    content: @document.html_content,
    variant: :document,
    min_height: "60vh",
    editor_class: "min-h-[60vh]",
    placeholder: t(".editor_placeholder")
  ) %>

  <div class="flex items-center justify-end gap-3 pt-2">
    <%= link_to written_document_path(@document), class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700
        bg-white border border-gray-300 rounded-md hover:bg-gray-50" do %>
      <%= t(".cancel") %>
    <% end %>
    <button type="submit"
        class="inline-flex items-center px-4 py-2 bg-accent-600 text-white text-sm font-medium rounded-md hover:bg-accent-700 cursor-pointer">
      <%= t(".save") %>
    </button>
  </div>
<% end %>
