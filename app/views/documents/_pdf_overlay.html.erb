<div data-pdf-preview-target="overlay"
     class="hidden fixed inset-0 z-50 bg-black/80 flex flex-col"
     data-action="keydown@window->pdf-preview#closeOnEscape click->pdf-preview#closeOnBackdrop">
  <div class="flex items-center justify-between p-3 text-white">
    <span class="text-sm font-medium truncate"><%= @document.canonical_filename || @document.original_file.filename %></span>
    <%= render Campbooks::IconButton.new(aria_label: t(".close_aria_label"), size: :md, data: { action: "pdf-preview#close" }, class: "hover:bg-white/10 text-white hover:text-white", title: t(".close_title")) do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    <% end %>
  </div>
  <iframe class="flex-1 w-full border-0" title="<%= t('.fullscreen_iframe_title') %>"></iframe>
</div>
