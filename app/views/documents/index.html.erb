<div data-controller="upload">
  <%= render Campbooks::PageHeader.new(title: t(".title")) do |header| %>
    <% header.with_actions do %>
      <% if @reprocessable_count > 0 %>
        <%= form_tag reprocess_all_documents_path, method: :post, id: "reprocess-all-form", class: "hidden" do %>
          <% Array(params[:type]).each do |t| %>
            <%= hidden_field_tag 'type[]', t %>
          <% end %>
          <%= hidden_field_tag :category, params[:category] if params[:category].present? %>
          <%= hidden_field_tag :review_status, params[:review_status] if params[:review_status].present? %>
          <%= hidden_field_tag :month, params[:month] if params[:month].present? %>
        <% end %>
        <%= render Campbooks::Button.new(variant: :outline, size: :sm, type: :submit, form: "reprocess-all-form") { t(".reanalyze_all", count: @reprocessable_count) } %>
      <% end %>
      <%= form_tag export_documents_path, method: :post, class: "inline" do %>
        <% Array(params[:type]).each do |t| %>
          <%= hidden_field_tag 'type[]', t %>
        <% end %>
        <%= hidden_field_tag :category, params[:category] if params[:category].present? %>
        <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
        <%= hidden_field_tag :month, params[:month] if params[:month].present? %>
        <%= render Campbooks::Button.new(variant: :outline, size: :sm, type: :submit,
              data: { turbo_confirm: t(".export_confirm") }) { t(".export") } %>
      <% end %>
      <button type="button" data-action="click->upload#toggle"
          class="inline-flex items-center px-4 py-2 bg-accent-600 text-white text-sm font-medium rounded-md hover:bg-accent-700 cursor-pointer">
        <%= t(".upload") %>
      </button>
    <% end %>
  <% end %>

  <% unless ai_provider_available?(:documents) %>
    <div class="mb-6">
      <%= render(Campbooks::AiSetupPrompt.new(capability: :documents, variant: :banner)) %>
    </div>
  <% end %>

  <!-- Upload form -->
  <div data-upload-target="container" class="bg-card rounded-xl shadow-sm border border-gray-200 p-6 mb-6 hidden">
    <%= form_tag documents_path, multipart: true, class: "space-y-6" do %>
      <div class="border-2 border-dashed border-gray-300 rounded-lg p-12 text-center hover:border-accent-200 transition-colors"
           data-upload-target="dropzone"
           data-action="dragover->upload#dragover dragenter->upload#dragover dragleave->upload#dragleave drop->upload#drop">
        <div class="space-y-2">
          <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div class="text-sm text-gray-600">
            <label class="cursor-pointer text-accent-600 hover:text-accent-500 font-medium">
              <%= t(".click_to_upload") %>
              <%= file_field_tag :files, multiple: true, accept: ".pdf,.jpg,.jpeg,.png,.webp,.heic",
                  class: "sr-only", data: { upload_target: "input", action: "change->upload#handleFiles" } %>
            </label>
            <%= t(".drag_and_drop") %>
          </div>
          <p class="text-xs text-gray-500"><%= t(".accepted_formats") %></p>
        </div>
      </div>

      <div data-upload-target="fileList" class="hidden">
        <h3 class="text-sm font-medium text-gray-700 mb-2"><%= t(".selected_files") %></h3>
        <ul data-upload-target="fileListItems" class="space-y-2"></ul>
      </div>

      <div class="flex justify-end">
        <%= render Campbooks::Button.new(variant: :primary, size: :lg, type: :submit, data: { upload_target: "submit" }) { t(".upload_and_process") } %>
      </div>
    <% end %>
  </div>

<%# Skim for Documents — the review-queue ring tray + the full-screen review overlay.
    Page-scoped controller (not mounted globally) so it never collides with email
    Skim. The tray loads lazily and renders nothing when nothing needs review;
    Documents::SkimTrayBroadcaster keeps its counts live. %>
<div data-controller="doc-skim-overlay">
  <%= turbo_stream_from "doc_skim_#{Current.workspace.id}" %>
  <%= turbo_frame_tag "doc_skim_tray", src: document_skim_tray_path, loading: :lazy, class: "block" %>
  <%= render "shared/doc_skim_overlay" %>
</div>

<% if @has_any_documents %>
<!-- Filters: collapsed by default on mobile (tap to expand), always open on desktop (md+) -->
<% active_filter_count = [ params[:category].presence, Array(params[:type]).reject(&:blank?).presence, params[:review_status].presence, params[:month].presence ].compact.size %>
<details class="filters-disclosure group/filters bg-card rounded-xl shadow-sm border border-gray-200 mb-6">
  <summary class="md:hidden flex items-center justify-between gap-2 p-4 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
    <span class="flex items-center gap-2 text-sm font-medium text-gray-700">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L15 12.414V19a1 1 0 01-.553.894l-4 2A1 1 0 019 21v-8.586L3.293 6.707A1 1 0 013 6V4z"/></svg>
      <%= t(".filters") %>
      <% if active_filter_count > 0 %>
        <%= render Campbooks::Badge.new(variant: :accent, size: :sm) { active_filter_count } %>
      <% end %>
    </span>
    <svg class="w-4 h-4 text-gray-400 group-open/filters:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
  </summary>
  <div class="hidden group-open/filters:block md:block px-4 pb-4 pt-0 md:pt-4">
  <%= form_tag documents_path, method: :get, class: "flex flex-wrap gap-4 items-end" do %>
    <div class="w-full sm:w-auto">
      <label class="block text-sm font-medium text-gray-700"><%= t(".filter_category") %></label>
      <%= select_tag :category,
          options_for_select([[t(".filter_all_categories"), ""]] + @categories.map { |c| [human_enum(DocumentType, :category, c), c] }, params[:category]),
          class: "mt-1 block w-full sm:w-auto rounded-md border-gray-300 shadow-sm text-sm",
          onchange: "this.form.requestSubmit()" %>
    </div>
    <div class="relative w-full sm:w-auto">
      <label class="block text-sm font-medium text-gray-700"><%= t(".filter_type") %></label>
      <details class="group mt-1" data-controller="dropdown-close">
        <summary class="flex items-center justify-between gap-2 rounded-md border border-gray-300 shadow-sm text-sm px-3 py-2 bg-card cursor-pointer select-none min-w-[160px]">
          <span><%= Array(params[:type]).any? ? t(".filter_types_selected", count: Array(params[:type]).size) : t(".filter_all_types") %></span>
          <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="absolute z-10 mt-1 bg-card border border-gray-200 rounded-md shadow-lg p-2 w-56 max-h-60 overflow-y-auto">
          <% @document_types.each do |dt| %>
            <label class="flex items-center gap-2 px-2 py-1.5 text-sm hover:bg-gray-50 rounded cursor-pointer">
              <%= check_box_tag 'type[]', dt.id, Array(params[:type]).include?(dt.id.to_s),
                  class: "rounded border-gray-300 text-accent-600 focus:ring-accent-500",
                  onchange: "this.form.requestSubmit()" %>
              <span class="flex items-center gap-1.5">
                <%= render Campbooks::ColorDot.new(color: document_type_dot_color(dt), size: :sm) %>
                <%= dt.name.humanize %>
              </span>
            </label>
          <% end %>
        </div>
      </details>
    </div>
    <div class="w-full sm:w-auto">
      <label class="block text-sm font-medium text-gray-700"><%= t(".filter_status") %></label>
      <%= select_tag :review_status,
          options_for_select([[t(".filter_all_statuses"), ""]] + Document.review_statuses.keys.map { |s| [human_enum(Document, :review_status, s), s] }, params[:review_status]),
          class: "mt-1 block w-full sm:w-auto rounded-md border-gray-300 shadow-sm text-sm",
          onchange: "this.form.requestSubmit()" %>
    </div>
    <div class="w-full sm:w-auto">
      <label class="block text-sm font-medium text-gray-700"><%= t(".filter_month") %></label>
      <%= month_field_tag :month, params[:month], class: "mt-1 block w-full sm:w-auto rounded-md border-gray-300 shadow-sm text-sm",
          onchange: "this.form.requestSubmit()" %>
    </div>
  <% end %>
  </div>
</details>

<!-- Documents table (md+) — cards take over below md so phones never scroll sideways -->
<div class="hidden md:block bg-card rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="min-w-full table-fixed divide-y divide-gray-200">
    <thead class="bg-warm-ash-bg">
      <tr>
        <th class="w-3/12 px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_name") %></th>
        <th class="w-1/12 px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_type") %></th>
        <th class="w-[8%] px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_date") %></th>
        <th class="w-2/12 px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_reference") %></th>
        <th class="w-[10%] px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_status") %></th>
        <th class="w-[8%] px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_source") %></th>
      </tr>
    </thead>
    <tbody id="documents_tbody" class="bg-card divide-y divide-gray-200">
      <%= render partial: "documents/row", collection: @documents, as: :doc %>
      <% if @documents.empty? %>
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-sm text-gray-500"><%= t(".no_documents") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Documents cards (mobile) -->
<div id="documents_cards" class="md:hidden space-y-3">
  <%= render partial: "documents/card", collection: @documents, as: :doc %>
  <% if @documents.empty? %>
    <div class="bg-card rounded-xl shadow-sm border border-gray-200 px-6 py-8 text-center text-sm text-gray-500">
      <%= t(".no_documents") %>
    </div>
  <% end %>
</div>

<!-- Exports history -->
<% if @exports.any? %>
  <div class="mt-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t(".exports_heading") %></h2>
    <div class="bg-card rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-warm-ash-bg">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_date") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_status") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_documents") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_download") %></th>
          </tr>
        </thead>
        <tbody class="bg-card divide-y divide-gray-200">
          <% @exports.each do |export| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= l(export.created_at, format: :at) %></td>
              <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(export.status) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right"><%= export.documents_count %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% if export.zip_file.attached? %>
                  <%= link_to t(".download_zip"), url_for(export.zip_file), class: "text-accent-600 hover:text-accent-700 font-medium" %>
                <% elsif export.failed? %>
                  <span class="text-red-500 dark:text-red-400"><%= t(".export_failed") %></span>
                <% else %>
                  <span class="text-gray-400"><%= human_enum(Export, :status, export.status) %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<% if @pagy.next %>
  <%= turbo_frame_tag "documents_pagination",
      src: documents_path(page: @pagy.next, format: :turbo_stream,
            type: params[:type], category: params[:category], review_status: params[:review_status], month: params[:month]),
      loading: :lazy do %>
    <div class="flex items-center justify-center py-6">
      <%= render Campbooks::Spinner.new(size: :md) %>
    </div>
  <% end %>
<% end %>
<noscript>
  <% if @pagy.pages > 1 %>
    <div class="mt-4">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</noscript>
<% else %>
  <%# Empty workspace (no documents at all): the page can't work yet, so guide the
      user to the actions that fill it instead of showing empty filters + table. %>
  <%= render(Campbooks::EmptyState.new(
        variant: :standalone,
        title: t(".empty_title"),
        description: @email_connected ? t(".empty_description_connected") : t(".empty_description"))) do |state| %>
    <% state.with_icon do %>
      <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-6 4h4m5 4H6a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v11a2 2 0 01-2 2z"/>
      </svg>
    <% end %>
    <% state.with_actions do %>
      <%= render(Campbooks::Button.new(variant: :primary, data: { action: "click->upload#toggle" })) { t(".empty_upload") } %>
      <% unless @email_connected %>
        <%= render(Campbooks::Button.new(variant: :outline, href: email_messages_path(inbox_settings: "accounts"))) { t(".empty_connect_email") } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
</div>
