<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= render(Campbooks::Logo.new(size: :lg)) %>
      <h1 class="text-lg font-semibold text-foreground mt-4"><%= t(".title") %></h1>
      <p class="text-sm text-gray-600 mt-1"><%= t(".subtitle") %></p>
    </div>

    <%= render(Campbooks::Card.new) do %>
      <% if @method == :totp %>
        <%= form_with url: session_challenge_path, method: :post, class: "space-y-4", data: { turbo: false } do %>
          <%= hidden_field_tag :method, "totp" %>
          <div>
            <label for="code" class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".totp_label") %></label>
            <input type="text" name="code" id="code" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]*" maxlength="6" required autofocus placeholder="000000"
                   class="block w-full text-center text-lg font-mono tracking-[0.5em] rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500" />
          </div>
          <%= render(Campbooks::Button.new(variant: :primary, type: :submit, class: "w-full justify-center")) { t(".totp_submit") } %>
        <% end %>

      <% elsif @method == :passkey %>
        <div class="space-y-4">
          <p class="text-sm text-gray-600"><%= t(".passkey_intro") %></p>
          <%= form_with url: session_challenge_path, method: :post,
                data: {
                  controller: "webauthn",
                  webauthn_options_url_value: passkey_options_session_challenge_path(format: :json),
                  webauthn_mode_value: "get",
                  webauthn_unsupported_message_value: t(".passkey_unsupported"),
                  turbo: false
                } do %>
            <%= hidden_field_tag :method, "passkey" %>
            <input type="hidden" name="credential" data-webauthn-target="credential" />
            <p data-webauthn-target="error" class="text-sm text-red-600 mb-2" hidden></p>
            <%= render(Campbooks::Button.new(variant: :primary, type: :button, class: "w-full justify-center", data: { action: "webauthn#start", webauthn_target: "submit" })) { t(".passkey_button") } %>
          <% end %>
        </div>

      <% elsif @method == :email_otp %>
        <div class="space-y-4">
          <p class="text-sm text-gray-600"><%= t(".email_intro") %></p>
          <%= form_with url: send_email_code_session_challenge_path, method: :post, data: { turbo: false } do %>
            <%= render(Campbooks::Button.new(variant: :outline, type: :submit, class: "w-full justify-center")) { t(".email_send") } %>
          <% end %>
          <%= form_with url: session_challenge_path, method: :post, class: "space-y-4", data: { turbo: false } do %>
            <%= hidden_field_tag :method, "email_otp" %>
            <div>
              <label for="code" class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".email_label") %></label>
              <input type="text" name="code" id="code" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]*" maxlength="6" required placeholder="000000"
                     class="block w-full text-center text-lg font-mono tracking-[0.5em] rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500" />
            </div>
            <%= render(Campbooks::Button.new(variant: :primary, type: :submit, class: "w-full justify-center")) { t(".email_submit") } %>
          <% end %>
        </div>

      <% elsif @method == :recovery %>
        <%= form_with url: session_challenge_path, method: :post, class: "space-y-4", data: { turbo: false } do %>
          <%= hidden_field_tag :method, "recovery" %>
          <div>
            <label for="code" class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".recovery_label") %></label>
            <input type="text" name="code" id="code" autocomplete="one-time-code" required autofocus placeholder="xxxxx-xxxxx"
                   class="block w-full text-center font-mono tracking-wider rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500" />
            <p class="text-sm text-gray-500 mt-1"><%= t(".recovery_hint") %></p>
          </div>
          <%= render(Campbooks::Button.new(variant: :primary, type: :submit, class: "w-full justify-center")) { t(".recovery_submit") } %>
        <% end %>
      <% end %>

      <%# Switch to another available factor, with recovery as a universal fallback. %>
      <% alternatives = @methods - [ @method ] %>
      <% if alternatives.any? || @method != :recovery %>
        <%= render(Campbooks::Divider.new) %>
        <div class="space-y-2 text-center text-sm">
          <% alternatives.each do |m| %>
            <div><%= link_to t(".method_#{m}"), session_challenge_path(method: m), class: "text-accent-600 hover:text-accent-700 font-medium", data: { turbo: false } %></div>
          <% end %>
          <% if @method != :recovery %>
            <div><%= link_to t(".use_recovery"), session_challenge_path(method: :recovery), class: "text-gray-500 hover:text-gray-700", data: { turbo: false } %></div>
          <% end %>
        </div>
      <% end %>

      <p class="text-center text-sm mt-6">
        <%= link_to t(".back_to_login"), new_session_path, class: "text-gray-500 hover:text-gray-700", data: { turbo: false } %>
      </p>
    <% end %>
  </div>
</div>
