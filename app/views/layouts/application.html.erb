<!DOCTYPE html>
<html class="h-full bg-background" lang="<%= I18n.locale %>">
  <head>
    <%= render "shared/theme_head" %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Campbooks">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full <%= "hotwire-native" if hotwire_native_app? %>"
        data-controller="<%= "command-palette " unless hotwire_native_app? %>email-shortcuts theme skim-overlay product-tour"
        data-command-palette-context-value="<%= content_for?(:cp_context) ? yield(:cp_context) : '' %>"
        data-command-palette-message-id-value="<%= content_for?(:cp_message_id) ? yield(:cp_message_id) : '' %>"
        data-command-palette-folders-value="<%= content_for?(:cp_folders) ? yield(:cp_folders) : '[]' %>"
        data-command-palette-subject-value="<%= content_for?(:cp_subject) ? yield(:cp_subject) : '' %>"
        data-command-palette-commands-value="<%= command_palette_catalog_json %>">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent-600 focus:text-white focus:rounded-md focus:shadow-lg focus:outline-none">Skip to content</a>

    <% if authenticated? %>
      <%= render(Campbooks::NavRail.new) %>
    <% end %>

    <div class="<%= "lg:pl-20 pb-16 lg:pb-0" if authenticated? %>">
      <%# Cloud-only "early beta" stripe. Sits at the top of the content column
          (clear of the fixed left rail); suppressed in native shells, which
          carry their own chrome. %>
      <%= render(Campbooks::BetaBanner.new) if show_beta_banner? && !hotwire_native_app? %>
      <%# Native shells provide their own top navigation bar (title + back),
          so the web topbar is suppressed to avoid double chrome. %>
      <%= render "shared/topbar" if authenticated? && !hotwire_native_app? %>
      <%= section_nav if authenticated? %>

      <main id="main-content" class="<%= content_for?(:main_class) ? yield(:main_class) : 'max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8' %>" tabindex="-1">
      <%= render "shared/flash_inline" %>

      <% if content_for?(:sidebar) %>
        <div class="flex flex-col gap-6 lg:flex-row lg:gap-8">
          <%= yield :sidebar %>
          <div class="flex-1 min-w-0">
            <%= yield %>
          </div>
        </div>
      <% else %>
        <%= yield %>
      <% end %>
      </main>
    </div>

    <% if authenticated? %>
      <%= render(Campbooks::BottomNav.new) %>

      <%= render "shared/email_drawer" %>

      <%= render "shared/setup_modal" %>
      <%= render "shared/skim_overlay" %>
      <%= render(Campbooks::ProductTour.new(autostart: product_tour_autostart?)) %>
      <%= render(Campbooks::BugReportTab.new) %>
      <%= render(Campbooks::BugReportModal.new) %>
    <% end %>

    <%# Command palette + keyboard-shortcuts cheat sheet are keyboard-driven — omit them in the native app. %>
    <% unless hotwire_native_app? %>
      <%= render(Campbooks::CommandPalette.new) %>
      <%= render(Campbooks::KeyboardShortcutsModal.new) %>
    <% end %>
    <%= render "shared/flash_toast_region" %>
    <% if authenticated? %><%= render "shared/swipe_dialogs" %><% end %>
  </body>
</html>
