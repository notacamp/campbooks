<!DOCTYPE html>
<html class="h-full bg-background" lang="<%= I18n.locale %>">
  <head>
    <%= render "shared/theme_head" %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Campbooks">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full" data-controller="theme">
    <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8" tabindex="-1">
      <%= render "shared/flash_inline" %>

      <%= yield %>
    </main>
    <%= render "shared/flash_toast_region" %>
  </body>
</html>
