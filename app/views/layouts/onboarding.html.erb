<!DOCTYPE html>
<html class="h-full bg-background" lang="<%= I18n.locale %>">
  <head>
    <%= render "shared/theme_head" %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Campbooks">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full" data-controller="theme product-tour">
    <main class="<%= content_for(:main_class) || "max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8" %>" tabindex="-1">
      <%= render "shared/flash_inline" %>

      <%= yield %>
    </main>
    <%# The guided demo is reachable pre-connect ("See it in action" on the
        welcome screen); never auto-opened here — home owns the autostart. No
        connect_path: the finish CTA closes onto the welcome screen's own cards. %>
    <%= render(Campbooks::ProductTour.new(autostart: false, connect_path: nil)) if authenticated? %>
    <%= render "shared/flash_toast_region" %>
  </body>
</html>
