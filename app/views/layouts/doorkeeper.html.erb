<!DOCTYPE html>
<html class="h-full bg-background" lang="<%= I18n.locale %>">
  <head>
    <title><%= t("doorkeeper.authorizations.new.page_title", default: "Authorize · Campbooks") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <meta name="robots" content="noindex, nofollow">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <body class="h-full">
    <main class="min-h-screen flex items-center justify-center px-4 py-10" tabindex="-1">
      <%= yield %>
    </main>
  </body>
</html>
