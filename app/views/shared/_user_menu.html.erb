<%#
  Avatar dropdown menu. Rendered in two places now: the desktop nav rail
  (compact: true, opens up-and-right) and the mobile top bar (defaults: name +
  chevron suppressed below lg, opens down-and-right). Locals:
    compact   — avatar-only trigger (no name/chevron). Default false.
    placement — :left | :right, passed to Campbooks::Dropdown. Default :right.
    drop      — :down | :up, passed to Campbooks::Dropdown. Default :down.
%>
<%
  compact   = local_assigns.fetch(:compact, false)
  placement = local_assigns.fetch(:placement, :right)
  drop      = local_assigns.fetch(:drop, :down)
%>
<%= render(Campbooks::Dropdown.new(placement: placement, drop: drop)) do |dropdown| %>
  <% dropdown.with_trigger do %>
    <% if compact %>
      <span class="inline-flex rounded-full transition-opacity hover:opacity-90">
        <%= render(Campbooks::Avatar.new(name: current_user.name, size: :md)) %>
      </span>
    <% else %>
      <div class="flex items-center gap-2 px-2 py-1 rounded-md hover:bg-muted transition-colors">
        <%= render(Campbooks::Avatar.new(name: current_user.name, size: :sm)) %>
        <span class="hidden lg:inline text-sm text-foreground"><%= current_user.name %></span>
        <svg class="hidden lg:block w-3 h-3 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    <% end %>
  <% end %>

  <% dropdown.with_menu do %>
    <div class="px-3 py-2 border-b border-border">
      <p class="text-sm font-medium text-foreground"><%= current_user.name %></p>
      <p class="text-xs text-muted-foreground"><%= current_user.email_address %></p>
    </div>
    <%# Mirrors the settings page organization (settings_nav_groups in
        NavigationHelper): same groups, headings, and order. %>
    <% settings_nav_groups.each_with_index do |(heading, items), group_index| %>
      <div class="py-1 <%= "border-t border-border" unless group_index.zero? %>">
        <p class="px-3 pt-1 pb-0.5 text-[11px] font-semibold uppercase tracking-wider text-muted-foreground"><%= heading %></p>
        <% items.each do |path, _active_keys, label, icon_path| %>
          <%= link_to path, class: "flex items-center gap-2.5 px-3 py-1.5 text-sm text-foreground whitespace-nowrap hover:bg-muted" do %>
            <svg class="w-4 h-4 flex-shrink-0 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= icon_path %>"/></svg>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Admin (cloud admins only) — moved here from the old topbar. %>
    <% if !self_hosted? && Current.user&.admin? %>
      <div class="py-1 border-t border-border">
        <%= link_to admin_root_path, class: "flex items-center gap-2.5 px-3 py-1.5 text-sm text-foreground whitespace-nowrap hover:bg-muted" do %>
          <svg class="w-4 h-4 flex-shrink-0 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span><%= t("shared.nav.admin") %></span>
        <% end %>
      </div>
    <% end %>

    <%# Preferences: theme toggle (single neutral icon; the theme controller has
        no sun/moon targets to sync) + keyboard shortcuts (desktop only). %>
    <div class="py-1 border-t border-border">
      <button type="button" data-action="click->theme#toggle" class="flex w-full items-center gap-2.5 px-3 py-1.5 text-sm text-foreground hover:bg-muted cursor-pointer">
        <svg class="w-4 h-4 flex-shrink-0 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/></svg>
        <span><%= t("shared.topbar.toggle_theme") %></span>
      </button>
      <button type="button" onclick="document.getElementById('keyboard-shortcuts-modal')?.showModal()" class="hidden lg:flex w-full items-center gap-2.5 px-3 py-1.5 text-sm text-foreground hover:bg-muted cursor-pointer">
        <svg class="w-4 h-4 flex-shrink-0 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 9h.01M15 9h.01M9 13h6M5 5h14a1 1 0 011 1v8a1 1 0 01-1 1H5a1 1 0 01-1-1V6a1 1 0 011-1zM8 19h8"/></svg>
        <span><%= t("shared.topbar.keyboard_shortcuts") %></span>
      </button>
    </div>

    <div class="border-t border-border py-1">
      <%= button_to t(".sign_out"), session_path, method: :delete, class: "block w-full text-left px-3 py-1.5 text-sm text-foreground hover:bg-muted cursor-pointer" %>
    </div>
  <% end %>
<% end %>
