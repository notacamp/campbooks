<%# Toolbar button that opens the "Customize AI" modal for `purpose` into the
    shared setup-modal turbo-frame (present in the app/email/onboarding layouts).
    Same guidance is also editable at Settings → AI Prompts. %>
<%= render(Campbooks::Button.new(variant: :outline, size: :sm, data: { setup_modal_open: edit_settings_ai_prompt_path(purpose) })) do %>
  <span class="inline-flex items-center gap-1.5">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
    <%= t("ai_prompts.customize_button") %>
  </span>
<% end %>
