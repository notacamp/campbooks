<%# AI setup. Two modes, both posting to setup#update_ai_configuration:
    • focus :all (default) — two steps: a required text provider, then an optional
      document/image (vision) provider.
    • focus :documents — the vision provider on its own (the "Add AI for documents
      & images" checklist item). Renders ONLY the document step, so no text fields
      are submitted and the text provider is never touched.
    text_provider/document_provider locals prefill the selects with the workspace's
    current choice. %>
<% focus = (local_assigns[:focus] || :all).to_sym %>
<% documents_only = focus == :documents %>
<% text_provider = local_assigns[:text_provider] || "deepseek" %>
<% document_provider = local_assigns[:document_provider] || "openai" %>
<% managed_available = local_assigns[:managed_available] %>
<% ai_mode = local_assigns[:ai_mode] %>
<turbo-frame id="setup_modal_frame">
  <% if managed_available && !documents_only %>
    <%# Cloud + platform keys: offer Campbooks AI vs bring-your-own (single page). %>
    <%= render "shared/modals/ai_configuration_choice_form",
          text_provider: text_provider, document_provider: document_provider,
          ai_mode: ai_mode, error: local_assigns[:error] %>
  <% else %>
  <%= form_with url: setup_path(:ai_configuration), method: :patch,
        data: { controller: "multi-step-form" } do |f| %>

    <%# Header + progress %>
    <div class="px-6 pt-4 pb-3 border-b border-gray-100">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-base font-semibold text-gray-900"
            data-multi-step-form-target="title"><%= documents_only ? t(".documents_title") : t(".title") %></h2>
        <button type="button" data-setup-modal-close=""
                class="p-1.5 -mr-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors cursor-pointer"
                aria-label="<%= t('.close_dialog') %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <% unless documents_only %>
        <div class="mt-3 flex items-center gap-3">
          <div class="h-1 flex-1 rounded-full bg-gray-100 overflow-hidden">
            <div class="h-full w-full bg-accent-600 origin-left transition-transform duration-300 ease-out"
                 style="transform: scaleX(0.5)" data-multi-step-form-target="bar"></div>
          </div>
          <span class="text-xs font-medium text-gray-500 tabular-nums"
                data-multi-step-form-target="progress"><%= t(".step_of", step: 1, total: 2) %></span>
        </div>
      <% end %>
    </div>

    <%# Body %>
    <div class="p-6 space-y-5">
      <%= render "shared/modals/form_error", error: local_assigns[:error] %>

      <% unless documents_only %>
        <%# Step 1 — Text provider (required) %>
        <div data-multi-step-form-target="step"
             data-step-title="<%= t('.title') %>">
          <p class="text-sm text-gray-600 mb-4"><%= t(".text_intro_html") %></p>
          <div class="space-y-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".provider_label") %></label>
              <%= select_tag "text_provider[provider]",
                    options_for_select(AiConfiguration::PROVIDERS.map { |p| [human_enum(AiConfiguration, :provider, p), p] }, text_provider),
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm", autofocus: true %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".api_key_label") %></label>
              <%= password_field_tag "text_provider[api_key]", nil,
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                    placeholder: t(".api_key_placeholder") %>
              <p class="text-xs text-gray-400 mt-1.5"><%= t(".api_key_hint") %></p>
            </div>
          </div>
        </div>
      <% end %>

      <%# Step 2 — Document & image provider (optional in :all mode; the only step
          in :documents mode) %>
      <div data-multi-step-form-target="step" class="<%= "hidden" unless documents_only %>"
           data-step-title="<%= t('.documents_title') %>">
        <p class="text-sm text-gray-600 mb-4"><%= t(".documents_intro_html") %></p>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".provider_label") %></label>
            <%= select_tag "document_provider[provider]",
                  options_for_select(AiConfiguration::VISION_PROVIDERS.map { |p| [human_enum(AiConfiguration, :provider, p), p] }, document_provider),
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".api_key_label") %></label>
            <%= password_field_tag "document_provider[api_key]", nil,
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                  placeholder: t(".document_api_key_placeholder") %>
            <p class="text-xs text-gray-400 mt-1.5"><%= t(".documents_api_key_hint") %></p>
          </div>
        </div>
      </div>

      <%# Navigation %>
      <div class="flex items-center gap-3 pt-3 border-t border-gray-100">
        <%= render(Campbooks::Button.new(variant: :ghost, size: :md, class: "hidden", data: { multi_step_form_target: "backBtn", action: "click->multi-step-form#back" }, type: :button)) { t("shared.actions.back") } %>
        <div class="flex items-center gap-2 ml-auto">
          <%= render(Campbooks::Button.new(variant: :outline, size: :md, type: :button, data: { setup_modal_close: "" })) { t("shared.actions.cancel") } %>
          <%= render(Campbooks::Button.new(variant: :primary, size: :md, class: "shadow-sm hover:shadow-md transition-all duration-150 active:scale-[0.98]", data: { multi_step_form_target: "nextBtn", action: "click->multi-step-form#next" }, type: :button)) { t("shared.actions.continue") } %>
          <%= render(Campbooks::Button.new(variant: :primary, size: :md, type: :submit, class: "hidden shadow-sm hover:shadow-md transition-all duration-150 active:scale-[0.98]", data: { multi_step_form_target: "submitBtn" })) { t(".save") } %>
        </div>
      </div>
    </div>
  <% end %>
  <% end %>
</turbo-frame>
