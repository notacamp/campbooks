<turbo-frame id="setup_modal_frame">
  <% form_step = @form_step || 0 %>

  <%= form_with url: setup_path(:workspace), method: :patch,
        data: { turbo_frame: "setup_modal_frame" } do |f| %>
    <%= hidden_field_tag :form_step, form_step %>

    <%# Header + progress %>
    <div class="px-6 pt-4 pb-3 border-b border-gray-100">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-base font-semibold text-gray-900">
          <%= case form_step
              when 0 then t(".step0_title")
              when 1 then t(".step1_title")
              when 2 then t(".step2_title")
              end %>
        </h2>
        <button type="button" data-setup-modal-close=""
                class="p-1.5 -mr-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors cursor-pointer"
                aria-label="<%= t('.close_dialog') %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="mt-3 flex items-center gap-3">
        <div class="h-1 flex-1 rounded-full bg-gray-100 overflow-hidden">
          <div class="h-full w-full bg-accent-600 origin-left transition-transform duration-300 ease-out"
               style="transform: scaleX(<%= ((form_step + 1) / 3.0).round(3) %>)"></div>
        </div>
        <span class="text-xs font-medium text-gray-500 tabular-nums"><%= t(".step_of", step: form_step + 1, total: 3) %></span>
      </div>
    </div>

    <%# Body %>
    <div class="p-6 space-y-5">
      <%= render "shared/modals/form_error", error: local_assigns[:error] %>

      <%= fields_for :workspace do |of| %>
        <% case form_step %>
        <% when 0 %>
          <div>
            <%= of.label :name, t(".workspace_name_label"), class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= of.text_field :name, value: Current.workspace.name,
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                  placeholder: t(".workspace_name_placeholder"),
                  autofocus: true %>
          </div>

          <% is_individual = Current.workspace.setting("workspace_type") == "individual" %>
          <fieldset class="space-y-2.5">
            <legend class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".workspace_type_legend") %></legend>
            <label class="flex items-start gap-3 p-3 rounded-xl border border-gray-200 hover:border-gray-300 cursor-pointer transition-colors has-[:checked]:border-accent-500 has-[:checked]:bg-accent-50">
              <%= radio_button_tag "workspace[workspace_type]", "company", !is_individual, class: "mt-0.5 text-accent-600 focus:ring-accent-500" %>
              <span>
                <span class="block text-sm font-semibold text-gray-900"><%= t(".type_company_label") %></span>
                <span class="block text-xs text-gray-500 mt-0.5"><%= t(".type_company_description") %></span>
              </span>
            </label>
            <label class="flex items-start gap-3 p-3 rounded-xl border border-gray-200 hover:border-gray-300 cursor-pointer transition-colors has-[:checked]:border-accent-500 has-[:checked]:bg-accent-50">
              <%= radio_button_tag "workspace[workspace_type]", "individual", is_individual, class: "mt-0.5 text-accent-600 focus:ring-accent-500" %>
              <span>
                <span class="block text-sm font-semibold text-gray-900"><%= t(".type_individual_label") %></span>
                <span class="block text-xs text-gray-500 mt-0.5"><%= t(".type_individual_description") %></span>
              </span>
            </label>
          </fieldset>

        <% when 1 %>
          <p class="text-sm text-gray-600"><%= t(".step1_description") %></p>
          <%= of.text_area :workspace_context, value: Current.workspace.settings&.dig("workspace_context"),
                rows: 4, autofocus: true,
                class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                placeholder: t(".workspace_context_placeholder") %>

        <% when 2 %>
          <p class="text-sm text-gray-600"><%= t(".step2_description") %></p>
          <div>
            <%= of.label :country, t(".country_label"), class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= of.text_field :country, value: Current.workspace.settings&.dig("country"),
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                  placeholder: t(".country_placeholder"), autofocus: true %>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <%= of.label :city, t(".city_label"), class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= of.text_field :city, value: Current.workspace.settings&.dig("city"),
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                    placeholder: t(".city_placeholder") %>
            </div>
            <div>
              <%= of.label :postal_code, t(".postal_code_label"), class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= of.text_field :postal_code, value: Current.workspace.settings&.dig("postal_code"),
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                    placeholder: t(".postal_code_placeholder") %>
            </div>
          </div>
          <div>
            <%= of.label :company_tax_id, t(".tax_id_label"), class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= of.text_field :company_tax_id, value: Current.workspace.settings&.dig("company_tax_id"),
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm",
                  placeholder: t(".tax_id_placeholder") %>
          </div>
        <% end %>
      <% end %>

      <%# Navigation %>
      <div class="flex items-center gap-3 pt-3 border-t border-gray-100">
        <% if form_step > 0 %>
          <%= link_to setup_path(:workspace, form_step: form_step - 1),
                class: "inline-flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            <%= t("shared.actions.back") %>
          <% end %>
        <% end %>
        <div class="flex items-center gap-2 ml-auto">
          <button type="button" data-setup-modal-close=""
                  class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors cursor-pointer">
            <%= t("shared.actions.cancel") %>
          </button>
          <%= f.submit(form_step < 2 ? t("shared.actions.continue") : t(".save_workspace"),
                class: "px-4 py-2 bg-accent-600 text-white text-sm font-medium rounded-lg shadow-sm hover:bg-accent-700 cursor-pointer border-0 transition-colors") %>
        </div>
      </div>
    </div>
  <% end %>
</turbo-frame>
