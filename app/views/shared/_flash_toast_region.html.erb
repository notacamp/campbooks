<%# Centered "feedback rail": ephemeral action toasts + the live sync pill, stacked
    in one column so they never overlap. Top on mobile (tucked under the sticky
    topbar), bottom-center on tablet (above the bottom nav, which is lg:hidden) and
    desktop. The notification-center (bell) toasts keep their own bottom-right
    corner below. %>
<div class="pointer-events-none fixed inset-x-0 z-50 flex justify-center px-4
            top-[max(4.5rem,calc(env(safe-area-inset-top)+4rem))]
            md:top-auto md:bottom-[max(5.5rem,calc(env(safe-area-inset-bottom)+4.5rem))]
            lg:bottom-[max(1.5rem,calc(env(safe-area-inset-bottom)+1rem))]">
  <div class="flex w-full max-w-md flex-col items-center gap-2 md:flex-col-reverse">
    <%# Action toasts append here. display:contents so each toast is a direct flex
        item of this column, stacking (with a gap) above the sync pill. %>
    <div id="<%= Campbooks::ActionToast::REGION_ID %>" class="contents" data-controller="action-toast">
      <%= render "shared/flash_toasts" %>
    </div>

    <% if authenticated? %>
      <%# Live email-sync indicator updates (broadcast from EmailScanJob). %>
      <%= turbo_stream_from "sync_status_#{current_user.id}" %>
      <%= render(Campbooks::SyncIndicator.new(scanning: current_user.email_syncing?)) %>
    <% end %>
  </div>
</div>

<% if authenticated? %>
  <%# Persistent notification-center toasts (bell), broadcast from the Notification
      model — their own bottom-right corner, distinct from action feedback. %>
  <%= turbo_stream_from "notifications_#{current_user.id}" %>
  <div class="pointer-events-none fixed bottom-20 right-4 lg:bottom-4 z-50 flex w-full max-w-sm flex-col-reverse gap-2">
    <div id="toasts" class="flex flex-col-reverse gap-2">
      <%# notification toasts appended here via Turbo Stream %>
    </div>
  </div>
<% end %>
