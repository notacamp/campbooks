<%# locals: calls, pagy, log_path, show_workspace: true %>
<%# Filter form: auto-submits on change via the auto-submit Stimulus controller. %>
<%= form_with url: log_path, method: :get,
      data: { turbo_frame: "isc_list", controller: "auto-submit" } do |f| %>
  <div class="flex flex-col sm:flex-row sm:items-end gap-2 flex-wrap mb-4">
    <%= render(Campbooks::Select.new(
          :service,
          include_blank: t("admin.system_health.show.filter_all_services"),
          options: SystemHealth::SERVICES.keys.map { |k|
            [ t("system_health.services.#{k}", default: k.humanize), k ]
          },
          selected: params[:service],
          data: { action: "change->auto-submit#submit" })) %>

    <%= render(Campbooks::Select.new(
          :status,
          include_blank: t("admin.system_health.show.filter_all_statuses"),
          options: [
            [ t("admin.system_health.show.filter_success"), "success" ],
            [ t("admin.system_health.show.filter_error"),   "error"   ]
          ],
          selected: params[:status],
          data: { action: "change->auto-submit#submit" })) %>

    <%= render(Campbooks::Select.new(
          :window,
          include_blank: nil,
          options: [
            [ t("admin.system_health.show.window_24h"), "24h" ],
            [ t("admin.system_health.show.window_7d"),  "7d"  ],
            [ t("admin.system_health.show.window_30d"), "30d" ]
          ],
          selected: params[:window].presence || "24h",
          data: { action: "change->auto-submit#submit" })) %>
  </div>
<% end %>

<%= turbo_frame_tag "isc_list" do %>
  <%= render(Campbooks::Card.new(padding: :none, overflow: :hidden)) do %>
    <div id="isc_rows" class="divide-y divide-border">
      <% if calls.any? %>
        <% calls.each do |call| %>
          <%= render(Campbooks::SystemHealth::CallRow.new(call: call, show_workspace: show_workspace)) %>
        <% end %>
      <% else %>
        <%= render(Campbooks::EmptyState.new(variant: :inline, title: t("admin.system_health.calls.no_matches"))) %>
      <% end %>
    </div>
  <% end %>

  <% if pagy&.next %>
    <%= turbo_frame_tag "isc_pagination",
          src: "#{log_path}?#{{ page: pagy.next, service: params[:service].presence, status: params[:status].presence, window: params[:window].presence, format: :turbo_stream }.compact.to_query}",
          loading: :lazy do %>
      <div class="flex justify-center py-4">
        <%= render(Campbooks::Spinner.new(size: :sm)) %>
      </div>
    <% end %>
  <% end %>
<% end %>
