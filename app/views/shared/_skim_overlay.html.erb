<%# Full-screen Skim Mode overlay (Instagram-stories style). Mounted in the layout
    nav (which carries data-controller="skim-overlay"); opened by the inbox "Skim"
    entry. The viewer (Campbooks::SkimStack, loaded into the frame) fills the panel
    and carries its own immersive surface, chrome, and close button. Escape or
    the in-viewer close button dismisses it. %>
<div data-skim-overlay-target="panel"
     data-action="keydown->skim-overlay#onKeydown"
     class="hidden fixed inset-0 z-[60]"
     role="dialog" aria-modal="true" aria-label="<%= t('.skim_inbox_label') %>">
  <%= turbo_frame_tag "skim_content",
        class: "block h-full w-full",
        data: { skim_overlay_target: "frame", skim_src: skim_path, action: "turbo:frame-load->skim-overlay#frameLoaded" } do %>
    <div class="flex h-full w-full items-center justify-center bg-background">
      <div class="flex flex-col items-center gap-3 text-sm text-muted-foreground">
        <svg class="h-6 w-6 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-90" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <%= t(".gathering_inbox") %>
      </div>
    </div>
  <% end %>
</div>
