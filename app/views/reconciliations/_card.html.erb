<div class="bg-card rounded-xl shadow-sm border border-border p-4">
  <%= link_to reconciliation_path(reconciliation), class: "block" do %>
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0 flex-1">
        <p class="font-medium text-foreground truncate">
          <%= reconciliation.statement_document&.original_file&.filename&.to_s&.truncate(50) || t("reconciliations.untitled_statement") %>
        </p>
        <p class="text-xs text-muted-foreground mt-0.5">
          <%= reconciliation.bank_name.presence || "—" %>
          <% if reconciliation.period_label %>
            &middot; <%= reconciliation.period_label %>
          <% end %>
        </p>
      </div>
      <%= render Campbooks::Accounting::ReconciliationStatusBadge.new(status: reconciliation.status) %>
    </div>
    <% if reconciliation.ready? && reconciliation.total_transactions > 0 %>
      <div class="mt-3 flex items-center gap-2">
        <div class="flex-1 bg-muted rounded-full h-1.5">
          <% pct = (reconciliation.resolved_count.to_f / reconciliation.total_transactions * 100).round %>
          <div class="bg-accent-500 h-1.5 rounded-full" style="width: <%= pct %>%"></div>
        </div>
        <span class="text-xs text-muted-foreground tabular-nums"><%= reconciliation.progress_label %></span>
      </div>
    <% end %>
  <% end %>
</div>
