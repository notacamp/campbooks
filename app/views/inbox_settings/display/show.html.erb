<%= turbo_frame_tag "inbox_settings_panel" do %>
  <div data-section="display">
    <header class="sticky top-0 z-10 bg-background/95 backdrop-blur px-6 py-4 border-b border-border">
      <h3 class="text-sm font-semibold text-foreground"><%= t(".heading") %></h3>
      <p class="text-xs text-muted-foreground mt-0.5"><%= t(".subheading") %></p>
    </header>

    <div class="px-6 py-5 space-y-7">
      <!-- Email accounts -->
      <section>
        <h4 class="text-xs font-semibold text-foreground mb-3"><%= t(".email_accounts_heading") %></h4>
        <% if @accounts.any? %>
          <div class="space-y-1">
            <% @accounts.each do |account| %>
              <label class="flex items-center gap-2.5 py-1 cursor-pointer">
                <input type="checkbox" checked
                       data-setting="account-<%= account.id %>"
                       data-action="change->inbox-settings-modal#toggle"
                       class="w-4 h-4 rounded border-gray-300 text-accent-600 focus:ring-accent-500">
                <%= render(Campbooks::ColorDot.new(color: account.color, size: :sm)) %>
                <span class="text-[13px] text-foreground"><%= account.display_name %></span>
              </label>
            <% end %>
          </div>
          <p class="text-xs text-muted-foreground mt-2"><%= t(".hide_account_hint") %></p>
        <% else %>
          <p class="text-[13px] text-muted-foreground"><%= t(".no_accounts") %></p>
        <% end %>
      </section>

      <!-- Display options -->
      <section>
        <h4 class="text-xs font-semibold text-foreground mb-3"><%= t(".show_heading") %></h4>
        <div class="space-y-1">
          <label class="flex items-center gap-2.5 py-1 cursor-pointer">
            <input type="checkbox" checked data-setting="labels"
                   data-action="change->inbox-settings-modal#toggle"
                   class="w-4 h-4 rounded border-gray-300 text-accent-600 focus:ring-accent-500">
            <span class="text-[13px] text-foreground"><%= t(".labels_option") %></span>
          </label>
          <label class="flex items-center gap-2.5 py-1 cursor-pointer">
            <input type="checkbox" checked data-setting="attachments"
                   data-action="change->inbox-settings-modal#toggle"
                   class="w-4 h-4 rounded border-gray-300 text-accent-600 focus:ring-accent-500">
            <span class="text-[13px] text-foreground"><%= t(".attachments_option") %></span>
          </label>
          <label class="flex items-center gap-2.5 py-1 cursor-pointer">
            <input type="checkbox" checked data-setting="chat"
                   data-action="change->inbox-settings-modal#toggle"
                   class="w-4 h-4 rounded border-gray-300 text-accent-600 focus:ring-accent-500">
            <span class="text-[13px] text-foreground"><%= t(".chat_option") %></span>
          </label>
        </div>
      </section>

      <!-- System labels (Gmail INBOX / CATEGORY_PERSONAL / …) — hidden by default -->
      <section>
        <h4 class="text-xs font-semibold text-foreground mb-3"><%= t(".system_labels_heading") %></h4>
        <p class="text-xs text-muted-foreground mb-2"><%= t(".system_labels_hint") %></p>
        <%= form_with url: inbox_settings_display_update_path, method: :patch, class: "inline" do |f| %>
          <label class="flex items-center gap-2.5 py-1 cursor-pointer">
            <%= f.check_box :show_system_labels,
                  { checked: @show_system_labels,
                    onchange: "this.form.requestSubmit()",
                    class: "w-4 h-4 rounded border-gray-300 text-accent-600 focus:ring-accent-500" },
                  "true", "false" %>
            <span class="text-[13px] text-foreground"><%= t(".show_system_labels") %></span>
          </label>
        <% end %>
      </section>

      <!-- View mode -->
      <section>
        <h4 class="text-xs font-semibold text-foreground mb-3"><%= t(".density_heading") %></h4>
        <div class="grid grid-cols-3 gap-2">
          <% %w[compact default breathable].each do |mode| %>
            <button type="button"
                    data-action="click->inbox-settings-modal#setViewMode"
                    data-view-mode="<%= mode %>"
                    class="text-[13px] text-gray-600 bg-gray-100 rounded-lg px-3 py-2 text-center cursor-pointer border-0 hover:bg-gray-200 transition-colors">
              <%= t(".density_#{mode}") %>
            </button>
          <% end %>
        </div>
      </section>
    </div>
  </div>
<% end %>
