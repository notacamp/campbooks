<%= turbo_stream.replace dom_id(@tag) do %>
  <%= render "inbox_settings/tags/tag", tag: @tag, count: EmailMessageTag.where(tag_id: @tag.id).count %>
<% end %>
<%= turbo_stream.update "inbox_settings_tag_form", "" %>
<%= turbo_stream.append "action_toasts" do %>
  <%= render "shared/action_toast", message: t(".updated_toast"), variant: :success %>
<% end %>
