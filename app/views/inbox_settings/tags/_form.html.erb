<%# locals: tag %>
<% persisted = tag.persisted? %>
<%= form_with model: tag,
      url: (persisted ? inbox_settings_tag_path(tag) : inbox_settings_tags_path),
      method: (persisted ? :patch : :post),
      class: "rounded-lg border border-border bg-muted/30 p-4 mb-4 space-y-4" do |f| %>
  <% if tag.errors.any? %>
    <div class="rounded-md bg-red-50 dark:bg-red-500/10 text-xs text-red-700 dark:text-red-300 px-3 py-2">
      <%= tag.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :name, class: "block text-xs font-medium text-foreground mb-1" %>
      <%= f.text_field :name, autofocus: true,
            class: "block w-full rounded-md border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500" %>
    </div>
    <div>
      <%= f.label :group_name, t(".group_label"), class: "block text-xs font-medium text-foreground mb-1" %>
      <%= f.text_field :group_name, list: "tag_group_suggestions", placeholder: t(".group_placeholder"),
            class: "block w-full rounded-md border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500" %>
      <datalist id="tag_group_suggestions">
        <% Tag.group_names(Current.workspace).each do |name| %>
          <option value="<%= name %>">
        <% end %>
      </datalist>
    </div>
  </div>

  <div>
    <%= f.label :color, t(".color_label"), class: "block text-xs font-medium text-foreground mb-1" %>
    <div class="flex items-center gap-2">
      <%= f.text_field :color,
            oninput: "document.getElementById('tag_color_swatch').style.backgroundColor = this.value",
            class: "block w-32 rounded-md border-gray-300 shadow-sm text-sm font-mono focus:border-accent-500 focus:ring-accent-500" %>
      <span id="tag_color_swatch" class="w-6 h-6 rounded-full border border-border flex-shrink-0"
            style="background-color: <%= tag.color.presence || '#9ca3af' %>"></span>
    </div>
  </div>

  <div>
    <%= render "shared/markdown_editor", form: f, field: :prompt, rows: 3, label: t(".ai_prompt_label") %>
    <p class="text-xs text-muted-foreground mt-1"><%= t(".ai_prompt_hint") %></p>
  </div>

  <div class="flex items-center justify-end gap-2 pt-1">
    <button type="button" onclick="this.closest('turbo-frame').innerHTML = ''"
            class="px-3 py-1.5 text-xs font-medium rounded-lg border border-border text-gray-600 hover:bg-gray-50 dark:hover:bg-white/5 transition-colors cursor-pointer">
      <%= t(".cancel") %>
    </button>
    <%= render(Campbooks::Button.new(variant: :primary, size: :sm, type: :submit)) { persisted ? t("shared.actions.save_changes") : t(".create_tag") } %>
  </div>
<% end %>
