<%# Visible tags + a collapsible "Hidden labels" review (re-rendered whole on toggle). %>
<div id="inbox_settings_tags_rows">
  <% if @visible_tags.any? %>
    <% @visible_tags.each do |tag| %>
      <%= render "inbox_settings/tags/tag", tag: tag, count: @tag_message_counts[tag.id] || 0 %>
    <% end %>
  <% else %>
    <p id="inbox_settings_tags_empty" class="text-[13px] text-muted-foreground py-8 text-center">
      <%= t("inbox_settings.tags.index.no_tags") %>
    </p>
  <% end %>
</div>

<% if @hidden_system.any? || @hidden_filtered.any? %>
  <details class="mt-6 border-t border-border pt-4 group">
    <summary class="flex items-center gap-1.5 cursor-pointer list-none mb-1 select-none">
      <svg class="w-3 h-3 text-muted-foreground flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-xs font-semibold text-foreground"><%= t("inbox_settings.tags.index.hidden_heading") %></span>
      <span class="text-[11px] text-muted-foreground">· <%= t("inbox_settings.tags.index.hidden_hint") %></span>
    </summary>

    <% if @hidden_system.any? %>
      <p class="text-[11px] font-semibold uppercase tracking-wide text-muted-foreground mt-3 mb-1"><%= t("inbox_settings.tags.index.system_group") %></p>
      <% @hidden_system.each do |tag| %>
        <%= render "inbox_settings/tags/hidden_tag", tag: tag, count: @tag_message_counts[tag.id] || 0 %>
      <% end %>
    <% end %>

    <% if @hidden_filtered.any? %>
      <p class="text-[11px] font-semibold uppercase tracking-wide text-muted-foreground mt-4 mb-1"><%= t("inbox_settings.tags.index.filtered_group") %></p>
      <% @hidden_filtered.each do |tag| %>
        <%= render "inbox_settings/tags/hidden_tag", tag: tag, count: @tag_message_counts[tag.id] || 0 %>
      <% end %>
    <% end %>
  </details>
<% end %>
