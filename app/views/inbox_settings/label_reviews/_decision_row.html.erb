<%# locals: decision, workspace_tags %>
<div class="py-4">
  <%# Hidden default — will be overridden by whichever radio the user selects. %>
  <input type="hidden"
         name="decisions[<%= decision.id %>][decision]"
         value="kept">

  <div class="flex items-start gap-3 mb-3">
    <div class="flex-1 min-w-0">
      <p class="text-[13px] font-medium text-foreground"><%= decision.provider_label_name %></p>
      <div class="flex items-center gap-1 mt-0.5">
        <% if decision.email_account.google? %>
          <%= render(Campbooks::BrandLogo.new(brand: :google, size: :xs)) %>
        <% else %>
          <%= render(Campbooks::BrandLogo.new(brand: :zoho, size: :xs)) %>
        <% end %>
        <span class="text-xs text-muted-foreground"><%= decision.email_account.display_name %></span>
      </div>
    </div>
  </div>

  <div class="space-y-2 pl-1">
    <%# Option 1: Map to existing tag %>
    <label class="flex items-center gap-2 cursor-pointer group"
           data-controller="label-review-option">
      <input type="radio"
             name="decisions[<%= decision.id %>][decision]"
             value="mapped"
             class="text-foreground focus:ring-ring"
             data-label-review-option-target="radio"
             data-action="change->label-review-option#toggle">
      <span class="text-[13px] text-foreground">
        <%= t("inbox_settings.label_reviews.index.option_map") %>
      </span>
      <select name="decisions[<%= decision.id %>][tag_id]"
              disabled
              data-label-review-option-target="select"
              class="ml-1 flex-1 max-w-[200px] rounded border border-input bg-background px-2 py-1 text-xs
                     text-foreground disabled:opacity-40 focus:outline-none focus:ring-2 focus:ring-ring">
        <option value=""><%= t("inbox_settings.label_reviews.index.select_tag_placeholder") %></option>
        <% workspace_tags.each do |t_opt| %>
          <option value="<%= t_opt.id %>"><%= t_opt.name %></option>
        <% end %>
      </select>
    </label>

    <%# Option 2: Keep as its own tag (default) %>
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="radio"
             name="decisions[<%= decision.id %>][decision]"
             value="kept"
             checked
             class="text-foreground focus:ring-ring">
      <span class="text-[13px] text-foreground">
        <%= t("inbox_settings.label_reviews.index.option_keep") %>
      </span>
    </label>

    <%# Option 3: Ignore — no workspace tag %>
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="radio"
             name="decisions[<%= decision.id %>][decision]"
             value="ignored"
             class="text-foreground focus:ring-ring">
      <span class="text-[13px] text-muted-foreground">
        <%= t("inbox_settings.label_reviews.index.option_ignore") %>
      </span>
    </label>
  </div>
</div>
