<%# locals: rule %>
<% latest_run = rule.runs.max_by(&:created_at) %>
<% active_run = latest_run&.queued? || latest_run&.running? %>
<%# No src attribute here: the show response renders this same frame, and a
    frame whose src references its own URL is rejected by Turbo. The poller
    assigns src from its url value on the first tick instead. %>
<%= turbo_frame_tag dom_id(rule),
      data: (active_run ? { controller: "rule-run-poller",
                            "rule-run-poller-url-value": inbox_settings_rule_path(rule) } : {}) do %>
  <div class="flex items-start gap-3 py-3 px-1 border-b border-border last:border-0">
    <div class="min-w-0 flex-1 <%= "opacity-60" unless rule.enabled? %>">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[13px] font-medium text-foreground"><%= rule.name %></span>
        <% unless rule.enabled? %>
          <%= render(Campbooks::Badge.new(variant: :neutral, size: :sm)) { t(".paused") } %>
        <% end %>
      </div>

      <p class="text-xs text-muted-foreground mt-0.5">
        <%= email_rule_criteria_summary(rule) %>
      </p>

      <div class="flex items-center gap-1.5 flex-wrap mt-1.5">
        <% rule.tags.each do |tag| %>
          <span class="inline-flex items-center gap-1 text-[11px] font-medium bg-muted text-muted-foreground rounded px-1.5 py-0.5">
            <%= render(Campbooks::ColorDot.new(color: tag.color.presence || "#9ca3af", size: :sm)) %>
            <%= tag.name %>
          </span>
        <% end %>
        <% if rule.archive? %>
          <span class="inline-flex items-center gap-1 text-[11px] font-medium bg-muted text-muted-foreground rounded px-1.5 py-0.5">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8l6 6m0 0l6-6m-6 6V3m-7 18h14"/>
            </svg>
            <%= t(".archive_chip") %>
          </span>
        <% end %>
        <% if rule.mark_read? %>
          <span class="inline-flex items-center gap-1 text-[11px] font-medium bg-muted text-muted-foreground rounded px-1.5 py-0.5">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <%= t(".mark_read_chip") %>
          </span>
        <% end %>
        <% if rule.mail_folder.present? %>
          <span class="inline-flex items-center gap-1 text-[11px] font-medium bg-muted text-muted-foreground rounded px-1.5 py-0.5">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
            </svg>
            <%= rule.mail_folder.name %>
          </span>
        <% end %>
      </div>

      <%# Meta line: run progress, undo offer, or lifetime stats %>
      <% if active_run %>
        <p class="text-[11px] text-muted-foreground mt-1.5 flex items-center gap-1.5 tabular-nums"
           data-rule-run-progress>
          <svg class="w-3 h-3 opacity-60 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9" stroke-opacity=".25" stroke-width="3"/>
            <path d="M21 12a9 9 0 00-9-9" stroke-linecap="round" stroke-width="3"/>
          </svg>
          <%= t(".running_progress", processed: latest_run.processed_count, total: latest_run.matched_count) %>
        </p>
      <% elsif latest_run&.completed? && latest_run.undoable? %>
        <p class="text-[11px] text-muted-foreground mt-1.5 tabular-nums flex items-center gap-1">
          <%= t(".applied_count", count: latest_run.matched_count) %>
          <span aria-hidden="true">&middot;</span>
          <%= button_to t(".undo"),
                inbox_settings_undo_rule_run_path(rule_id: rule.id, id: latest_run.id),
                method: :post,
                class: "underline underline-offset-2 text-[11px] font-medium text-muted-foreground hover:text-foreground transition-colors cursor-pointer",
                data: { turbo_stream: true } %>
        </p>
      <% else %>
        <p class="text-[11px] text-muted-foreground mt-1.5 tabular-nums">
          <% if rule.matched_count > 0 %>
            <%= t(".matched_count", count: rule.matched_count) %>
            <% if rule.last_run_at.present? %>
              &middot; <%= t(".last_ran", time: time_ago_in_words(rule.last_run_at)) %>
            <% end %>
          <% elsif rule.last_run_at.present? %>
            <%= t(".last_ran", time: time_ago_in_words(rule.last_run_at)) %>
          <% else %>
            <%= t(".never_run_on_existing") %>
          <% end %>
        </p>
      <% end %>
    </div>

    <div class="flex items-center gap-1 flex-shrink-0 pt-0.5">
      <% unless active_run %>
        <%= button_to t(".run"), run_inbox_settings_rule_path(rule), method: :post,
              class: "px-2 py-0.5 text-xs font-medium text-muted-foreground hover:bg-muted rounded cursor-pointer transition-colors",
              data: { turbo_stream: true } %>
      <% end %>
      <%= link_to t(".edit"), edit_inbox_settings_rule_path(rule),
            data: { turbo_frame: "inbox_settings_rule_form" },
            class: "px-2 py-0.5 text-xs font-medium text-muted-foreground hover:bg-muted rounded cursor-pointer transition-colors" %>
      <%= button_to t(".delete"), inbox_settings_rule_path(rule), method: :delete,
            data: { turbo_confirm: t(".delete_confirm", name: rule.name), turbo_stream: true },
            class: "px-2 py-0.5 text-xs font-medium text-muted-foreground hover:bg-red-50 hover:text-red-600 dark:hover:bg-red-500/10 rounded cursor-pointer transition-colors" %>
      <%= button_to toggle_inbox_settings_rule_path(rule), method: :patch,
            class: "inline-flex items-center cursor-pointer flex-shrink-0 p-0.5",
            title: rule.enabled? ? t(".disable_rule") : t(".enable_rule"),
            aria: { label: rule.enabled? ? t(".disable_rule") : t(".enable_rule") },
            data: { turbo_stream: true } do %>
        <span class="w-8 h-5 rounded-full transition-colors relative block <%= rule.enabled? ? "bg-primary" : "bg-border" %>">
          <span class="block w-3.5 h-3.5 rounded-full bg-background shadow absolute top-[3px] transition-transform <%= rule.enabled? ? "translate-x-[14px]" : "translate-x-[3px]" %>"></span>
        </span>
      <% end %>
    </div>
  </div>
<% end %>
