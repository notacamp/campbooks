<%# Prefs form. Every checkbox auto-submits (auto-submit Stimulus controller),
    so there's no Save button; the turbo_stream response re-renders this
    partial and toasts. %>
<div id="smart_groups_panel" class="px-6 py-5">
  <%= form_with url: inbox_settings_smart_groups_path, method: :patch,
        data: { controller: "auto-submit" } do %>
    <section>
      <label class="flex items-center gap-2.5 py-1 cursor-pointer">
        <input type="hidden" name="smart_groups[enabled]" value="0">
        <input type="checkbox" name="smart_groups[enabled]" value="1"
               <%= "checked" if current_user.smart_groups_enabled? %>
               data-action="change->auto-submit#submit"
               class="w-4 h-4 rounded border-gray-300 text-accent-600 focus:ring-accent-500">
        <span class="text-[13px] font-medium text-foreground"><%= t(".master_toggle") %></span>
      </label>
      <p class="text-xs text-muted-foreground mt-1 mb-4"><%= t(".master_hint") %></p>
    </section>

    <section class="<%= "opacity-50 pointer-events-none" unless current_user.smart_groups_enabled? %>">
      <h4 class="text-xs font-semibold text-foreground mb-2"><%= t(".buckets_heading") %></h4>
      <div class="space-y-1">
        <% User::SMART_GROUP_BUCKETS.each do |bucket| %>
          <label class="flex items-center gap-2.5 py-1 cursor-pointer">
            <input type="hidden" name="smart_groups[<%= bucket %>]" value="0">
            <input type="checkbox" name="smart_groups[<%= bucket %>]" value="1"
                   <%= "checked" if current_user.inbox_smart_groups.fetch(bucket, true) %>
                   data-action="change->auto-submit#submit"
                   class="w-4 h-4 rounded border-gray-300 text-accent-600 focus:ring-accent-500">
            <%= render(Campbooks::CategoryChip.new(category: bucket.to_sym, size: :sm, label: false)) %>
            <span class="text-[13px] text-foreground"><%= t("components.category_chip.labels.#{bucket}") %></span>
          </label>
        <% end %>
      </div>
      <p class="text-xs text-muted-foreground mt-3"><%= t(".never_grouped_hint") %></p>
    </section>
  <% end %>
</div>
