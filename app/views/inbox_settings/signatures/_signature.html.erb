<%# locals: signature %>
<div class="rounded-lg border border-border p-3">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        <span class="text-[13px] font-medium text-foreground truncate"><%= signature.name %></span>
        <% if signature.is_default? %>
          <%= render(Campbooks::Badge.new(variant: :accent, size: :md)) { t(".default_badge") } %>
        <% end %>
      </div>
      <% if signature.email_accounts.any? %>
        <div class="flex flex-wrap items-center gap-1 mt-1">
          <% signature.email_accounts.each do |account| %>
            <%= render(Campbooks::Badge.new(variant: :neutral, size: :md)) { account.display_name } %>
          <% end %>
        </div>
      <% end %>
      <% if signature.content.present? %>
        <p class="text-xs text-muted-foreground mt-1.5 line-clamp-2"><%= strip_tags(signature.content).truncate(160) %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-1 flex-shrink-0">
      <% unless signature.is_default? %>
        <%= button_to t(".set_default"), set_default_inbox_settings_signature_path(signature), method: :post,
              class: "px-2 py-0.5 text-xs font-medium text-gray-600 hover:bg-accent-50 hover:text-accent-700 dark:hover:bg-accent-500/10 rounded cursor-pointer transition-colors" %>
      <% end %>
      <%= link_to t("shared.actions.edit"), edit_inbox_settings_signature_path(signature),
            data: { turbo_frame: "inbox_settings_signature_form" },
            class: "px-2 py-0.5 text-xs font-medium text-gray-600 hover:bg-gray-100 rounded cursor-pointer transition-colors" %>
      <%= button_to t("shared.actions.delete"), inbox_settings_signature_path(signature), method: :delete,
            data: { turbo_confirm: t(".delete_confirm") },
            class: "px-2 py-0.5 text-xs font-medium text-gray-500 hover:bg-red-50 hover:text-red-600 dark:hover:bg-red-500/10 rounded cursor-pointer transition-colors" %>
    </div>
  </div>
</div>
