<%= turbo_frame_tag "inbox_settings_panel" do %>
  <div data-section="filtering">
    <header class="sticky top-0 z-10 bg-background/95 backdrop-blur px-6 py-4 border-b border-border">
      <h3 class="text-sm font-semibold text-foreground"><%= t(".heading") %></h3>
      <p class="text-xs text-muted-foreground mt-0.5"><%= t(".subheading") %></p>
    </header>

    <div class="px-6 py-5 space-y-7">
      <!-- Strategy -->
      <section>
        <h4 class="text-xs font-semibold text-foreground mb-3"><%= t(".strategy_heading") %></h4>
        <%= form_with url: inbox_settings_filtering_path, method: :patch do |f| %>
          <div class="space-y-2">
            <% Workspace::INBOX_FILTER_STRATEGIES.each do |mode| %>
              <label class="flex items-start gap-3 rounded-xl border <%= @strategy == mode ? "border-accent-400 bg-accent-50/60 dark:bg-accent-500/10" : "border-border" %> px-3.5 py-3 cursor-pointer transition-colors">
                <%= f.radio_button :inbox_filter_strategy, mode, checked: @strategy == mode, class: "mt-0.5 h-4 w-4 text-accent-600 focus:ring-accent-500 border-gray-300" %>
                <span class="min-w-0">
                  <span class="block text-[13px] font-medium text-foreground"><%= t(".strategy.#{mode}.label") %></span>
                  <span class="block text-xs text-muted-foreground mt-0.5"><%= t(".strategy.#{mode}.desc") %></span>
                </span>
              </label>
            <% end %>
          </div>
          <div class="mt-3">
            <%= f.submit t(".save"), class: "inline-flex items-center rounded-lg bg-primary px-3.5 py-1.5 text-[13px] font-medium text-primary-foreground hover:bg-primary/90 cursor-pointer border-0" %>
          </div>
        <% end %>
      </section>

      <!-- Starred senders -->
      <section>
        <h4 class="text-xs font-semibold text-foreground mb-2"><%= t(".starred_heading") %></h4>
        <%= render "sender_list", contacts: @starred, state: "unstar", action_label: t(".unstar"), empty: t(".no_starred") %>
      </section>

      <!-- Blocked senders -->
      <section>
        <h4 class="text-xs font-semibold text-foreground mb-2"><%= t(".blocked_heading") %></h4>
        <p class="text-xs text-muted-foreground mb-2"><%= t(".blocked_hint") %></p>
        <%= render "sender_list", contacts: @blocked, state: "unblock", action_label: t(".unblock"), empty: t(".no_blocked") %>
      </section>

      <!-- Allowed senders (whitelist mode) -->
      <% if @strategy == "whitelist" %>
        <section>
          <h4 class="text-xs font-semibold text-foreground mb-2"><%= t(".allowed_heading") %></h4>
          <%= render "sender_list", contacts: @allowed, state: "neutral", action_label: t(".remove"), empty: t(".no_allowed") %>
        </section>
      <% end %>
    </div>
  </div>
<% end %>
