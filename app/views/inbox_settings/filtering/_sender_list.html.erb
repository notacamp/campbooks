<% if contacts.any? %>
  <ul class="divide-y divide-border rounded-xl border border-border">
    <% contacts.each do |contact| %>
      <li class="flex items-center justify-between gap-3 px-3.5 py-2">
        <span class="min-w-0">
          <span class="block truncate text-[13px] text-foreground"><%= contact.display_name %></span>
          <span class="block truncate text-xs text-muted-foreground"><%= contact.email %></span>
        </span>
        <%= button_to action_label,
              inbox_settings_filtering_sender_path,
              params: { contact_id: contact.id, state: state },
              class: "flex-shrink-0 rounded-lg border border-border px-2.5 py-1 text-xs font-medium text-foreground hover:bg-muted cursor-pointer" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-[13px] text-muted-foreground"><%= empty %></p>
<% end %>
