<%= turbo_frame_tag "inbox_settings_panel" do %>
  <div data-section="labels">
    <header class="sticky top-0 z-10 bg-background/95 backdrop-blur px-6 py-4 border-b border-border flex items-center justify-between gap-4">
      <div class="min-w-0">
        <h3 class="text-sm font-semibold text-foreground"><%= t(".heading") %></h3>
        <p class="text-xs text-muted-foreground mt-0.5"><%= t(".subtitle") %></p>
      </div>
      <% if @account %>
        <%= button_to t(".sync"), sync_inbox_settings_external_labels_path(email_account_id: @account.id), method: :post,
              class: "inline-flex items-center gap-1 rounded-lg border border-border px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-50 dark:hover:bg-white/5 cursor-pointer transition-colors" %>
      <% end %>
    </header>

    <div class="px-6 py-5 space-y-4">
      <% if @accounts.empty? %>
        <p class="text-[13px] text-muted-foreground py-8 text-center"><%= t(".no_accounts") %></p>
      <% else %>
        <% if @accounts.size > 1 %>
          <%= form_with url: inbox_settings_external_labels_path, method: :get, data: { turbo_frame: "inbox_settings_panel" } do %>
            <label class="block text-xs font-medium text-foreground mb-1"><%= t(".account_label") %></label>
            <select name="email_account_id" onchange="this.form.requestSubmit()"
                    class="block w-full rounded-md border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500">
              <% @accounts.each do |account| %>
                <option value="<%= account.id %>" <%= "selected" if account == @account %>><%= account.display_name %></option>
              <% end %>
            </select>
          <% end %>
        <% end %>

        <%= form_with url: inbox_settings_external_labels_path, method: :post,
              class: "flex items-end gap-2 rounded-lg border border-border bg-muted/30 p-3" do |f| %>
          <%= hidden_field_tag :email_account_id, @account&.id %>
          <div>
            <label class="block text-[11px] font-medium text-foreground mb-0.5"><%= t(".new_label_label") %></label>
            <%= f.text_field :name, required: true, placeholder: t(".new_label_placeholder"),
                  class: "block w-44 rounded-md border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500" %>
          </div>
          <div>
            <label class="block text-[11px] font-medium text-foreground mb-0.5"><%= t(".color_label") %></label>
            <%= f.color_field :color, value: "#ffd700", class: "block w-12 h-9 rounded-md border-gray-300 shadow-sm cursor-pointer p-0.5" %>
          </div>
          <%= render(Campbooks::Button.new(variant: :primary, size: :sm, type: :submit)) { t("shared.actions.add") } %>
        <% end %>

        <%= render "inbox_settings/external_labels/labels", labels: @labels, account: @account %>
      <% end %>
    </div>
  </div>
<% end %>
