<%# locals: labels, account %>
<div id="inbox_settings_labels_rows" class="space-y-2">
  <% if labels.any? %>
    <% labels.each do |label| %>
      <div class="flex items-center justify-between rounded-lg border border-border p-2.5">
        <div class="flex items-center gap-2.5 min-w-0">
          <span class="w-3.5 h-3.5 rounded-full flex-shrink-0" style="background-color: <%= label.color %>"></span>
          <span class="text-[13px] text-foreground truncate"><%= label.name %></span>
        </div>
        <%= button_to t("shared.actions.delete"), inbox_settings_external_label_path(label, email_account_id: account.id), method: :delete,
              data: { turbo_confirm: t(".delete_confirm") },
              class: "px-2 py-0.5 text-xs font-medium text-gray-500 hover:bg-red-50 hover:text-red-600 dark:hover:bg-red-500/10 rounded cursor-pointer transition-colors" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-[13px] text-muted-foreground py-6 text-center"><%= t(".empty") %></p>
  <% end %>
</div>
