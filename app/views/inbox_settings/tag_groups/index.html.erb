<%= turbo_frame_tag "inbox_settings_panel" do %>
  <div data-section="tag_groups">
    <header class="sticky top-0 z-10 bg-background/95 backdrop-blur px-6 py-4 border-b border-border flex items-center justify-between gap-4">
      <div class="min-w-0">
        <h3 class="text-sm font-semibold text-foreground"><%= t(".heading") %></h3>
        <p class="text-xs text-muted-foreground mt-0.5"><%= t(".subheading") %></p>
      </div>
      <%= render(Campbooks::Button.new(variant: :primary, size: :sm,
            href: inbox_settings_new_tag_group_path,
            data: { turbo_frame: "inbox_settings_tag_group_form" })) { t(".new_group") } %>
    </header>

    <div class="px-6 py-5">
      <%= turbo_frame_tag "inbox_settings_tag_group_form" %>

      <div id="inbox_settings_tag_groups_list">
        <% if @groups.any? %>
          <% @groups.each do |name, tags| %>
            <div class="flex items-start gap-3 py-3 border-b border-hair last:border-b-0">
              <span class="mt-1"><%= render(Campbooks::ColorDot.new(color: tags.first.color, size: :sm)) %></span>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 min-w-0">
                  <span class="text-[13px] font-medium text-foreground truncate"><%= name %></span>
                  <span class="text-[11px] text-muted-foreground flex-shrink-0"><%= t(".threads_count", count: @group_thread_counts[name] || 0) %></span>
                </div>
                <div class="mt-1.5 flex items-center gap-1 flex-wrap">
                  <% tags.each do |tag| %>
                    <%= render(Campbooks::TagChip.new(tag: tag, size: :sm)) %>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-0.5 flex-shrink-0">
                <%= link_to t(".edit"), inbox_settings_edit_tag_group_path(group: name),
                      class: "rounded-md px-2 py-1 text-[11px] font-medium text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors",
                      data: { turbo_frame: "inbox_settings_tag_group_form" } %>
                <%= button_to t(".ungroup"), inbox_settings_tag_groups_path(group: name), method: :delete,
                      form: { data: { turbo_frame: "inbox_settings_panel", turbo_confirm: t(".ungroup_confirm", name: name) } },
                      class: "rounded-md px-2 py-1 text-[11px] font-medium text-gray-500 hover:text-red-600 hover:bg-red-50 transition-colors cursor-pointer border-0 bg-transparent" %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p id="inbox_settings_tag_groups_empty" class="text-[13px] text-muted-foreground py-8 text-center">
            <%= t(".no_groups") %>
          </p>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
