<%# Lazy pagination: append the next page of events, then advance the cursor. %>
<%= turbo_stream.append "isc_rows" do %>
  <% @events.each do |event| %>
    <%= render(Campbooks::Activity::EventRow.new(event: event)) %>
  <% end %>
<% end %>

<% if @pagy.next %>
  <%= turbo_stream.replace "isc_pagination" do %>
    <%= turbo_frame_tag "isc_pagination",
          src: activity_path(page: @pagy.next, group: @group.presence, format: :turbo_stream),
          loading: :lazy do %>
      <div class="flex justify-center py-4"><%= render(Campbooks::Spinner.new(size: :sm)) %></div>
    <% end %>
  <% end %>
<% else %>
  <%= turbo_stream.remove "isc_pagination" %>
<% end %>
