<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= render(Campbooks::Logo.new(size: :lg)) %>
      <h1 class="text-xl font-semibold text-gray-900 mt-6"><%= t(".heading") %></h1>
      <p class="text-sm text-gray-600 mt-2"><%= t(".tagline") %></p>
    </div>

    <%= render(Campbooks::Card.new) do %>
      <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>
        <%= render(Campbooks::Input.new(:password, type: :password, label: t(".password_label"), placeholder: t(".password_placeholder"), required: true, autocomplete: "new-password")) %>

        <%= render(Campbooks::Input.new(:password_confirmation, type: :password, label: t(".password_confirmation_label"), placeholder: t(".password_confirmation_placeholder"), required: true, autocomplete: "new-password")) %>

        <div class="pt-1">
          <%= render(Campbooks::Button.new(variant: :primary, type: "submit", class: "w-full justify-center")) { t(".submit") } %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
