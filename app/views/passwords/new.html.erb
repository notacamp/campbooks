<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-block" do %>
        <%= render(Campbooks::Logo.new(size: :lg)) %>
      <% end %>
      <h1 class="text-xl font-semibold text-gray-900 mt-6"><%= t(".heading") %></h1>
      <p class="text-sm text-gray-600 mt-2"><%= t(".tagline") %></p>
    </div>

    <%= render(Campbooks::Card.new) do %>
      <%= form_with url: passwords_path, class: "space-y-5" do |form| %>
        <%= render(Campbooks::Input.new(:email_address, type: :email, label: t(".email_label"), placeholder: t(".email_placeholder"), required: true, autofocus: true, autocomplete: "email", value: params[:email_address])) %>

        <div class="pt-1">
          <%= render(Campbooks::Button.new(variant: :primary, type: "submit", class: "w-full justify-center")) { t(".submit") } %>
        </div>
      <% end %>

      <p class="mt-6 text-center text-sm">
        <%= link_to t(".back_to_sign_in"), new_session_path, class: "text-accent-600 hover:text-accent-700 font-medium" %>
      </p>
    <% end %>
  </div>
</div>
