<% content_for :main_class, "mx-auto flex w-full max-w-[26.5rem] flex-col justify-center px-5 py-10 min-h-svh" %>

<%= render "shared/auth_header", title: t(".title"), subtitle: t(".tagline") %>

<%# Native submit (turbo: false): sign-in redirects to the app (often
    root → onboarding, a different layout), which a Turbo form submission
    can silently fail to render — leaving the user stuck on the login page.
    Errors are shown via a flash redirect, so disabling Turbo here is safe. %>
<%= form_with url: session_url, class: "mt-9 space-y-5 animate-stage-in", data: { turbo: false }, html: { style: "--stage-delay: .16s" } do |form| %>
  <%= render(Campbooks::Input.new("email_address", type: :email, label: t(".email_label"), placeholder: t(".email_placeholder"), required: true, value: params[:email_address], autofocus: true, autocomplete: "email")) %>

  <%= render(Campbooks::Input.new("password", type: :password, label: t(".password_label"), placeholder: t(".password_placeholder"), required: true, autocomplete: "current-password")) %>

  <div class="pt-1">
    <%= render(Campbooks::Button.new(variant: :primary, type: "submit", size: :lg, class: "w-full justify-center")) { t(".submit") } %>
  </div>

  <p class="text-center text-sm">
    <%= link_to t(".forgot_password"), new_password_path, class: "font-medium text-muted-foreground hover:text-foreground" %>
  </p>
<% end %>

<div class="animate-stage-in" style="--stage-delay: .2s">
  <%= render(Campbooks::Divider.new(label: t(".or"), class: "my-6")) %>

  <%# In the native app, link straight to the provider authorize URL (built
      in the controller) so the system browser opens exactly once; on the
      web, use the normal /session/:provider redirect. %>
  <div class="space-y-2.5">
    <%= render(Campbooks::OauthButton.new(provider: :google, href: @oauth_urls&.dig(:google) || google_session_path, size: :lg)) %>
    <% if microsoft_enabled? %>
      <%= render(Campbooks::OauthButton.new(provider: :microsoft, href: @oauth_urls&.dig(:microsoft) || microsoft_session_path, size: :lg)) %>
    <% end %>
    <%= render(Campbooks::OauthButton.new(provider: :zoho, href: @oauth_urls&.dig(:zoho) || zoho_session_path, size: :lg)) %>
  </div>

  <% if public_signup_allowed? %>
    <% if hotwire_native_app? %>
      <%# Native apps are sign-in-only: self-serve account creation happens on
          the web so subscription billing stays outside Apple/Google in-app
          purchase (and to ease App Review). RegistrationsController guards this
          server-side too; invited users can still finish signing up in-app. %>
      <p class="mt-7 text-center text-sm text-muted-foreground">
        <%= t(".signup_on_web_html", link: link_to(t(".signup_on_web_link"), marketing_url("/"), class: "font-medium text-foreground hover:text-accent-700")) %>
      </p>
    <% else %>
      <p class="mt-7 text-center text-sm text-muted-foreground">
        <%= t(".no_account") %>
        <%= link_to t(".sign_up"), new_registration_path, class: "font-medium text-foreground hover:text-accent-700" %>
      </p>
    <% end %>
  <% end %>
</div>
