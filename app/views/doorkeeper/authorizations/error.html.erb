<%
  # Message comes either from our rescue_from (a raised DoorkeeperError, since
  # handle_auth_errors is :raise) or from Doorkeeper's own `render :error` path
  # (the deny/InvalidTokenStrategy case), which passes an `error_response` local.
  message = @authorize_error.presence
  if message.blank? && local_assigns[:error_response]
    body = (local_assigns[:error_response].body rescue nil)
    message = body.is_a?(Hash) ? body.dig(:error, :message) : local_assigns[:error_response].try(:description)
  end
  message = message.presence || t(".generic")
%>
<div class="w-full max-w-md">
  <div class="text-center mb-8">
    <%= render(Campbooks::Logo.new(size: :lg)) %>
  </div>

  <%= render(Campbooks::Card.new) do %>
    <div class="space-y-4 text-center">
      <h1 class="text-xl font-semibold text-gray-900"><%= t(".title") %></h1>
      <p class="text-sm text-gray-600"><%= message %></p>
      <p class="text-xs text-gray-400"><%= t(".retry_hint") %></p>
    </div>
  <% end %>
</div>
