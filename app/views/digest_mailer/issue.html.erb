<% colors = MailerStyleHelper::COLORS %>

<%# Greeting %>
<p style="<%= email_text_greeting %>"><%= t("digest_mailer.issue.greeting", name: @user.name) %></p>

<%# Overview (AI-generated or omitted in list mode) %>
<% if @issue.overview.present? %>
<p style="<%= email_text_body %>"><%= @issue.overview %></p>
<% end %>

<%# Sections %>
<% @sections.each do |section| %>
<p style="margin:0 0 8px; font-size:11px; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:<%= colors[:text_muted] %>;"><%= section[:title] %></p>

<table cellpadding="0" cellspacing="0" role="presentation" width="100%" style="margin:0 0 24px; background-color:<%= colors[:white] %>; border-radius:8px; border:1px solid <%= colors[:border] %>;">
  <tr>
    <td style="padding:6px 20px;">
      <% section[:items].each do |item| %>
        <table cellpadding="0" cellspacing="0" role="presentation" width="100%" style="margin:10px 0;">
          <tr>
            <td>
              <a href="<%= item[:url] %>" style="text-decoration:none; color:<%= colors[:text_heading] %>; font-size:15px; font-weight:600; line-height:1.3;"><%= item[:title] %></a>
              <% if item[:subtitle].present? || item[:note].present? %>
                <div style="margin-top:3px; color:<%= colors[:text_secondary] %>; font-size:13px; line-height:1.4;">
                  <% if item[:subtitle].present? %><span><%= item[:subtitle] %></span><% end %>
                  <% if item[:note].present? %>
                    <% if item[:subtitle].present? %> &middot; <% end %>
                    <%# Muted, not accent — notes are context, and Ember red reads as an alert. %>
                    <span style="color:<%= colors[:text_muted] %>; font-style:italic;"><%= item[:note] %></span>
                  <% end %>
                </div>
              <% end %>
            </td>
          </tr>
        </table>
      <% end %>
      <% if section[:overflow] > 0 %>
        <p style="margin:8px 0 10px; font-size:13px; color:<%= colors[:text_muted] %>;">
          <a href="<%= @manage_url %>" style="color:<%= colors[:text_muted] %>; text-decoration:underline;"><%= t("digest_mailer.issue.and_more", count: section[:overflow]) %></a>
        </p>
      <% end %>
    </td>
  </tr>
</table>
<% end %>

<%# Footer %>
<p style="margin:0; font-size:13px; color:<%= colors[:footer_text] %>;">
  <%= t("digest_mailer.issue.footer_html",
        manage_link: link_to(t("digest_mailer.issue.manage_link_label"), @manage_url,
                             style: "color:#{colors[:footer_text]}; text-decoration:underline;")).html_safe %>
</p>
