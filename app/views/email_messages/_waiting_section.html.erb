<%# The inbox "Waiting on replies" band — sticky frosted pill + rows, mirroring the
    Priority (pinned) section. The outer wrapper keeps a STABLE dom id even when
    empty so EmailMessagesController#dismiss_follow_up can Turbo-replace it (the band
    then vanishes once the last waiting thread is dismissed). Threads come from
    #waiting_thread_scope (EmailThread.awaiting_reply — pure data, no AI). %>
<% waiting_threads = local_assigns[:waiting_threads] || [] %>
<div id="waiting_replies_section">
  <% if waiting_threads.any? %>
    <div class="group/section px-1.5 py-1.5 sticky top-0 z-20 flex items-center pointer-events-none">
      <div class="pointer-events-auto inline-flex items-center rounded-full border border-gray-100 bg-card/75 px-3 py-1 shadow-sm backdrop-blur-md">
        <div class="flex-shrink-0 w-0 group-hover/section:w-5 [&:has(input:checked)]:w-5 [&:has(input:indeterminate)]:w-5 group-data-[select-mode=on]/select:w-5 overflow-hidden transition-all duration-150 flex items-center">
          <input type="checkbox"
                 class="w-3.5 h-3.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500 cursor-pointer bg-transparent"
                 data-action="change->email-selection#toggleSection"
                 data-email-selection-target="sectionToggle"
                 data-section="waiting_replies"
                 aria-label="<%= t("email_messages.thread_list.select_section", section: t("email_messages.thread_list.waiting_section")) %>"
                 title="<%= t("email_messages.thread_list.select_section", section: t("email_messages.thread_list.waiting_section")) %>">
        </div>
        <div class="flex items-center gap-1.5 min-w-0">
          <svg class="w-3 h-3 flex-shrink-0 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5V12l3 2"/></svg>
          <%= render(Campbooks::SectionHeader.new) { t("email_messages.thread_list.waiting_section") } %>
        </div>
      </div>
    </div>
    <%# Recent silences stay in the band; anything staler than 30 days folds away
        behind the disclosure below, keeping a floor of visible rows regardless of
        age (see EmailMessageHelpers#partition_waiting_threads). %>
    <% visible_threads, older_threads = partition_waiting_threads(waiting_threads) %>
    <% visible_threads.each do |thread| %>
      <% next unless thread.latest_message %>
      <%= render "email_messages/thread_row", thread: thread, section_key: "waiting_replies" %>
    <% end %>
    <% older_threads = older_threads.select(&:latest_message) %>
    <% if older_threads.any? %>
      <details class="group/older">
        <summary class="mx-1.5 my-0.5 inline-flex w-fit cursor-pointer select-none list-none items-center gap-1 rounded-md px-3 py-1.5 text-[12px] font-medium text-muted-foreground outline-none transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden">
          <svg class="h-3.5 w-3.5 flex-shrink-0 transition-transform duration-150 group-open/older:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          <span class="group-open/older:hidden"><%= t("email_messages.thread_list.waiting_show_older", count: older_threads.size) %></span>
          <span class="hidden group-open/older:inline"><%= t("email_messages.thread_list.waiting_hide_older") %></span>
        </summary>
        <% older_threads.each do |thread| %>
          <%= render "email_messages/thread_row", thread: thread, section_key: "waiting_replies" %>
        <% end %>
      </details>
    <% end %>
  <% end %>
</div>
