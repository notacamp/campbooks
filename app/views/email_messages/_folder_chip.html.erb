<%# A user-defined folder chip in the inbox folder bar. Doubles as a drag-and-drop
    / tap-to-move target (mail-folder-drop controller). Reused by the bar loop and
    appended on create. Locals: folder (MailFolder), active (bool). %>
<%= link_to email_messages_path(folder_name: folder.name),
      id: dom_id(folder, :folder_chip),
      data: {
        turbo_frame: "_top",
        mail_folder_drop_target: "chip",
        folder_name: folder.name,
        folder_active: active.to_s
      },
      class: class_names(
        "flex-shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium whitespace-nowrap transition-colors",
        active ? "bg-accent-600 text-white" : "bg-muted text-muted-foreground hover:bg-accent"
      ) do %>
  <%= folder.name %>
<% end %>
