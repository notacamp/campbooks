<%# locals: (message:) %>
<div class="relative" data-controller="dropdown">
  <%= button_tag type: "button",
        data: { action: "click->dropdown#toggle" },
        class: "inline-flex items-center gap-1 px-2 py-1 text-[11px] text-gray-400 hover:text-yellow-600 dark:hover:text-yellow-400 hover:bg-yellow-50 dark:hover:bg-yellow-500/10 rounded-md transition-colors cursor-pointer border-0",
        title: t(".snooze_title") do %>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
  <% end %>

  <div data-dropdown-target="panel" class="hidden absolute right-0 top-full mt-1 z-30 bg-card border border-gray-200 rounded-lg shadow-lg py-1 min-w-[200px]">
    <% snooze_presets.each do |_key, label, time| %>
      <%= button_to tool_email_message_path(message),
            method: :post,
            params: { tool: "snooze", args: { snoozed_until: time.iso8601 } },
            form: { data: { turbo: true } },
            class: "block w-full text-left text-[11px] px-3 py-1.5 hover:bg-gray-50 text-gray-700 transition-colors cursor-pointer border-0 bg-transparent" do %>
        <%= label %>
      <% end %>
    <% end %>
    <div class="border-t border-gray-100 my-1"></div>
    <div class="px-3 py-1.5">
      <%= form_tag tool_email_message_path(message), method: :post, data: { turbo: true }, class: "flex gap-1" do %>
        <%= hidden_field_tag :tool, "snooze" %>
        <input type="datetime-local" name="args[snoozed_until]" required
               class="flex-1 text-[10px] border border-gray-200 rounded px-1.5 py-0.5 focus:outline-none focus:border-accent-400"
               min="<%= Time.current.strftime('%Y-%m-%dT%H:%M') %>">
        <%= button_tag t(".ok"), type: "submit",
              class: "text-[10px] px-2 py-0.5 bg-accent-500 text-white rounded hover:bg-accent-600 cursor-pointer border-0" %>
      <% end %>
    </div>
  </div>
</div>
