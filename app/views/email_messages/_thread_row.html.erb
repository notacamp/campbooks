<%# Single inbox thread row, wrapped in Campbooks::Swipeable for swipe-to-act
    (swipe left: Archive → Snooze; swipe right: Trash → Delete-with-confirm).
    The Swipeable WRAPPER carries the dom_id / data-active / data-email-account-id
    and the active-highlight classes, so every removal path (swipe, keyboard,
    Scout, bulk, reply-daemon) clears the whole row and email_shortcuts_controller's
    highlight + navigation keep working against [id*="thread_item"].
    Extracted from _thread_list so the same markup serves the list, infinite scroll,
    and the swipe Undo (unarchive) restore. Locals: thread:, active: (optional). %>
<% latest = thread.latest_message %>
<% return unless latest %>
<% thread_messages = thread.email_messages %>
<% active = local_assigns.fetch(:active) { thread.id == @thread&.id } %>
<% unread = thread.unread? %>
<% messages_count = thread_messages.size %>
<% has_any_attachments = thread_messages.any?(&:has_attachment?) %>
<% total_attachments = thread_messages.sum { |m| m.files.size } %>
<% is_sent = latest.sent? %>
<% account = thread.email_account %>
<% pinned = thread.pinned? %>
<%# Facepile when the conversation has more than one sender (thread_messages is
    already loaded above, so participant_senders adds no query). %>
<% participants = thread.participant_senders(limit: 4) %>
<% multi_sender = participants.size > 1 %>

<%= render(Campbooks::Swipeable.new(
      id: dom_id(thread, :thread_item),
      class: "mx-1.5 rounded-xl transition-colors #{active ? 'bg-subtle' : 'hover:bg-muted'}",
      data: { email_account_id: account&.id }.merge(active ? { active: "true" } : {}),
      left: [
        { key: "archive", label: t("components.swipeable.archive"), icon: :archive, color: "blue",
          endpoint: tool_email_message_path(latest), params: { tool: "archive" },
          confirm: { title: t("components.swipeable.confirm_archive_title"),
                     message: t("components.swipeable.confirm_archive_message"), remember_key: "archive" } },
        { key: "snooze", label: t("components.swipeable.snooze"), icon: :snooze, color: "amber",
          endpoint: tool_email_message_path(latest), params: { tool: "snooze" }, picker: "snooze" }
      ],
      right: [
        { key: "trash", label: t("components.swipeable.trash"), icon: :trash, color: "orange",
          endpoint: tool_email_message_path(latest), params: { tool: "trash" },
          confirm: { title: t("components.swipeable.confirm_trash_title"),
                     message: t("components.swipeable.confirm_trash_message"), remember_key: "trash" } },
        { key: "delete", label: t("components.swipeable.delete"), icon: :delete, color: "red",
          endpoint: bulk_email_messages_path,
          params: { tool: "delete", "email_ids[]" => thread_messages.map(&:id) },
          confirm: { title: t("components.swipeable.confirm_delete_title"),
                     message: t("components.swipeable.confirm_delete_message") } }
      ]
    )) do %>
  <div class="flex items-center group">
    <!-- Drag handle (desktop) + checkbox area -->
    <div class="flex-shrink-0 w-0 group-hover:w-6 sm:group-hover:w-12 [&:has(input:checked)]:w-6 sm:[&:has(input:checked)]:w-12 group-data-[select-mode=on]/select:w-6 sm:group-data-[select-mode=on]/select:w-12 overflow-hidden transition-all duration-150 flex items-center gap-0.5 relative z-10 self-stretch pl-1.5">
      <%# Grab to move this email to a folder (drag onto a folder chip). Desktop
          only — mobile uses select + tap a chip. data-no-swipe so grabbing it
          doesn't start a row swipe; draggable handled by swipe_actions_controller. %>
      <span class="hidden sm:flex items-center justify-center w-4 shrink-0 cursor-grab active:cursor-grabbing text-gray-300 hover:text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity"
            draggable="true"
            data-drag-handle
            data-no-swipe
            data-email-ids="<%= thread_messages.map(&:id).join(",") %>"
            title="<%= t("email_messages.thread_list.drag_to_folder") %>"
            aria-hidden="true">
        <svg class="w-3 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><circle cx="5" cy="3" r="1.3"/><circle cx="11" cy="3" r="1.3"/><circle cx="5" cy="8" r="1.3"/><circle cx="11" cy="8" r="1.3"/><circle cx="5" cy="13" r="1.3"/><circle cx="11" cy="13" r="1.3"/></svg>
      </span>
      <input type="checkbox"
             class="w-3.5 h-3.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500 cursor-pointer opacity-0 group-hover:opacity-100 checked:opacity-100 group-data-[select-mode=on]/select:opacity-100 transition-opacity bg-transparent"
             data-action="change->email-selection#toggle"
             data-email-selection-target="checkbox"
             data-message-id="<%= latest.id %>"
             data-section="<%= local_assigns[:section_key] %>"
             value="<%= latest.id %>">
    </div>

    <%= link_to email_message_path(latest, folder_id: params[:folder_id].presence, group: params[:group].presence),
          class: "flex items-start px-3 flex-1 min-w-0 #{active ? 'text-accent-700' : ''}",
          style: "padding-top:var(--thread-py,0.8125rem);padding-bottom:var(--thread-py,0.8125rem);gap:var(--thread-gap,0.875rem)",
          data: { turbo_frame: "_top" } do %>
      <div class="relative shrink-0 mt-px">
        <% if multi_sender %>
          <%= render(Campbooks::ContactAvatarGroup.new(
                participants: participants, size: :lg, max: 3, variant: :neutral,
                account_color: account&.color
              )) %>
        <% else %>
          <%= render(Campbooks::ContactAvatar.new(
                email: latest.from_address || "?",
                sent: is_sent,
                size: :lg,
                contact_id: latest.contact_id,
                variant: :neutral,
                show_direction: true,
                account_color: account&.color
              )) %>
        <% end %>
        <% if unread && !active %>
          <%# Ember = "this wants you" (same signal as the nav-rail attention dot) %>
          <span class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 rounded-full bg-ember border-2 border-card"></span>
        <% end %>
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex items-start justify-between gap-1">
          <span class="text-gray-900 truncate <%= 'font-bold' if unread && !active %>" style="font-size:var(--thread-subject-size,13px);line-height:1.4"><%= latest.subject.presence || t("email_messages.thread_list.no_subject") %></span>
          <span class="text-gray-400 flex-shrink-0 <%= 'font-medium text-gray-600' if unread && !active %>" style="font-size:var(--thread-meta-size,10px);line-height:1.3"><%= thread_date_label(latest.received_at) %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <% if is_sent %>
            <span class="text-blue-500 dark:text-blue-400 flex-shrink-0" style="font-size:var(--thread-label-size,9px)"><%= t("email_messages.thread_list.sent_to_prefix") %></span>
            <% to_name = latest.to_address.presence %>
            <span class="text-blue-600 dark:text-blue-400 truncate" style="font-size:var(--thread-meta-size,10px)"><%= to_name ? clean_email_address(to_name) : (latest.from_address&.split("@")&.first || "-") %></span>
          <% else %>
            <span class="text-gray-500 truncate" style="font-size:var(--thread-meta-size,10px)"><%= latest.from_address&.split("@")&.first || "-" %></span>
          <% end %>
          <% if messages_count > 1 %>
            <span class="text-gray-400 flex-shrink-0" style="font-size:var(--thread-label-size,9px)"><%= messages_count %></span>
          <% end %>
          <% if has_any_attachments %>
            <span class="w-auto h-4 rounded-full bg-subtle text-muted-foreground flex items-center justify-center flex-shrink-0 px-1 gap-0.5 js-inbox-attachments">
              <svg style="width:7px;height:7px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
              <span style="font-size:var(--thread-label-size,8px);font-weight:600;line-height:1"><%= total_attachments %></span>
            </span>
          <% end %>
          <% latest.document_types.first(1).each do |dt| %>
            <span class="flex items-center gap-1 flex-shrink-0" style="font-size:var(--thread-label-size,9px);color:<%= dt.color %>">
              <%= render(Campbooks::ColorDot.new(color: dt.color, size: :sm)) %>
              <span class="font-medium"><%= dt.name.humanize %></span>
            </span>
          <% end %>
        </div>
        <div class="mt-0.5 flex items-center gap-1.5 flex-wrap js-inbox-labels" id="<%= dom_id(latest, :thread_tags) %>">
          <%= render "email_messages/thread_tags", message: latest %>
        </div>
      </div>
    <% end %>

    <%# Star toggle — pins this thread into the "Priority" section at the top of the
        inbox (same pinned_at as Skim's "Make priority"). Subtle until hovered on
        desktop; always visible (and gold) once pinned, so mobile can unpin too.
        data-no-swipe stops a tap here from starting a row swipe. %>
    <% pin_label = pinned ? t("email_messages.thread_list.unpin_title") : t("email_messages.thread_list.pin_title") %>
    <%= button_to tool_email_message_path(latest, tool: (pinned ? "unpin" : "pin"), folder_id: params[:folder_id].presence, group: params[:group].presence),
          method: :post,
          form: { class: "flex-shrink-0 self-stretch flex items-center", data: { no_swipe: true, turbo: true } },
          class: "flex items-center justify-center w-7 self-stretch cursor-pointer border-0 bg-transparent transition-colors #{pinned ? 'text-amber-500 hover:text-amber-600' : 'text-gray-300 hover:text-amber-500 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 sm:focus-within:opacity-100'}",
          data: { no_swipe: true },
          title: pin_label,
          "aria-label": pin_label,
          "aria-pressed": pinned.to_s do %>
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="<%= pinned ? "currentColor" : "none" %>" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.5a.56.56 0 011.04 0l2.12 4.92 5.34.46c.49.04.69.66.31.98l-4.05 3.5 1.21 5.22c.11.48-.41.86-.83.6L12 17.27l-4.63 2.91c-.42.26-.94-.12-.83-.6l1.21-5.22-4.05-3.5c-.38-.32-.18-.94.31-.98l5.34-.46 2.12-4.92z"/></svg>
    <% end %>
  </div>
<% end %>
