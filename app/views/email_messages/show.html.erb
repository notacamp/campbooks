<% content_for :cp_context, "email-show" %>
<% content_for :cp_message_id, @message.id.to_s %>
<% content_for :cp_folders, (@folders || []).select { |f| f[:id] }.map { |f| { id: f[:id], name: f[:name] } }.to_json %>
<% content_for :cp_subject, @message.subject.to_s.truncate(120) %>
<% content_for :shortcuts_message_id, @message.id.to_s %>
<% content_for :shortcuts_context, "show" %>

<%# The email_detail turbo frame wraps ONLY the reading pane (see below), so
    opening another email swaps just that pane — the thread list keeps its DOM,
    scroll position and selection. Everything out here renders once per full
    page load. %>
<div class="block h-full overflow-hidden">
  <div class="flex flex-col h-full" data-controller="scout-mobile email-mobile inbox-layout new-folder" data-email-mobile-breakpoint-value="1024" data-inbox-layout-board-src-value="<%= board_email_messages_path %>">
    <%# Top band — spans the list + reading panes: the Skim ring tray (full width, so
        the rings breathe instead of scrolling in a 256px column) plus the inbox's main
        actions, Search and Compose, on the right where primary actions live. On mobile
        it belongs to the list view (email-mobile `topband` target) so it hides while
        reading a message. %>
    <%# The band sits on the raw canvas (like home) rather than inside a bordered
        toolbar slab — in dark mode the work panes below read as elevated cards. %>
    <div data-email-mobile-target="topband" class="hidden lg:flex flex-col flex-shrink-0 border-b border-gray-100 bg-background">
      <div class="flex items-center gap-3 px-4 py-2">
        <div class="min-w-0 flex-1 max-w-2xl">
          <%= render(Campbooks::EmailSearchBar.new(search_params: @search_params, folders: @folders || [], accounts: @accounts || [], tags: @all_tags || [])) %>
        </div>
        <%= render(Campbooks::Button.new(variant: :primary, size: :sm, href: new_email_message_path, class: "flex-shrink-0 ml-auto", title: t(".compose_label"), data: { turbo_frame: "_top", action: "click->email-shortcuts#composeClick" })) do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.931-8.931z"/></svg>
          <span class="hidden sm:inline"><%= t(".compose_label") %></span>
          <kbd class="ml-1 hidden sm:inline-flex h-[18px] min-w-[18px] items-center justify-center rounded border border-white/30 px-1 text-[10px] font-semibold leading-none text-white/70" aria-hidden="true">C</kbd>
        <% end %>
      </div>
      <%# Skim ring tray — full width now. turbo_permanent + lazy so it persists across
          email navigations and never blocks the inbox. %>
      <%= turbo_frame_tag "skim_tray", src: skim_tray_path, loading: "lazy", class: "skim-compact block", data: { turbo_permanent: true } do %>
        <div class="flex items-center gap-4 px-4 py-2.5" aria-hidden="true">
          <% 5.times do %>
            <div class="flex flex-col items-center gap-1.5">
              <div class="h-12 w-12 animate-pulse rounded-full bg-gray-100 dark:bg-gray-800"></div>
              <div class="h-2 w-9 animate-pulse rounded bg-gray-100 dark:bg-gray-800"></div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Panes row: folder rail | thread list | reading pane | board -->
    <div class="flex flex-1 min-h-0">
    <%# Desktop folder pane (lg+); the mobile chip bar (below) covers < lg. The pane's
        "+" and the chip bar's "+" both open this single shared New Folder dialog. %>
    <%= render(Campbooks::FolderPane.new(system_folders: @common_folders, custom_folders: @mail_folders, current_folder: @current_folder, document_counts: MailFolder.document_counts(@mail_folders))) %>
    <%= render(Campbooks::NewFolderModal.new) %>
    <!-- Thread list (mobile: shown in list mode; desktop: always shown) -->
    <%# Below lg the whole pane scrolls so the folder bar + search scroll away
        with the list; at lg+ the pane is fixed and only the inner list scrolls. %>
    <div class="group/select hidden lg:flex w-full lg:w-64 flex-shrink-0 border-r border-gray-100 flex-col bg-card relative overflow-y-auto lg:overflow-visible"
         data-controller="email-selection panel-resize"
         data-email-mobile-target="list"
         data-inbox-pane="list"
         data-select-mode="off"
         data-action="keydown@window->email-selection#keydown click->email-selection#rowClick"
         data-panel-resize-edge-value="right"
         data-panel-resize-storage-key-value="campbooks:email-list-width"
         data-panel-resize-min-width-value="224"
         data-panel-resize-default-width-value="<%= inbox_list_width_px(@accounts) %>"
         data-panel-resize-max-width-value="560"
         data-panel-resize-min-viewport-value="1024">
      <%= render(Campbooks::ResizeHandle.new(edge: :right)) %>
      <%= render "mobile_folder_bar", with_modal: false, desktop_hidden: true %>
      <%# Live updates for the Skim tray: counts drop as you address mail, and new
          mail appears, without a manual reload. %>
      <%= turbo_stream_from "skim_#{current_user.id}" %>
      <%# Live inbox sync (Emails::InboxBroadcaster). "inbox_#{id}" carries the
          filter-safe ops — a row refresh or removal targeted by DOM id, which no-ops
          when the row isn't on this page — so every inbox view subscribes. The
          new-mail/restore INSERT ("inbox_feed_#{id}") is subscribed only on the
          unfiltered default inbox, so a folder/group/search view never gets a row
          floated in where it doesn't belong. %>
      <%= turbo_stream_from "inbox_#{current_user.id}" %>
      <% unless @search_active || @current_group.present? || @current_smart_group.present? || params[:folder_id].present? || params[:folder_name].present? %>
        <%= turbo_stream_from "inbox_feed_#{current_user.id}" %>
      <% end %>
      <%# Skim tray, Search and Compose now live in the content-spanning top band
          above the panes (see top of this file). %>
      <div class="px-2.5 py-1.5 border-b border-gray-100 relative">
        <div class="flex items-center justify-between gap-1">
          <div class="flex items-center gap-1.5 min-w-0 flex-1">
            <input type="checkbox"
                   class="w-3.5 h-3.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500 cursor-pointer flex-shrink-0"
                   data-action="change->email-selection#toggleAll"
                   data-email-selection-select-all>

            <!-- Header -->
            <div data-email-selection-target="header" class="flex items-center gap-2">
              <% if @current_group.present? %>
                <%= render(Campbooks::SectionHeader.new) { @current_group } %>
              <% else %>
                <%= render(Campbooks::SectionHeader.new) { t(".inbox_heading") } %>
              <% end %>
              <%= render(Campbooks::EmailAccountFilter.new(accounts: @accounts, class: "flex-shrink-0")) %>
            </div>

            <!-- Selection toolbar — replaces header when items selected -->
            <div data-email-selection-target="toolbar" class="hidden flex items-center gap-0.5 min-w-0 flex-1">
              <span class="text-[10px] font-semibold text-gray-700 flex-shrink-0" data-email-selection-target="count">0</span>

              <button type="button" data-tool="archive" data-action="click->email-selection#bulkAction"
                      class="flex-shrink-0 p-1 rounded hover:bg-gray-100 text-gray-500 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_tag_title") %>">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
              </button>

              <button type="button" data-tool="mark_read" data-action="click->email-selection#bulkAction"
                      class="flex-shrink-0 p-1 rounded hover:bg-gray-100 text-gray-500 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_mark_read_title") %>">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </button>

              <button type="button" data-tool="mark_unread" data-action="click->email-selection#bulkAction"
                      class="flex-shrink-0 p-1 rounded hover:bg-gray-100 text-gray-500 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_mark_unread_title") %>">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h18M3 8h18M3 12h12M3 16h18M3 20h18"/></svg>
              </button>

              <div class="relative flex-shrink-0">
                <button type="button" data-menu="tag" data-action="click->email-selection#toggleDropdown"
                        class="p-1 rounded hover:bg-gray-100 text-gray-500 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_tag_title") %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                </button>
                <div data-email-selection-target="tagMenu" class="hidden absolute left-0 top-full mt-1 z-30 bg-card/90 backdrop-blur-md border border-border rounded-xl shadow-lg py-1 min-w-[120px] max-h-40 overflow-y-auto">
                  <% @all_tags&.each do |tag| %>
                    <button type="button" data-tool="tag" data-tag-name="<%= tag.name %>" data-tag-action="add"
                            data-action="click->email-selection#bulkActionWithArgs"
                            class="block w-full text-left text-[10px] px-3 py-1.5 hover:bg-gray-50 text-gray-700 transition-colors cursor-pointer border-0 bg-transparent">
                      <%= render(Campbooks::ColorDot.new(color: tag.color, size: :sm)) %> <%= tag.name %>
                    </button>
                  <% end %>
                  <% if @all_tags.present? %>
                    <div class="border-t border-gray-100 my-0.5"></div>
                  <% end %>
                  <% @all_tags&.each do |tag| %>
                    <button type="button" data-tool="tag" data-tag-name="<%= tag.name %>" data-tag-action="remove"
                            data-action="click->email-selection#bulkActionWithArgs"
                            class="block w-full text-left text-[10px] px-3 py-1.5 hover:bg-gray-50 text-gray-500 transition-colors cursor-pointer border-0 bg-transparent">
                      <span class="text-red-400 dark:text-red-400">−</span> <%= tag.name %>
                    </button>
                  <% end %>
                </div>
              </div>

              <div class="relative flex-shrink-0">
                <button type="button" data-menu="folder" data-action="click->email-selection#toggleDropdown"
                        class="p-1 rounded hover:bg-gray-100 text-gray-500 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_move_folder_title") %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                </button>
                <div data-email-selection-target="folderMenu" class="hidden absolute left-0 top-full mt-1 z-30 bg-card/90 backdrop-blur-md border border-border rounded-xl shadow-lg py-1 min-w-[140px] max-h-40 overflow-y-auto">
                  <% @folders&.each do |folder| %>
                    <% next if folder[:id].nil? %>
                    <button type="button" data-tool="move_to_folder" data-folder-id="<%= folder[:id] %>"
                            data-action="click->email-selection#bulkActionWithArgs"
                            class="block w-full text-left text-[10px] px-3 py-1.5 hover:bg-gray-50 text-gray-700 transition-colors cursor-pointer border-0 bg-transparent">
                      <%= folder[:name] %>
                      <% if folder[:count] > 0 %><span class="text-gray-400 ml-1"><%= folder[:count] %></span><% end %>
                    </button>
                  <% end %>
                </div>
              </div>

              <div class="relative flex-shrink-0">
                <button type="button" data-menu="snooze" data-action="click->email-selection#toggleDropdown"
                        class="p-1 rounded hover:bg-yellow-50 dark:hover:bg-yellow-500/10 text-gray-500 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_snooze_title") %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </button>
                <div data-email-selection-target="snoozeMenu" class="hidden absolute left-0 top-full mt-1 z-30 bg-card/90 backdrop-blur-md border border-border rounded-xl shadow-lg py-1 min-w-[180px]">
                  <% snooze_presets.each do |_key, label, time| %>
                    <button type="button" data-tool="snooze" data-snoozed-until="<%= time.iso8601 %>"
                            data-action="click->email-selection#bulkActionWithArgs"
                            class="block w-full text-left text-[10px] px-3 py-1.5 hover:bg-gray-50 text-gray-700 transition-colors cursor-pointer border-0 bg-transparent">
                      <%= label %>
                    </button>
                  <% end %>
                </div>
              </div>

              <button type="button" data-tool="process_ai" data-action="click->email-selection#bulkAction"
                      class="flex-shrink-0 p-1 rounded hover:bg-accent-50 text-gray-500 hover:text-accent-600 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_send_to_scout_title") %>">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/></svg>
              </button>

              <button type="button" data-tool="scout_chat" data-action="click->email-selection#bulkAction"
                      class="flex-shrink-0 p-1 rounded hover:bg-blue-50 dark:hover:bg-blue-500/10 text-gray-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_scout_chat_title") %>">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              </button>

              <button type="button" data-tool="delete" data-action="click->email-selection#bulkAction"
                      class="flex-shrink-0 p-1 rounded hover:bg-red-50 dark:hover:bg-red-500/10 text-gray-500 hover:text-red-500 dark:hover:text-red-400 transition-colors cursor-pointer border-0 bg-transparent" title="<%= t(".toolbar_delete_title") %>">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>

              <button type="button" data-action="click->email-selection#clear"
                      class="flex-shrink-0 p-1 rounded hover:bg-gray-100 text-gray-400 transition-colors cursor-pointer border-0 bg-transparent ml-0.5" title="<%= t(".toolbar_clear_selection_title") %>">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          </div>

          <%# Select mode — flips the inbox into batch-organize: persistent
              checkboxes on every row + section, and tap-a-row-to-select (so it
              works on touch). Active state is driven purely by data-select-mode
              on the email-selection root. %>
          <button type="button"
                  data-email-selection-target="selectToggle"
                  data-action="click->email-selection#toggleMode"
                  aria-pressed="false"
                  title="<%= t(".select_mode_title") %>"
                  aria-label="<%= t(".select_mode_title") %>"
                  class="flex-shrink-0 mr-0.5 inline-flex items-center justify-center rounded-lg p-1.5 transition-colors cursor-pointer border-0 bg-transparent text-muted-foreground hover:text-foreground hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-accent-500 group-data-[select-mode=on]/select:bg-accent-100 group-data-[select-mode=on]/select:text-accent-700 dark:group-data-[select-mode=on]/select:bg-accent-500/15 dark:group-data-[select-mode=on]/select:text-accent-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="4" y="4" width="16" height="16" rx="3" stroke-width="1.8"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8.5 12.4l2.2 2.2 4.8-5.2"/>
            </svg>
          </button>

          <%= render(Campbooks::InboxViewSwitcher.new(class: "flex-shrink-0 mr-0.5")) %>

          <%= render(Campbooks::IconButton.new(aria_label: t(".inbox_settings_aria"), size: :sm, data: { action: "click->inbox-settings-modal#open" })) do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          <% end %>
        </div>
      </div>
      <div class="lg:flex-1 lg:overflow-y-auto lg:min-h-0">
        <%= turbo_frame_tag "email_search_results" do %>
          <% if @search_active %>
            <%= render partial: "search_results", locals: { messages: @messages, search_params: @search_params, pagy: @pagy } %>
          <% else %>
            <div id="email_threads" data-controller="email-thread" data-inbox-view-mode="breathable">
              <% if @threads.any? || @pinned_threads&.any? || @waiting_threads&.any? %>
                <%= render partial: "thread_list", locals: { threads: @threads, current_group: @current_group, tag_groups: @tag_groups, pinned_threads: @pinned_threads, waiting_threads: @waiting_threads, group_items: @group_items, smart_group_items: @smart_group_items, current_smart_group: @current_smart_group } %>
              <% else %>
                <%= render(Campbooks::EmptyState.new(variant: :inline, class: "p-6")) do %>
                  <p class="text-[11px] text-gray-400"><%= t(".no_emails_yet") %></p>
                <% end %>
              <% end %>
            </div>
            <% if @threads.any? && @pagy&.next %>
              <%= render partial: "threads_pagination", locals: { pagy: @pagy, threads: @threads } %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Email detail + chat: the in-place navigation frame. Row clicks and
         arrow-key navigation load only this pane (see show_detail.html.erb);
         email-mobile#frameLoad flips mobile back to the detail view after an
         in-frame swap from the revealed list. -->
    <%= turbo_frame_tag "email_detail",
          class: "flex flex-1 min-w-0",
          style: "height:100%",
          data: { email_mobile_target: "detail", inbox_pane: "detail", detail_nav: "always",
                  action: "turbo:frame-load->email-mobile#frameLoad" } do %>
      <%= render "detail_pane" %>
    <% end %>

    <!-- Board layout: status kanban (revealed by CSS when data-inbox-layout="board") -->
    <%= turbo_frame_tag "inbox_board", class: "hidden flex-1 min-w-0 bg-muted/30", data: { inbox_layout_target: "boardFrame", inbox_pane: "board" } do %>
      <div class="flex items-center justify-center h-full">
        <%= render(Campbooks::Spinner.new(size: :md)) %>
      </div>
    <% end %>
    </div>
    <%# /panes row %>

<!-- Scout mobile overlay backdrop -->
<div data-scout-mobile-target="backdrop" data-action="click->scout-mobile#close"
     class="hidden lg:hidden fixed inset-0 top-14 z-40 bg-black/40 backdrop-blur-sm"></div>

  </div>
</div>
