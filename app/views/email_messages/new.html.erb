<%= turbo_frame_tag "email_detail", class: "block h-full" do %>
  <div class="flex h-full" data-controller="email-sidebar scout-mobile">
    <!-- Folder apparatus: hidden on mobile -->
    <div class="hidden lg:flex flex-shrink-0">
    <!-- Folder sidebar (collapsible) -->
    <div class="hidden flex-shrink-0 border-r border-gray-200 bg-card flex flex-col transition-all duration-200" data-email-sidebar-target="sidebar" style="width: 200px">
      <div class="px-3 py-2.5 border-b border-gray-100 flex items-center justify-between">
        <%= render(Campbooks::SectionHeader.new) { t(".folders_heading") } %>
        <%= render(Campbooks::IconButton.new(aria_label: t(".collapse_sidebar_aria"), size: :sm, data: { action: "click->email-sidebar#toggle" })) do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7"/></svg>
        <% end %>
      </div>
      <div class="flex-1 overflow-y-auto py-1 px-2">
        <% @common_folders&.each do |folder| %>
          <% active = (@current_folder == folder[:id]) || (folder[:id].nil? && @current_folder.nil?) %>
          <%= render(Campbooks::FolderItem.new(
                label: folder[:name],
                href: email_messages_path(folder_id: folder[:id]),
                count: folder[:count],
                active: active,
                data: { turbo_frame: "_top" }
              )) do |item| %>
            <% item.with_icon { folder_icon(folder[:name], active) } %>
          <% end %>
        <% end %>
        <%# All folder %>
        <%= render(Campbooks::FolderItem.new(
              label: t(".all_folder_label"),
              href: email_messages_path(folder_id: "all"),
              active: @current_folder == "all",
              data: { turbo_frame: "_top" }
            )) do |item| %>
          <% item.with_icon { folder_icon("All", @current_folder == "all") } %>
        <% end %>
      </div>
    </div>

    <!-- Collapsed folder icons -->
    <div class="flex-shrink-0 border-r border-gray-200 bg-card py-3 px-1 flex flex-col items-center gap-1.5" data-email-sidebar-target="collapsedToggle">
      <%= render(Campbooks::IconButton.new(aria_label: t(".expand_sidebar_aria"), size: :md, data: { action: "click->email-sidebar#toggle" }, class: "mb-1")) do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7"/></svg>
      <% end %>
      <% @common_folders&.each do |folder| %>
        <% active = (@current_folder == folder[:id]) || (folder[:id].nil? && @current_folder.nil?) %>
        <%= render(Campbooks::CollapsedFolderItem.new(
              label: folder[:name],
              href: email_messages_path(folder_id: folder[:id]),
              count: folder[:count],
              active: active,
              data: { turbo_frame: "_top" }
            )) do %>
          <%= folder_icon_small(folder[:name]) %>
        <% end %>
      <% end %>
      <%# All folder %>
      <%= render(Campbooks::CollapsedFolderItem.new(
            label: t(".all_folder_label"),
            href: email_messages_path(folder_id: "all"),
            active: @current_folder == "all",
            data: { turbo_frame: "_top" }
          )) do %>
        <%= folder_icon_small("All") %>
      <% end %>
    </div>
    </div>

    <!-- Thread list (hidden on mobile — compose is the focus) -->
    <div class="hidden lg:flex w-64 flex-shrink-0 border-r border-gray-200 flex-col bg-card">
      <div class="px-3 py-2 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <%= render(Campbooks::SectionHeader.new) { t(".inbox_heading") } %>
          <%= render(Campbooks::EmailAccountFilter.new(accounts: @accounts)) %>
        </div>
        <%= render(Campbooks::IconButton.new(aria_label: t(".inbox_settings_aria"), size: :sm, data: { action: "click->inbox-settings-modal#open" })) do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        <% end %>
      </div>
      <div class="flex-1 overflow-y-auto">
        <div id="email_threads" data-controller="email-thread" data-inbox-view-mode="breathable">
          <% if @threads&.any? %>
            <%= render partial: "thread_list", locals: { threads: @threads } %>
          <% else %>
            <%= render(Campbooks::EmptyState.new(variant: :inline, class: "p-6")) do %>
              <p class="text-[11px] text-gray-400"><%= t(".no_emails_yet") %></p>
            <% end %>
          <% end %>
        </div>
        <% if @threads&.any? && @pagy&.next %>
          <%= render partial: "threads_pagination", locals: { pagy: @pagy, threads: @threads } %>
        <% end %>
      </div>
    </div>

    <!-- Center: compose + chat -->
    <div class="flex flex-1 min-w-0" style="height:100%" data-controller="compose-chat">
      <!-- Compose form -->
      <div class="flex-1 flex flex-col min-w-0">
        <% if @account %>
          <%= form_with url: send_new_email_messages_path, method: :post,
                data: { controller: "compose-area", action: "submit->compose-area#validateForm", turbo: "true" },
                class: "flex-1 flex flex-col min-h-0" do |f| %>

            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <input type="hidden" name="email_account_id" value="<%= @account.id %>">

            <!-- Header: "New Message" -->
            <div class="px-5 py-4 border-b border-gray-200 flex-shrink-0 flex items-center justify-between gap-2">
              <div class="flex items-center gap-2 min-w-0">
                <%= link_to email_messages_path, data: { turbo_frame: "_top" }, class: "lg:hidden inline-flex items-center text-accent-600 flex-shrink-0" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                <% end %>
                <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                <span class="text-xs font-medium text-gray-700"><%= t(".new_message_heading") %></span>
              </div>
              <button type="button" data-action="click->scout-mobile#open"
                      class="lg:hidden inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-blue-50 text-blue-600 dark:bg-blue-500/10 dark:text-blue-400 cursor-pointer flex-shrink-0">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M9 4.5a.75.75 0 01.721.544l.813 2.846a3.75 3.75 0 002.576 2.576l2.846.813a.75.75 0 010 1.442l-2.846.813a3.75 3.75 0 00-2.576 2.576l-.813 2.846a.75.75 0 01-1.442 0l-.813-2.846a3.75 3.75 0 00-2.576-2.576l-2.846-.813a.75.75 0 010-1.442l2.846-.813A3.75 3.75 0 007.466 7.89l.813-2.846A.75.75 0 019 4.5z" clip-rule="evenodd"/></svg>
                <%= t(".scout_label") %>
              </button>
            </div>

            <!-- Fields area -->
            <div class="px-5 py-3 space-y-2 flex-shrink-0 border-b border-gray-100">
              <!-- From -->
              <div class="flex items-start gap-2">
                <label class="w-10 text-xs font-medium text-gray-500 pt-1.5 flex-shrink-0 text-right"><%= t(".from_label") %></label>
                <select name="email_account_id" data-action="change->compose-chat#onFromAccountChange" class="flex-1 min-w-0 text-sm bg-card border border-gray-200 rounded-md px-2.5 py-1 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500">
                  <% @sendable_accounts.each do |acct| %>
                    <option value="<%= acct.id %>" <%= "selected" if acct == @account %>><%= acct.select_label %></option>
                  <% end %>
                </select>
              </div>

              <!-- To -->
              <div class="flex items-start gap-2">
                <label class="w-10 text-xs font-medium text-gray-500 pt-1.5 flex-shrink-0 text-right"><%= t(".to_label") %></label>
                <%= render(Campbooks::ContactPillInput.new(
                  name: "to_address",
                  value: "",
                  placeholder: t(".to_placeholder")
                )) %>
              </div>

              <!-- Cc -->
              <div class="flex items-start gap-2" data-controller="toggle-visibility">
                <label class="w-10 text-xs font-medium text-gray-500 pt-1.5 flex-shrink-0 text-right"><%= t(".cc_label") %></label>
                <div class="flex-1 min-w-0 flex items-center gap-2">
                  <div class="flex-1 min-w-0">
                    <%= render(Campbooks::ContactPillInput.new(
                      name: "cc_address",
                      value: "",
                      placeholder: t(".cc_placeholder")
                    )) %>
                  </div>
                  <button type="button"
                          class="text-[10px] text-gray-400 hover:text-gray-600 font-medium flex-shrink-0"
                          data-action="click->toggle-visibility#toggle"
                          data-toggle-visibility-target="toggle"><%= t(".bcc_toggle_label") %></button>
                </div>
              </div>

              <!-- Bcc -->
              <div class="hidden items-start gap-2" data-toggle-visibility-target="content">
                <label class="w-10 text-xs font-medium text-gray-500 pt-1.5 flex-shrink-0 text-right"><%= t(".bcc_label") %></label>
                <%= render(Campbooks::ContactPillInput.new(
                  name: "bcc_address",
                  value: "",
                  placeholder: t(".bcc_placeholder")
                )) %>
              </div>

              <!-- Subject -->
              <div class="flex items-start gap-2">
                <label class="w-10 text-xs font-medium text-gray-500 pt-1.5 flex-shrink-0 text-right"><%= t(".subject_label") %></label>
                <input type="text" name="subject" placeholder="<%= t(".subject_placeholder") %>"
                       class="flex-1 min-w-0 text-sm font-medium bg-card border border-gray-200 rounded-md px-2.5 py-1 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500">
              </div>

              <!-- Signature -->
              <div class="flex items-start gap-2">
                <label class="w-10 text-xs font-medium text-gray-500 pt-1.5 flex-shrink-0 text-right"><%= t(".signature_label") %></label>
                <select name="signature_id" data-compose-chat-target="signatureSelect" data-action="change->compose-chat#selectSignature"
                       class="flex-1 min-w-0 text-sm bg-card border border-gray-200 rounded-md px-2.5 py-1 focus:outline-none focus:border-accent-500 focus:ring-1 focus:ring-accent-500">
                  <option value=""><%= t(".no_signature_option") %></option>
                  <% @signatures.each do |sig| %>
                    <option value="<%= sig.id %>"
                            data-content="<%= sig.content %>"
                            data-account-ids="<%= sig.email_account_ids.join(',') %>"
                            data-default="<%= sig.is_default? %>"
                            <%= "selected" if sig == @signature %>><%= sig.name %><%= " #{t(".signature_default_suffix")}" if sig.is_default? %></option>
                  <% end %>
                </select>
              </div>
            </div>

            <!-- Rich-text editor (fills remaining space) -->
            <div class="flex-1 overflow-hidden px-5 py-3">
              <%= render Campbooks::RichTextEditor.new(
                    input_name: "body",
                    content: "",
                    placeholder: t(".write_message_placeholder"),
                    upload_url: compose_images_path,
                    wrapper_class: "h-full flex flex-col",
                    editor_class: "flex-1 overflow-y-auto"
                  ) %>
            </div>

            <!-- Attachments -->
            <div class="px-5 pb-2 flex-shrink-0">
              <%= render Campbooks::ComposeAttachments.new(upload_url: compose_attachments_path) %>
            </div>

            <!-- Signature preview -->
            <div id="signature_preview" class="px-5 pb-3 flex-shrink-0">
              <% if @signature %>
                <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wide"><%= t(".signature_preview_heading") %></div>
                <div class="text-xs text-gray-500 border border-gray-200 rounded-md p-2.5 bg-gray-50 dark:bg-gray-500/10 max-h-20 overflow-y-auto">
                  <%= raw @signature.content %>
                </div>
              <% end %>
            </div>

            <!-- Actions -->
            <div class="px-5 py-3 border-t border-gray-200 flex-shrink-0 flex items-center gap-2">
              <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium bg-accent-600 text-white rounded-lg hover:bg-accent-700 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                <%= t("shared.actions.send") %>
              </button>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center justify-center flex-1">
            <%= render(Campbooks::EmptyState.new(variant: :card, title: t(".no_sendable_accounts_title"), description: t(".no_sendable_accounts_description"))) %>
          </div>
        <% end %>
      </div>

      <!-- Chat panel (Scout AI) — hidden on mobile; opened as overlay -->
      <div class="hidden lg:flex flex-shrink-0 border-l-2 border-blue-200 dark:border-blue-500/25 flex-col bg-card transition-all duration-200 w-96"
           data-controller="chat-panel"
           data-scout-mobile-target="panel">
        <div class="px-4 py-3 border-b border-gray-200 flex-shrink-0 flex items-center gap-1.5">
          <div class="hidden lg:block">
            <%= render(Campbooks::IconButton.new(aria_label: t(".toggle_chat_aria"), size: :sm, class: "hover:bg-gray-100", data: { action: "click->chat-panel#toggle" })) do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-chat-panel-target="icon">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
              </svg>
            <% end %>
          </div>
          <svg class="w-3.5 h-3.5 text-blue-500 dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M9 4.5a.75.75 0 01.721.544l.813 2.846a3.75 3.75 0 002.576 2.576l2.846.813a.75.75 0 010 1.442l-2.846.813a3.75 3.75 0 00-2.576 2.576l-.813 2.846a.75.75 0 01-1.442 0l-.813-2.846a3.75 3.75 0 00-2.576-2.576l-2.846-.813a.75.75 0 010-1.442l2.846-.813A3.75 3.75 0 007.466 7.89l.813-2.846A.75.75 0 019 4.5zM18 1.5a.75.75 0 01.728.568l.258 1.036c.236.94.88 1.584 1.82 1.82l1.036.258a.75.75 0 010 1.456l-1.036.258c-.94.236-1.584.88-1.82 1.82l-.258 1.036a.75.75 0 01-1.456 0l-.258-1.036a2.625 2.625 0 00-1.82-1.82l-1.036-.258a.75.75 0 010-1.456l1.036-.258a2.625 2.625 0 001.82-1.82l.258-1.036A.75.75 0 0118 1.5zM16.5 15a.75.75 0 01.712.513l.394 1.183c.15.447.5.799.948.948l1.183.395a.75.75 0 010 1.422l-1.183.395c-.447.15-.799.5-.948.948l-.395 1.183a.75.75 0 01-1.422 0l-.395-1.183a1.5 1.5 0 00-.948-.948l-1.183-.395a.75.75 0 010-1.422l1.183-.395a1.5 1.5 0 00.948-.948l.395-1.183A.75.75 0 0116.5 15z" clip-rule="evenodd"/>
          </svg>
          <span class="text-[12px] font-semibold text-gray-700"><%= t(".scout_label") %></span>
          <span class="hidden lg:inline text-[10px] text-gray-400 ml-auto"><%= t(".scout_keyboard_hint") %></span>
          <button type="button" data-action="click->scout-mobile#close" aria-label="<%= t(".close_scout_aria") %>"
                  class="lg:hidden ml-auto inline-flex items-center justify-center w-7 h-7 rounded-md text-gray-400 hover:text-gray-600 hover:bg-gray-100 cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <%= turbo_stream_from "compose_chat_#{current_user.id}" %>

        <div data-chat-panel-target="body" class="flex flex-col flex-1 min-h-0">
          <div id="compose_messages_wrapper" class="flex flex-col flex-1 min-h-0">
            <%= render "email_compose_chat/messages_panel", thread: @compose_thread, messages: @compose_messages %>
          </div>
        </div>
      </div>
    </div>

    <!-- Scout mobile overlay backdrop -->
    <div data-scout-mobile-target="backdrop" data-action="click->scout-mobile#close"
         class="hidden lg:hidden fixed inset-0 top-14 z-40 bg-black/40"></div>

    <div>
        <div id="redirect_script"></div>
  </div>
<% end %>
