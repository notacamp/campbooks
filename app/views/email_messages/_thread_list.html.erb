<% current_group = local_assigns[:current_group] %>
<% tag_groups = local_assigns[:tag_groups] || {} %>
<%# Collapsed tag-group rows injected into the list (default + custom groups). %>
<% group_items = local_assigns[:group_items] || [] %>
<%# When this page continues an earlier one (infinite scroll), the previous page's
    last section label is passed in so we don't repeat its sticky header. %>
<% continue_section = local_assigns[:continue_section] %>

<%# Group context band: back to the inbox + bulk clear actions. The group's
    name lives in the list toolbar above (with its color dot), so this band
    stays a single quiet row — same ghost-button vocabulary as the selection
    toolbar. %>
<% if current_group.present? %>
  <div class="flex items-center justify-between gap-1 px-1.5 py-1">
    <%# Icon-only back (like the selection-toolbar buttons) — the list pane can be
        ~220px with the reading pane open, too tight for a label; the group header
        directly above keeps the context and title/aria carry the name. %>
    <%= link_to email_messages_path(folder_id: params[:folder_id].presence),
          class: "flex items-center justify-center p-1.5 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors flex-shrink-0",
          title: t(".back_to_inbox_label"),
          "aria-label": t(".back_to_inbox_label"),
          data: { turbo_frame: "_top" } do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <%# data-turbo:false — a Turbo submit would carry its turbo-stream Accept
        header through the redirect into `index`, which would answer with the
        infinite-scroll APPEND and duplicate the section pills. Classic form
        nav gets the normal full-page flow (cf. the drawer deep-link gotcha).
        The group name rides as a hidden `group` param so "&"/spaces survive. %>
    <div class="flex items-center gap-0.5 flex-shrink-0">
      <%= button_to tag_group_mark_all_read_path,
            params: { group: current_group },
            form: { data: { turbo: false } },
            class: "inline-flex items-center gap-1 rounded-md px-1.5 py-1 text-[11px] font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors cursor-pointer border-0 bg-transparent" do %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <%= t(".mark_all_read") %>
      <% end %>
      <%= button_to tag_group_archive_all_path,
            params: { group: current_group },
            form: { data: { turbo: false } },
            class: "inline-flex items-center gap-1 rounded-md px-1.5 py-1 text-[11px] font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors cursor-pointer border-0 bg-transparent" do %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
        <%= t(".archive_all") %>
      <% end %>
    </div>
  </div>
<% end %>

<%# Pinned ("Priority") threads — a sticky section pinned above the date sections.
    Only rendered when the caller passes the local (page 1); the infinite-scroll
    pages omit it so it never repeats, and they exclude pinned threads entirely. %>
<% pinned_threads = local_assigns[:pinned_threads] || [] %>
<% if pinned_threads.any? %>
  <div id="pinned_section">
    <%# Floating section label — sticky, calendar-style: quiet uppercase text, no
        border/shadow box. The soft blur backdrop exists only for legibility while
        rows scroll beneath. pointer-events pass through the transparent strip;
        only the label itself is interactive, so rows sliding under stay clickable. %>
    <div class="group/section px-1.5 pt-3 pb-1 sticky top-0 z-20 flex items-center pointer-events-none">
      <div class="pointer-events-auto inline-flex items-center rounded-full bg-card/80 px-2 py-1 backdrop-blur-md">
        <div class="flex-shrink-0 w-0 group-hover/section:w-5 [&:has(input:checked)]:w-5 [&:has(input:indeterminate)]:w-5 group-data-[select-mode=on]/select:w-5 overflow-hidden transition-all duration-150 flex items-center">
          <input type="checkbox"
                 class="w-3.5 h-3.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500 cursor-pointer bg-transparent"
                 data-action="change->email-selection#toggleSection"
                 data-email-selection-target="sectionToggle"
                 data-section="pinned"
                 aria-label="<%= t(".select_section", section: t(".priority_section")) %>"
                 title="<%= t(".select_section", section: t(".priority_section")) %>">
        </div>
        <div class="flex items-center gap-1.5 min-w-0">
          <svg class="w-3 h-3 flex-shrink-0 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.48 3.5a.56.56 0 011.04 0l2.12 4.92 5.34.46c.49.04.69.66.31.98l-4.05 3.5 1.21 5.22c.11.48-.41.86-.83.6L12 17.27l-4.63 2.91c-.42.26-.94-.12-.83-.6l1.21-5.22-4.05-3.5c-.38-.32-.18-.94.31-.98l5.34-.46 2.12-4.92z"/></svg>
          <%= render(Campbooks::SectionHeader.new) { t(".priority_section") } %>
        </div>
      </div>
    </div>
    <% pinned_threads.each do |thread| %>
      <% next unless thread.latest_message %>
      <%= render "email_messages/thread_row", thread: thread, section_key: "pinned" %>
    <% end %>
  </div>
<% end %>

<%# "Waiting on replies" — the durable, AI-free counterpart of the Priority band:
    threads where the owner sent last and is still waiting. Rendered only on page 1
    (the caller passes the local); infinite-scroll pages omit it so the sticky band
    and its stable dom id never repeat, and they exclude these threads entirely. %>
<% if local_assigns.key?(:waiting_threads) %>
  <%= render "email_messages/waiting_section", waiting_threads: waiting_threads %>
<% end %>

<% thread_counter = 0 %>
<%
  sections = grouped_threads(threads, current_group: current_group, tag_groups: tag_groups)
  today_count = (sections.first && sections.first[:key] == "today") ? sections.first[:threads].size : 0
  inject_at = [today_count + 1, 10].min
%>

<% sections.each_with_index do |section, section_idx| %>
  <% section_label = section[:label] %>
  <% section_key = section[:key] %>
  <% section_threads = section[:threads] %>

  <% unless section_idx.zero? && section_label == continue_section %>
    <div class="group/section px-1.5 pt-3 pb-1 sticky top-0 z-20 flex items-center pointer-events-none">
      <div class="pointer-events-auto inline-flex items-center rounded-full bg-card/80 px-2 py-1 backdrop-blur-md">
        <div class="flex-shrink-0 w-0 group-hover/section:w-5 [&:has(input:checked)]:w-5 [&:has(input:indeterminate)]:w-5 group-data-[select-mode=on]/select:w-5 overflow-hidden transition-all duration-150 flex items-center">
          <input type="checkbox"
                 class="w-3.5 h-3.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500 cursor-pointer bg-transparent"
                 data-action="change->email-selection#toggleSection"
                 data-email-selection-target="sectionToggle"
                 data-section="<%= section_key %>"
                 aria-label="<%= t(".select_section", section: section_label) %>"
                 title="<%= t(".select_section", section: section_label) %>">
        </div>
        <%= render(Campbooks::SectionHeader.new) do %>
          <%= section_label %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% section_threads.each do |thread| %>
    <% thread_counter += 1 %>

    <% if thread_counter == inject_at && group_items.any? && current_group.blank? %>
      <% group_items.each do |group| %>
        <%= render(Campbooks::TagGroupRow.new(
              label: group[:label], count: group[:count], color: group[:color], senders: group[:senders],
              href: email_messages_path(folder_id: params[:folder_id].presence, group: group[:label]))) %>
      <% end %>
    <% end %>

    <%# Regular thread row — swipe-to-act wrapper + markup live in _thread_row %>
    <% next unless thread.latest_message %>
    <%= render "email_messages/thread_row", thread: thread, section_key: section_key %>
  <% end %>
<% end %>

<%# If there are fewer than 4 threads, still show groups at the end %>
<% if thread_counter < inject_at && group_items.any? && current_group.blank? %>
  <% group_items.each do |group| %>
    <%= render(Campbooks::TagGroupRow.new(
          label: group[:label], count: group[:count], color: group[:color], senders: group[:senders],
          href: email_messages_path(folder_id: params[:folder_id].presence, group: group[:label]))) %>
  <% end %>
<% end %>
