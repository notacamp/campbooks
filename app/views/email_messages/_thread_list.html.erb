<% current_group = local_assigns[:current_group] %>
<% tag_groups = local_assigns[:tag_groups] || {} %>
<% group_items = local_assigns[:group_items] || [] %>
<%# When this page continues an earlier one (infinite scroll), the previous page's
    last section label is passed in so we don't repeat its sticky header. %>
<% continue_section = local_assigns[:continue_section] %>

<%# Back button when inside a group view %>
<% if current_group.present? %>
  <div class="border-b border-gray-100">
    <%= link_to email_messages_path(folder_id: params[:folder_id].presence),
          class: "flex items-center gap-2 px-3 py-2 text-[11px] text-gray-500 hover:text-gray-700 hover:bg-gray-50 transition-colors",
          data: { turbo_frame: "_top" } do %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span class="font-medium text-gray-700"><%= current_group %></span>
      <span class="text-gray-400"><%= t(".back_to_inbox") %></span>
    <% end %>
  </div>
<% end %>

<%# Pinned ("Priority") threads — a sticky section pinned above the date sections.
    Only rendered when the caller passes the local (page 1); the infinite-scroll
    pages omit it so it never repeats, and they exclude pinned threads entirely. %>
<% pinned_threads = local_assigns[:pinned_threads] || [] %>
<% if pinned_threads.any? %>
  <div id="pinned_section">
    <%# Frosted floating section pill — sticky, so rows visibly scroll under the
        glass. pointer-events pass through the transparent strip; only the pill
        itself is interactive, so rows sliding beneath stay clickable. %>
    <div class="group/section px-1.5 py-1.5 sticky top-0 z-20 flex items-center pointer-events-none">
      <div class="pointer-events-auto inline-flex items-center rounded-full border border-gray-100 bg-card/75 px-3 py-1 shadow-sm backdrop-blur-md">
        <div class="flex-shrink-0 w-0 group-hover/section:w-5 [&:has(input:checked)]:w-5 [&:has(input:indeterminate)]:w-5 group-data-[select-mode=on]/select:w-5 overflow-hidden transition-all duration-150 flex items-center">
          <input type="checkbox"
                 class="w-3.5 h-3.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500 cursor-pointer bg-transparent"
                 data-action="change->email-selection#toggleSection"
                 data-email-selection-target="sectionToggle"
                 data-section="pinned"
                 aria-label="<%= t(".select_section", section: t(".priority_section")) %>"
                 title="<%= t(".select_section", section: t(".priority_section")) %>">
        </div>
        <div class="flex items-center gap-1.5 min-w-0">
          <svg class="w-3 h-3 flex-shrink-0 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.48 3.5a.56.56 0 011.04 0l2.12 4.92 5.34.46c.49.04.69.66.31.98l-4.05 3.5 1.21 5.22c.11.48-.41.86-.83.6L12 17.27l-4.63 2.91c-.42.26-.94-.12-.83-.6l1.21-5.22-4.05-3.5c-.38-.32-.18-.94.31-.98l5.34-.46 2.12-4.92z"/></svg>
          <%= render(Campbooks::SectionHeader.new) { t(".priority_section") } %>
        </div>
      </div>
    </div>
    <% pinned_threads.each do |thread| %>
      <% next unless thread.latest_message %>
      <%= render "email_messages/thread_row", thread: thread, section_key: "pinned" %>
    <% end %>
  </div>
<% end %>

<% thread_counter = 0 %>
<%
  sections = grouped_threads(threads, current_group: current_group, tag_groups: tag_groups)
  today_count = (sections.first && sections.first[:key] == "today") ? sections.first[:threads].size : 0
  inject_at = [today_count + 1, 10].min
%>

<% sections.each_with_index do |section, section_idx| %>
  <% section_label = section[:label] %>
  <% section_key = section[:key] %>
  <% section_threads = section[:threads] %>

  <% unless section_idx.zero? && section_label == continue_section %>
    <div class="group/section px-1.5 py-1.5 sticky top-0 z-20 flex items-center pointer-events-none">
      <div class="pointer-events-auto inline-flex items-center rounded-full border border-gray-100 bg-card/75 px-3 py-1 shadow-sm backdrop-blur-md">
        <div class="flex-shrink-0 w-0 group-hover/section:w-5 [&:has(input:checked)]:w-5 [&:has(input:indeterminate)]:w-5 group-data-[select-mode=on]/select:w-5 overflow-hidden transition-all duration-150 flex items-center">
          <input type="checkbox"
                 class="w-3.5 h-3.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500 cursor-pointer bg-transparent"
                 data-action="change->email-selection#toggleSection"
                 data-email-selection-target="sectionToggle"
                 data-section="<%= section_key %>"
                 aria-label="<%= t(".select_section", section: section_label) %>"
                 title="<%= t(".select_section", section: section_label) %>">
        </div>
        <%= render(Campbooks::SectionHeader.new) do %>
          <%= section_label %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% section_threads.each do |thread| %>
    <% thread_counter += 1 %>

    <% if thread_counter == inject_at && group_items.any? && current_group.blank? %>
      <% group_items.each do |group| %>
        <%= link_to email_messages_path(folder_id: params[:folder_id].presence, group: group[:label]),
              class: "flex items-center mx-1.5 rounded-xl px-2 transition-colors hover:bg-muted",
              style: "padding-top:var(--thread-py,0.625rem);padding-bottom:var(--thread-py,0.625rem);gap:var(--thread-gap,0.75rem)#{";background-color:#{group[:color]}12" if group[:color]}",
              data: { turbo_frame: "_top" } do %>
          <%# Stacked avatars %>
          <div class="relative shrink-0" style="width:38px;height:28px">
            <% senders = group[:senders] || [] %>
            <% if senders.any? %>
              <% senders.each_with_index do |sender, i| %>
                <span class="absolute" style="left:<%= i * 8 %>px;top:3px;z-index:<%= senders.length - i %>">
                  <%= render(Campbooks::ContactAvatar.new(
                        email: sender[:email] || "?",
                        sent: sender[:sent],
                        size: :sm,
                        contact_id: sender[:contact_id],
                        variant: :neutral,
                        show_direction: false,
                        account_color: sender[:account_color]
                      )) %>
                </span>
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-400"
                    style="width:24px;height:24px;font-size:8px">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
              </span>
            <% end %>
          </div>

          <%# Group name and senders %>
          <div class="min-w-0 flex-1">
            <span class="text-gray-900 font-semibold truncate block" style="font-size:var(--thread-subject-size,11px);line-height:1.3"><%= group[:label] %></span>
            <% senders = group[:senders] || [] %>
            <% if senders.any? %>
              <%
                names = senders.map { |s| (s[:email] || "?").split("@").first }
                label = case names.length
                when 1 then names.first
                when 2 then "#{names[0]}, #{names[1]}"
                else t(".senders_more", first: names[0], second: names[1])
                end
              %>
              <span class="text-gray-400 truncate block" style="font-size:var(--thread-meta-size,10px)"><%= label %></span>
            <% end %>
          </div>

          <%# Count %>
          <span class="text-gray-400 flex-shrink-0 font-medium" style="font-size:var(--thread-meta-size,10px)"><%= group[:count] %></span>

          <%# Right arrow %>
          <svg class="w-3.5 h-3.5 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      <% end %>
    <% end %>

    <%# Regular thread row — swipe-to-act wrapper + markup live in _thread_row %>
    <% next unless thread.latest_message %>
    <%= render "email_messages/thread_row", thread: thread, section_key: section_key %>
  <% end %>
<% end %>

<%# If there are fewer than 4 threads, still show groups at the end %>
<% if thread_counter < inject_at && group_items.any? && current_group.blank? %>
  <% group_items.each do |group| %>
    <%= link_to email_messages_path(folder_id: params[:folder_id].presence, group: group[:label]),
          class: "flex items-center mx-1.5 rounded-xl px-2 transition-colors hover:bg-muted",
          style: "padding-top:var(--thread-py,0.625rem);padding-bottom:var(--thread-py,0.625rem);gap:var(--thread-gap,0.75rem)#{";background-color:#{group[:color]}12" if group[:color]}",
          data: { turbo_frame: "_top" } do %>
      <%# Stacked avatars %>
      <div class="relative shrink-0" style="width:38px;height:28px">
        <% senders = group[:senders] || [] %>
        <% if senders.any? %>
          <% senders.each_with_index do |sender, i| %>
            <span class="absolute" style="left:<%= i * 8 %>px;top:3px;z-index:<%= senders.length - i %>">
              <%= render(Campbooks::ContactAvatar.new(
                    email: sender[:email] || "?",
                    sent: sender[:sent],
                    size: :sm,
                    contact_id: sender[:contact_id],
                    variant: :neutral,
                    show_direction: false,
                    account_color: sender[:account_color]
                  )) %>
            </span>
          <% end %>
        <% else %>
          <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-400"
                style="width:24px;height:24px;font-size:8px">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
          </span>
        <% end %>
      </div>

      <%# Group name and senders %>
      <div class="min-w-0 flex-1">
        <span class="text-gray-900 font-semibold truncate block" style="font-size:var(--thread-subject-size,11px);line-height:1.3"><%= group[:label] %></span>
        <% senders = group[:senders] || [] %>
        <% if senders.any? %>
          <%
            names = senders.map { |s| (s[:email] || "?").split("@").first }
            label = case names.length
            when 1 then names.first
            when 2 then "#{names[0]}, #{names[1]}"
            else "#{names[0]}, #{names[1]}, and more"
            end
          %>
          <span class="text-gray-400 truncate block" style="font-size:var(--thread-meta-size,10px)"><%= label %></span>
        <% end %>
      </div>

      <%# Count %>
      <span class="text-gray-400 flex-shrink-0 font-medium" style="font-size:var(--thread-meta-size,10px)"><%= group[:count] %></span>

      <%# Right arrow %>
      <svg class="w-3.5 h-3.5 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
  <% end %>
<% end %>
