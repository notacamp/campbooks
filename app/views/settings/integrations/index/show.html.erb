<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"))) %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <!-- Google Drive -->
  <%= render(Campbooks::Card.new(padding: :md)) do |card| %>
    <% card.with_header do %>
      <div class="flex items-center justify-between w-full">
        <div class="flex items-center gap-3">
          <%= render(Campbooks::BrandLogo.new(brand: :google_drive, size: :sm)) %>
          <h2 class="text-base font-semibold text-gray-900"><%= t(".google_drive_heading") %></h2>
        </div>
        <% if @google_drive_connected %>
          <%= render(Campbooks::Badge.new(variant: :success, size: :md)) { t(".connected") } %>
        <% else %>
          <%= render(Campbooks::Badge.new(variant: :neutral, size: :md)) { t(".not_connected") } %>
        <% end %>
      </div>
    <% end %>
    <% card.with_body do %>
      <p class="text-sm text-gray-500 mb-4"><%= t(".google_drive_desc") %></p>
      <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: settings_integrations_google_drive_path)) { t(".google_drive_configure") } %>
    <% end %>
  <% end %>

  <!-- Zoho Drive -->
  <%= render(Campbooks::Card.new(padding: :md)) do |card| %>
    <% card.with_header do %>
      <div class="flex items-center justify-between w-full">
        <div class="flex items-center gap-3">
          <%= render(Campbooks::BrandLogo.new(brand: :zoho, size: :sm)) %>
          <h2 class="text-base font-semibold text-gray-900"><%= t(".zoho_drive_heading") %></h2>
        </div>
        <% if @zoho_drive_connected %>
          <%= render(Campbooks::Badge.new(variant: :success, size: :md)) { t(".connected") } %>
        <% else %>
          <%= render(Campbooks::Badge.new(variant: :neutral, size: :md)) { t(".not_connected") } %>
        <% end %>
      </div>
    <% end %>
    <% card.with_body do %>
      <p class="text-sm text-gray-500 mb-4"><%= t(".zoho_drive_desc") %></p>
      <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: settings_integrations_zoho_drive_path)) { t(".zoho_drive_configure") } %>
    <% end %>
  <% end %>

  <!-- Notion -->
  <%= render(Campbooks::Card.new(padding: :md)) do |card| %>
    <% card.with_header do %>
      <div class="flex items-center justify-between w-full">
        <div class="flex items-center gap-3">
          <%= render(Campbooks::BrandLogo.new(brand: :notion, size: :sm)) %>
          <h2 class="text-base font-semibold text-gray-900"><%= t(".notion_heading") %></h2>
        </div>
        <% if @notion_connected %>
          <%= render(Campbooks::Badge.new(variant: :success, size: :md)) { t(".connected") } %>
        <% else %>
          <%= render(Campbooks::Badge.new(variant: :neutral, size: :md)) { t(".not_connected") } %>
        <% end %>
      </div>
    <% end %>
    <% card.with_body do %>
      <p class="text-sm text-gray-500 mb-4"><%= t(".notion_desc") %></p>
      <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: settings_integrations_notion_path)) { t(".notion_configure") } %>
    <% end %>
  <% end %>

  <!-- Calendars -->
  <%= render(Campbooks::Card.new(padding: :md)) do |card| %>
    <% card.with_header do %>
      <div class="flex items-center justify-between w-full">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4.5" width="18" height="16.5" rx="2" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9.5h18M8 3v4M16 3v4"/></svg>
          <h2 class="text-base font-semibold text-gray-900"><%= t(".calendars_heading") %></h2>
        </div>
        <% if @calendar_connected %>
          <%= render(Campbooks::Badge.new(variant: :success, size: :md)) { t(".connected") } %>
        <% else %>
          <%= render(Campbooks::Badge.new(variant: :neutral, size: :md)) { t(".not_connected") } %>
        <% end %>
      </div>
    <% end %>
    <% card.with_body do %>
      <p class="text-sm text-gray-500 mb-4"><%= t(".calendars_desc") %></p>
      <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: settings_integrations_calendars_path)) { t(".calendars_configure") } %>
    <% end %>
  <% end %>

  <!-- API Connections (developer-only — hidden in the native app shell) -->
  <% unless hotwire_native_app? %>
  <%= render(Campbooks::Card.new(padding: :md)) do |card| %>
    <% card.with_header do %>
      <div class="flex items-center justify-between w-full">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
          <h2 class="text-base font-semibold text-gray-900"><%= t(".api_connections_heading") %></h2>
        </div>
        <% if @connections_count.to_i.positive? %>
          <%= render(Campbooks::Badge.new(variant: :success, size: :md)) { t(".connections", count: @connections_count) } %>
        <% else %>
          <%= render(Campbooks::Badge.new(variant: :neutral, size: :md)) { t(".none_yet") } %>
        <% end %>
      </div>
    <% end %>
    <% card.with_body do %>
      <p class="text-sm text-gray-500 mb-4"><%= t(".api_connections_desc") %></p>
      <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: settings_integrations_connections_path)) { t(".api_connections_manage") } %>
    <% end %>
  <% end %>
  <% end %>
</div>
