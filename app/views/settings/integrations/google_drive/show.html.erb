<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"))) %>

<!-- Connection -->
<%= render(Campbooks::Card.new(padding: :lg, class: "mb-6")) do %>
  <div class="flex items-center gap-2 mb-4">
    <%= render(Campbooks::BrandLogo.new(brand: :google_drive, size: :sm)) %>
    <h2 class="text-sm font-semibold text-gray-900"><%= t(".connected_account_heading") %></h2>
  </div>

  <% if @account&.connected? %>
    <div class="flex items-center gap-3 mb-4">
      <%= render(Campbooks::ColorDot.new(color: "#22c55e", size: :xs)) %>
      <span class="text-sm text-gray-700">
        <%= t(".connected_label") %><% if @account.email %> <%= t(".connected_as") %> <strong><%= @account.email %></strong><% end %>
      </span>
    </div>

    <% unless @account.full_access? %>
      <div class="mb-4 rounded-md border border-amber-200 bg-amber-50 p-3 dark:border-amber-500/20 dark:bg-amber-500/10">
        <p class="text-sm text-amber-800 dark:text-amber-300"><%= t(".reconnect_prompt") %></p>
        <%= render(Campbooks::Button.new(variant: :outline, size: :sm, href: oauth_google_connect_path, class: "mt-2")) { t(".reconnect_button") } %>
      </div>
    <% end %>

    <%= button_to t(".disconnect"), settings_integrations_google_drive_path, method: :delete,
        class: "px-4 py-2 bg-red-50 text-red-600 text-sm font-medium rounded-md hover:bg-red-100 dark:bg-red-500/10 dark:text-red-400 dark:hover:bg-red-500/15",
        form: { data: { turbo_confirm: t(".disconnect_confirm") } } %>

    <% if @failed_count && @failed_count > 0 %>
      <div class="mt-4 rounded-md border border-amber-200 bg-amber-50 p-3 dark:border-amber-500/20 dark:bg-amber-500/10">
        <p class="text-sm text-amber-800 dark:text-amber-300"><%= t(".failed_count", count: @failed_count) %></p>
        <%= button_to t(".retry_all_failed"), retry_failed_settings_integrations_google_drive_path,
            method: :post, class: "mt-2 px-3 py-1.5 bg-amber-100 text-amber-700 text-sm font-medium rounded-md hover:bg-amber-200 dark:bg-amber-500/20 dark:text-amber-300 dark:hover:bg-amber-500/30 cursor-pointer" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-sm text-gray-500 mb-4">
      <%= t(".connect_desc_html", scope: content_tag(:code, "drive", class: "text-xs bg-gray-100 px-1 rounded")) %>
    </p>
    <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: oauth_google_connect_path)) { t(".connect_button") } %>
  <% end %>
<% end %>

<!-- Per-document-type Configuration -->
<% if @account&.connected? %>
  <%= render(Campbooks::Card.new(padding: :lg)) do %>
    <h2 class="text-sm font-semibold text-gray-900 mb-4"><%= t(".drive_org_heading") %></h2>
    <p class="text-xs text-gray-500 mb-4">
      <%= t(".drive_org_desc") %>
    </p>

    <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b text-left text-xs font-medium text-gray-500">
          <th class="py-2 pr-4"><%= t(".col_document_type") %></th>
          <th class="py-2 pr-4"><%= t(".col_auto_push") %></th>
          <th class="py-2 pr-4"><%= t(".col_drive_folder") %></th>
          <th class="py-2 pr-4"><%= t(".col_subfolders") %></th>
          <th class="py-2"></th>
        </tr>
      </thead>
      <tbody>
        <% @document_types.each do |type| %>
          <% config = @configs[type.id] || GoogleDriveConfig.new(document_type: type) %>
          <tr class="border-b last:border-0">
            <td class="py-2 pr-4">
              <span class="inline-flex items-center gap-1.5">
                <%= render(Campbooks::ColorDot.new(color: type.color, size: :sm)) %>
                <%= type.name.humanize %>
              </span>
            </td>
            <td class="py-2 pr-4">
              <% if config.auto_push? %>
                <%= render(Campbooks::Badge.new(variant: :success, size: :md)) { t(".on_badge") } %>
              <% else %>
                <%= render(Campbooks::Badge.new(variant: :neutral, size: :md)) { t(".off_badge") } %>
              <% end %>
            </td>
            <td class="py-2 pr-4 text-gray-500">
              <%= config.folder_path.presence || (config.folder_id.present? ? t(".folder_set") : "—") %>
            </td>
            <td class="py-2 pr-4 text-gray-500">
              <%= config.subfolder_pattern == "flat" ? "—" : human_enum(GoogleDriveConfig, :subfolder_pattern, config.subfolder_pattern) %>
            </td>
            <td class="py-2 text-right">
              <%= render(Campbooks::Button.new(variant: :ghost, size: :xs, href: settings_integrations_google_drive_edit_config_path(type.id))) { config.persisted? ? t(".edit_config") : t(".configure") } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  <% end %>
<% end %>
