<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"), back_href: settings_integrations_root_path, back_label: t(".back"))) %>

<!-- Connection -->
<%= render(Campbooks::Card.new(padding: :lg, class: "mb-6")) do %>
  <div class="flex items-center gap-2 mb-4">
    <%= render(Campbooks::BrandLogo.new(brand: :notion, size: :sm)) %>
    <h2 class="text-sm font-semibold text-gray-900"><%= t(".workspace_heading") %></h2>
  </div>

  <!-- Connected workspaces -->
  <% if @integrations.any? %>
    <ul class="mb-5 divide-y divide-gray-100 dark:divide-white/10">
      <% @integrations.each do |integration| %>
        <li class="flex items-center justify-between gap-3 py-2.5">
          <span class="flex items-center gap-2 text-sm text-gray-700">
            <%= render(Campbooks::ColorDot.new(color: "#22c55e", size: :xs)) %>
            <strong><%= integration.display_name %></strong>
          </span>
          <%= button_to t(".disconnect"), settings_integrations_notion_integration_path(integration), method: :delete,
              class: "px-3 py-1.5 bg-red-50 text-red-600 text-xs font-medium rounded-md hover:bg-red-100 dark:bg-red-500/10 dark:text-red-400 dark:hover:bg-red-500/15",
              form: { data: { turbo_confirm: t(".disconnect_confirm") } } %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <!-- Connect a (new) workspace -->
  <% if @oauth_configured %>
    <p class="text-sm text-gray-500 mb-3"><%= t(".oauth_desc") %></p>
    <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: oauth_notion_connect_path)) do %>
      <%= render(Campbooks::BrandLogo.new(brand: :notion, size: :xs, class: "mr-2 -ml-0.5")) %><%= @integrations.any? ? t(".connect_another") : t(".connect_button") %>
    <% end %>

    <details class="mt-4 group">
      <summary class="text-xs text-gray-500 cursor-pointer hover:text-gray-700"><%= t(".manual_toggle") %></summary>
      <div class="mt-3">
        <%= render "token_form" %>
      </div>
    </details>
  <% else %>
    <%= render "token_form" %>
  <% end %>
<% end %>

<!-- Database Mappings (legacy document auto-sync) -->
<% if @integrations.any? %>
  <%= render(Campbooks::Card.new(padding: :lg)) do %>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-gray-900"><%= t(".destinations_heading") %></h2>
      <span class="text-xs text-gray-500"><%= t(".per_doc_type") %></span>
    </div>

    <p class="text-xs text-gray-500 mb-4">
      <%= t(".mappings_desc") %>
    </p>

    <% if @mappings.any? %>
      <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-left text-xs font-medium text-gray-500">
            <th class="py-2 pr-4"><%= t(".col_document_type") %></th>
            <th class="py-2 pr-4"><%= t(".col_database") %></th>
            <th class="py-2 pr-4"><%= t(".col_push") %></th>
            <th class="py-2 pr-4"><%= t(".col_pull") %></th>
            <th class="py-2"></th>
          </tr>
        </thead>
        <tbody>
          <% @mappings.each do |mapping| %>
            <tr class="border-b last:border-0">
              <td class="py-2 pr-4">
                <% if mapping.document_type %>
                  <span class="inline-flex items-center gap-1.5">
                    <%= render(Campbooks::ColorDot.new(color: mapping.document_type.color, size: :sm)) %>
                    <%= mapping.document_type.name.humanize %>
                  </span>
                <% else %>
                  <span class="text-gray-400"><%= t(".unknown_type") %></span>
                <% end %>
              </td>
              <td class="py-2 pr-4 text-gray-600"><%= mapping.notion_database_name || mapping.notion_database_id.truncate(20) %></td>
              <td class="py-2 pr-4">
                <% if mapping.push_enabled? %>
                  <%= render(Campbooks::Badge.new(variant: :success, size: :sm)) { t(".on_badge") } %>
                <% else %>
                  <%= render(Campbooks::Badge.new(variant: :neutral, size: :sm)) { t(".off_badge") } %>
                <% end %>
              </td>
              <td class="py-2 pr-4">
                <% if mapping.pull_enabled? %>
                  <%= render(Campbooks::Badge.new(variant: :success, size: :sm)) { t(".on_badge") } %>
                <% else %>
                  <%= render(Campbooks::Badge.new(variant: :neutral, size: :sm)) { t(".off_badge") } %>
                <% end %>
              </td>
              <td class="py-2 text-right">
                <%= render(Campbooks::Button.new(variant: :ghost, size: :xs, href: email_messages_path(inbox_settings: "document_types"), data: { turbo_frame: "_top" })) { t(".edit") } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <%= render(Campbooks::EmptyState.new(variant: :inline, title: t(".no_mappings"))) do %>
        <%= link_to t(".edit_doc_type_link"), email_messages_path(inbox_settings: "document_types"), class: "text-accent-600 hover:text-accent-700" %> <%= t(".no_mappings_hint") %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
