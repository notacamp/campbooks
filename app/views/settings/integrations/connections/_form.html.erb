<% input_class = "block w-full rounded-md border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500" %>
<% label_class = "block text-sm font-medium text-gray-700 mb-1" %>

<%= form_with model: connection,
      url: connection.persisted? ? settings_integrations_connection_path(connection) : settings_integrations_connections_path,
      method: connection.persisted? ? :patch : :post,
      class: "space-y-5" do |f| %>

  <% if connection.errors.any? %>
    <%= render(Campbooks::Alert.new(variant: :error, message: connection.errors.full_messages.to_sentence)) %>
  <% end %>

  <div>
    <%= f.label :name, t(".name_label"), class: label_class %>
    <%= f.text_field :name, class: input_class, placeholder: t(".name_placeholder") %>
  </div>

  <div>
    <%= f.label :base_url, t(".base_url_label"), class: label_class %>
    <%= f.text_field :base_url, class: "#{input_class} font-mono", placeholder: t(".base_url_placeholder") %>
    <p class="mt-1 text-xs text-gray-500"><%= t(".base_url_hint") %></p>
  </div>

  <div>
    <%= f.label :auth_type, t(".auth_label"), class: label_class %>
    <%= f.select :auth_type, Connection::AUTH_TYPES.map { |t| [ human_enum(Connection, :auth_type, t), t ] }, {}, class: input_class %>
    <p class="mt-1 text-xs text-gray-500"><%= t(".auth_hint") %></p>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :auth_header_name, t(".header_name_label"), class: label_class %>
      <%= f.text_field :auth_header_name, class: "#{input_class} font-mono", placeholder: t(".header_name_placeholder") %>
      <p class="mt-1 text-xs text-gray-500"><%= t(".header_name_hint") %></p>
    </div>
    <div>
      <%= f.label :auth_username, t(".username_label"), class: label_class %>
      <%= f.text_field :auth_username, class: input_class, placeholder: t(".username_placeholder") %>
      <p class="mt-1 text-xs text-gray-500"><%= t(".username_hint") %></p>
    </div>
  </div>

  <div>
    <%= f.label :auth_secret, t(".secret_label"), class: label_class %>
    <%= f.password_field :auth_secret, class: "#{input_class} font-mono", autocomplete: "new-password",
          placeholder: connection.persisted? ? t(".secret_placeholder_existing") : t(".secret_placeholder_new") %>
    <p class="mt-1 text-xs text-gray-500"><%= t(".secret_hint") %></p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= render(Campbooks::Button.new(variant: :primary, size: :md, type: :submit)) { connection.persisted? ? t(".save_connection") : t(".create_connection") } %>
    <%= link_to t("shared.actions.cancel"), settings_integrations_connections_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
