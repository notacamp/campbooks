<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>

<header class="flex items-center justify-between gap-4 pb-5 border-b border-border mb-6">
  <div class="min-w-0">
    <h2 class="text-lg font-semibold text-foreground"><%= t(".heading") %></h2>
    <p class="text-[13px] text-muted-foreground mt-0.5"><%= t(".subtitle") %></p>
  </div>
  <%= link_to new_settings_pipeline_path,
        class: "inline-flex items-center gap-1.5 rounded-lg bg-accent-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-accent-700 transition" do %>
    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
    </svg>
    <%= t(".new_pipeline") %>
  <% end %>
</header>

<% if @pipelines.any? %>
  <div class="space-y-3">
    <% @pipelines.each do |pipeline| %>
      <div class="rounded-xl border border-border bg-card p-4 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-semibold text-foreground"><%= pipeline.name %></h3>
            <% if pipeline.description.present? %>
              <p class="text-[12px] text-muted-foreground mt-0.5 line-clamp-2"><%= pipeline.description %></p>
            <% end %>
            <div class="flex flex-wrap items-center gap-1.5 mt-2.5">
              <% pipeline.stages.ordered.each do |stage| %>
                <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-medium"
                      style="background-color: <%= stage.color %>20; color: <%= stage.color %>">
                  <%= stage.name %>
                  <% if stage.is_terminal? %>
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  <% end %>
                </span>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <% if pipelines_enabled? %>
              <%= link_to t(".view_board"), board_pipeline_path(pipeline),
                    class: "text-[12px] text-accent-600 hover:text-accent-700 font-medium",
                    data: { turbo: false } %>
            <% end %>
            <%= link_to t("shared.actions.edit"), edit_settings_pipeline_path(pipeline),
                  class: "text-[12px] text-accent-600 hover:text-accent-700 font-medium" %>
            <%= button_to settings_pipeline_path(pipeline), method: :delete,
                  class: "text-[12px] text-red-500 hover:text-red-600 font-medium",
                  form: { data: { turbo_confirm: t(".confirm_delete") } } do %>
              <%= t("shared.actions.delete") %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-16 text-center">
    <svg class="h-12 w-12 text-muted-foreground/40 mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"/>
    </svg>
    <p class="text-sm font-medium text-foreground"><%= t(".empty_title") %></p>
    <p class="text-[13px] text-muted-foreground mt-1 max-w-sm"><%= t(".empty_description") %></p>
    <%= link_to t(".create_first"), new_settings_pipeline_path,
          class: "mt-4 inline-flex items-center gap-1.5 rounded-lg bg-accent-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-accent-700 transition" %>
  </div>
<% end %>
