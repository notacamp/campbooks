<% input_class = "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500" %>
<% label_class = "block text-sm font-medium text-gray-700 mb-1" %>

<div class="space-y-4">
  <div>
    <%= f.label :name, class: label_class %>
    <%= f.text_field :name, required: true, class: input_class,
          placeholder: t("settings.document_templates.form.name_placeholder") %>
  </div>

  <div>
    <%= f.label :description, class: label_class %>
    <p class="text-xs text-gray-400 mb-1"><%= t("settings.document_templates.form.description_hint") %></p>
    <%= f.text_area :description, rows: 3, class: input_class,
          placeholder: t("settings.document_templates.form.description_placeholder") %>
  </div>

  <% if @template.persisted? && @template.html_content.present? %>
    <div>
      <%= f.label :html_content, class: label_class %>
      <p class="text-xs text-gray-400 mb-1"><%= t("settings.document_templates.form.html_content_hint") %></p>
      <%= f.text_area :html_content, rows: 16, spellcheck: false,
            class: "#{input_class} font-mono text-xs" %>
    </div>
  <% end %>
</div>
