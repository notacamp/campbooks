<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"))) %>

<div class="max-w-xl space-y-6">
  <div class="bg-card rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-base font-semibold text-gray-900 mb-4"><%= t(".change_password") %></h2>

    <%= form_with url: settings_account_path, method: :patch, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :current_password, t(".current_password"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :current_password, required: true,
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password, t(".new_password"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, required: true, minlength: 8,
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password_confirmation, t(".confirm_password"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, required: true, minlength: 8,
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm" %>
      </div>

      <%= render(Campbooks::Button.new(variant: :primary, type: :submit)) { t(".update_password") } %>
    <% end %>
  </div>

  <div class="bg-card rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-base font-semibold text-gray-900 mb-1"><%= t(".language_title") %></h2>
    <p class="text-sm text-gray-500 mb-4"><%= t(".language_subtitle") %></p>

    <%= form_with url: language_settings_account_path, method: :patch, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :locale, t(".language_title"), class: "sr-only" %>
        <%= f.select :locale, options_for_select(locale_options, current_user.locale), {},
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm" %>
      </div>

      <%= render(Campbooks::Button.new(variant: :primary, type: :submit)) { t(".save_language") } %>
    <% end %>
  </div>

  <div class="bg-card rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-base font-semibold text-gray-900 mb-1"><%= t(".writing_style_title") %></h2>
    <p class="text-sm text-gray-500 mb-4"><%= t(".writing_style_subtitle") %></p>

    <%= form_with url: writing_style_settings_account_path, method: :patch, class: "space-y-3" do |f| %>
      <div>
        <%= f.label :writing_style, t(".writing_style_label"), class: "sr-only" %>
        <%= f.text_area :writing_style, value: current_user.writing_style, rows: 5,
              placeholder: t(".writing_style_placeholder"),
              class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm" %>
      </div>
      <%= render(Campbooks::Button.new(variant: :primary, type: :submit)) { t(".writing_style_save") } %>
    <% end %>

    <div class="mt-5 pt-5 border-t border-gray-100">
      <div class="flex items-center justify-between gap-3 mb-2">
        <h3 class="text-sm font-medium text-gray-700"><%= t(".writing_style_learned_label") %></h3>
        <%= button_to t(".writing_style_analyze"), analyze_writing_style_settings_account_path, method: :post,
              class: "inline-flex items-center text-xs font-medium text-accent-600 hover:text-accent-700 cursor-pointer" %>
      </div>
      <% if current_user.writing_style_learned.present? %>
        <p class="text-sm text-gray-600 whitespace-pre-wrap leading-relaxed bg-gray-50 border border-gray-200 rounded-lg p-3"><%= current_user.writing_style_learned %></p>
      <% else %>
        <p class="text-sm text-gray-400"><%= t(".writing_style_learned_empty") %></p>
      <% end %>
    </div>
  </div>

  <div class="bg-card rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-base font-semibold text-gray-900 mb-1"><%= t(".data_export_title") %></h2>
    <p class="text-sm text-gray-500 mb-4"><%= t(".data_export_desc") %></p>
    <% latest_export = current_user.account_exports.recent.first %>
    <div class="flex flex-wrap items-center gap-3">
      <%= button_to t(".data_export_button"), export_settings_account_path, method: :post,
            class: "inline-flex items-center justify-center rounded-lg border border-gray-300 bg-card px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer" %>
      <% if latest_export&.generated? %>
        <%= render(Campbooks::Button.new(variant: :ghost, size: :sm, href: download_export_settings_account_path)) { t(".data_export_download") } %>
      <% elsif latest_export&.pending? || latest_export&.generating? %>
        <span class="text-sm text-gray-500"><%= t(".data_export_preparing") %></span>
      <% end %>
    </div>
  </div>

  <div class="bg-card rounded-xl shadow-sm border border-red-200 p-6">
    <h2 class="text-base font-semibold text-red-700 mb-1"><%= t(".danger_zone_title") %></h2>
    <p class="text-sm text-gray-500 mb-4"><%= t(".danger_zone_desc") %></p>
    <%= render(Campbooks::Button.new(variant: :danger, href: delete_settings_account_path)) { t(".delete_account_button") } %>
  </div>

  <div class="text-center pt-2">
    <p class="text-xs text-gray-400">
      <%= link_to t(".privacy_policy"), marketing_url("/privacy"), target: "_blank", rel: "noopener", class: "hover:text-gray-600 underline" %>
      ·
      <%= link_to t(".terms_of_service"), marketing_url("/terms"), target: "_blank", rel: "noopener", class: "hover:text-gray-600 underline" %>
    </p>
  </div>
</div>
