<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"))) %>

<div class="max-w-xl space-y-5">
  <% if current_user.mfa_enabled? %>
    <div class="flex items-center gap-2 text-sm text-green-700 bg-green-50 border border-green-200 rounded-lg px-4 py-2.5">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75 11.25 15 15 9.75"/></svg>
      <span><%= t(".status_on") %></span>
    </div>
  <% else %>
    <p class="text-sm text-muted-foreground"><%= t(".status_off") %></p>
  <% end %>

  <%# ── Sign-in & security activity (audit log) ── %>
  <%= link_to audit_log_settings_security_path,
        class: "flex items-center justify-between gap-3 bg-card rounded-xl shadow-sm border border-border px-4 py-3 hover:bg-muted/50 transition-colors" do %>
    <span class="min-w-0">
      <span class="block text-sm font-medium text-foreground"><%= t("settings.security.audit_log.link") %></span>
      <span class="block text-xs text-muted-foreground"><%= t("settings.security.audit_log.link_hint") %></span>
    </span>
    <svg class="w-4 h-4 flex-shrink-0 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <% end %>

  <%# ── Sign-in methods (Google / Microsoft / Zoho logins) ── %>
  <%= render(Campbooks::SecurityMethodCard.new(title: t(".sign_in_methods_title"), description: t(".sign_in_methods_description"), enabled: @identities.any?, icon: "M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l3 3m0 0-3 3m3-3H2.25")) do %>
    <div class="space-y-3">
      <% if @identities.any? %>
        <ul class="divide-y divide-border border border-border rounded-lg">
          <% @identities.each do |identity| %>
            <li class="flex items-center justify-between gap-3 px-3 py-2">
              <div class="min-w-0">
                <p class="text-sm font-medium text-foreground"><%= identity.provider_label %></p>
                <p class="text-xs text-muted-foreground truncate"><%= identity.email %></p>
              </div>
              <% if @only_sign_in_method %>
                <span class="text-xs text-muted-foreground flex-shrink-0"><%= t(".sign_in_only_method") %></span>
              <% else %>
                <%= form_with url: settings_security_sign_in_method_path(identity), method: :delete, class: "flex items-center gap-2 flex-shrink-0", data: { turbo_confirm: t(".sign_in_remove_confirm", provider: identity.provider_label) } do %>
                  <% if current_user.password_set_by_user? %>
                    <input type="password" name="current_password" required autocomplete="current-password"
                           placeholder="<%= t(".danger_password_label") %>" aria-label="<%= t(".danger_password_label") %>"
                           class="block w-32 rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 text-sm" />
                  <% end %>
                  <%= render(Campbooks::Button.new(variant: :ghost, size: :sm, type: :submit, class: "text-red-600 hover:bg-red-50")) { t(".sign_in_remove") } %>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-muted-foreground"><%= t(".sign_in_methods_empty") %></p>
      <% end %>

      <% if @linkable_providers.any? %>
        <div class="flex flex-wrap gap-2">
          <% @linkable_providers.each do |provider| %>
            <%= form_with url: settings_security_sign_in_methods_path(provider: provider), method: :post do %>
              <%= render(Campbooks::Button.new(variant: :outline, size: :sm, type: :submit)) { t(".sign_in_add", provider: provider.titleize) } %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Authenticator app (TOTP) ── %>
  <%= render(Campbooks::SecurityMethodCard.new(title: t(".totp_title"), description: t(".totp_description"), enabled: @totp_enabled, icon: "M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3")) do %>
    <div class="flex flex-wrap gap-2">
      <% if @totp_enabled %>
        <%= render(Campbooks::Button.new(variant: :outline, size: :sm, href: new_settings_security_totp_path)) { t(".totp_reconfigure") } %>
        <%= form_with url: settings_security_totp_path, method: :delete, class: "flex items-end gap-2", data: { turbo_confirm: t(".totp_disable_confirm") } do %>
          <div>
            <label for="totp_disable_password" class="block text-xs font-medium text-gray-600 mb-1"><%= t(".danger_password_label") %></label>
            <input type="password" name="current_password" id="totp_disable_password" required autocomplete="current-password"
                   class="block w-44 rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 text-sm" />
          </div>
          <%= render(Campbooks::Button.new(variant: :ghost, size: :sm, type: :submit, class: "text-red-600 hover:bg-red-50")) { t(".totp_disable") } %>
        <% end %>
      <% else %>
        <%= render(Campbooks::Button.new(variant: :primary, size: :sm, href: new_settings_security_totp_path)) { t(".totp_enable") } %>
      <% end %>
    </div>
  <% end %>

  <%# ── Passkeys / security keys ── %>
  <%= render(Campbooks::SecurityMethodCard.new(title: t(".passkeys_title"), description: t(".passkeys_description"), enabled: @passkeys.any?, icon: "M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33")) do %>
    <div class="space-y-3">
      <% if @passkeys.any? %>
        <ul class="divide-y divide-border border border-border rounded-lg">
          <% @passkeys.each do |pk| %>
            <li class="flex items-center justify-between gap-3 px-3 py-2">
              <div class="min-w-0">
                <p class="text-sm font-medium text-foreground truncate"><%= pk.nickname.presence || t(".passkeys_default_name") %></p>
                <p class="text-xs text-muted-foreground">
                  <%= t(".passkeys_added_on", date: l(pk.created_at.to_date)) %>
                  · <%= pk.last_used_at ? t(".passkeys_last_used", date: l(pk.last_used_at.to_date)) : t(".passkeys_never_used") %>
                </p>
              </div>
              <%= form_with url: settings_security_passkey_path(pk), method: :delete, class: "flex items-center gap-2 flex-shrink-0", data: { turbo_confirm: t(".passkeys_remove_confirm") } do %>
                <input type="password" name="current_password" required autocomplete="current-password"
                       placeholder="<%= t(".danger_password_label") %>" aria-label="<%= t(".danger_password_label") %>"
                       class="block w-36 rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 text-sm" />
                <%= render(Campbooks::Button.new(variant: :ghost, size: :sm, type: :submit, class: "text-red-600 hover:bg-red-50")) { t(".passkeys_remove") } %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-muted-foreground"><%= t(".passkeys_empty") %></p>
      <% end %>
      <%= render(Campbooks::Button.new(variant: @passkeys.any? ? :outline : :primary, size: :sm, href: new_settings_security_passkey_path)) { t(".passkeys_add") } %>
    </div>
  <% end %>

  <%# ── Email one-time code ── %>
  <%= render(Campbooks::SecurityMethodCard.new(title: t(".email_title"), description: t(".email_description"), enabled: @email_otp_enabled, icon: "M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75")) do %>
    <div class="flex flex-wrap gap-2">
      <% if @email_otp_enabled %>
        <%= form_with url: settings_security_email_otp_path, method: :delete, class: "flex items-end gap-2" do %>
          <div>
            <label for="email_otp_disable_password" class="block text-xs font-medium text-gray-600 mb-1"><%= t(".danger_password_label") %></label>
            <input type="password" name="current_password" id="email_otp_disable_password" required autocomplete="current-password"
                   class="block w-44 rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 text-sm" />
          </div>
          <%= render(Campbooks::Button.new(variant: :ghost, size: :sm, type: :submit, class: "text-red-600 hover:bg-red-50")) { t(".email_disable") } %>
        <% end %>
      <% else %>
        <%= form_with url: settings_security_email_otp_path, method: :post, class: "flex items-end gap-2" do %>
          <div>
            <label for="email_otp_enable_password" class="block text-xs font-medium text-gray-600 mb-1"><%= t(".danger_password_label") %></label>
            <input type="password" name="current_password" id="email_otp_enable_password" required autocomplete="current-password"
                   class="block w-44 rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 text-sm" />
          </div>
          <%= render(Campbooks::Button.new(variant: :primary, size: :sm, type: :submit)) { t(".email_enable") } %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# ── Recovery codes (only relevant once a factor exists) ── %>
  <% if current_user.mfa_enabled? %>
    <%= render(Campbooks::SecurityMethodCard.new(title: t(".recovery_title"), description: t(".recovery_description"), enabled: @recovery_codes_remaining.positive?, icon: "M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z")) do %>
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm text-muted-foreground"><%= t(".recovery_remaining", count: @recovery_codes_remaining) %></span>
        <%= render(Campbooks::Button.new(variant: :outline, size: :sm, href: settings_security_recovery_codes_path)) { t(".recovery_view") } %>
      </div>
    <% end %>
  <% end %>

  <%# ── Danger zone: turn off all 2FA (password required) ── %>
  <% if current_user.mfa_enabled? %>
    <div class="bg-card rounded-xl shadow-sm border border-red-200 p-5 sm:p-6">
      <h2 class="text-base font-semibold text-red-700 mb-1"><%= t(".danger_title") %></h2>
      <p class="text-sm text-muted-foreground mb-4"><%= t(".danger_description") %></p>
      <%= form_with url: disable_settings_security_path, method: :delete, class: "space-y-3", data: { turbo_confirm: t(".danger_confirm") } do %>
        <div>
          <label for="disable_current_password" class="block text-sm font-medium text-gray-700 mb-1"><%= t(".danger_password_label") %></label>
          <input type="password" name="current_password" id="disable_current_password" required autocomplete="current-password"
                 class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-accent-500 focus:ring-accent-500 sm:text-sm" />
        </div>
        <%= render(Campbooks::Button.new(variant: :danger, size: :sm, type: :submit)) { t(".danger_button") } %>
      <% end %>
    </div>
  <% end %>
</div>
