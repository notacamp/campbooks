<div class="space-y-4">
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, required: true, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500", placeholder: t(".name_placeholder") %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <p class="text-xs text-gray-400 mb-1"><%= t(".description_hint") %></p>
    <%= f.text_area :description, rows: 3, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500", placeholder: t(".description_placeholder") %>
  </div>

  <div>
    <%= f.label :subject, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <p class="text-xs text-gray-400 mb-1"><%= t(".subject_hint") %></p>
    <%= f.text_field :subject, class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500", placeholder: t(".subject_placeholder") %>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1"><%= t(".body_label") %></label>
    <p class="text-xs text-gray-400 mb-1"><%= t(".body_hint") %></p>
    <%= render(Campbooks::RichTextEditor.new(
          input_name: "email_template[body_html]",
          content: @template.body_html,
          placeholder: t(".body_placeholder"),
          upload_url: compose_images_path
        )) %>
  </div>

  <% attachable = @document_templates.to_a.select { |dt| dt.html_content.present? } %>
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1"><%= t(".documents_label") %></label>
    <p class="text-xs text-gray-400 mb-2"><%= t(".documents_hint") %></p>
    <% if attachable.any? %>
      <%# Submit an empty value so unchecking every box clears the association. %>
      <%= hidden_field_tag "email_template[document_template_ids][]", "" %>
      <div class="space-y-1.5">
        <% selected_ids = @template.document_template_ids %>
        <% attachable.each do |dt| %>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <%= check_box_tag "email_template[document_template_ids][]", dt.id, selected_ids.include?(dt.id), class: "rounded border-gray-300 text-accent-600 focus:ring-accent-500" %>
            <span><%= dt.name %></span>
          </label>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-gray-400"><%= t(".documents_empty") %></p>
    <% end %>
  </div>
</div>
