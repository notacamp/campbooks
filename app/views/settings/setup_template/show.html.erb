<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"))) %>

<div class="max-w-2xl space-y-6">

  <%# ── Active templates status ─────────────────────────── %>
  <div class="rounded-xl border border-border bg-card p-6">
    <h2 class="text-sm font-semibold text-foreground"><%= t(".current_heading") %></h2>

    <% if @chosen_templates.any? %>
      <div class="mt-3 space-y-2">
        <% @chosen_templates.each do |tpl| %>
          <div class="flex items-start gap-3 rounded-xl border border-border bg-muted/30 p-4">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-accent-100 text-accent-700 dark:bg-accent-900/40 dark:text-accent-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-[18px] w-[18px]" aria-hidden="true">
                <path d="<%= tpl[:icon] %>"/>
              </svg>
            </span>
            <div>
              <p class="text-sm font-semibold text-foreground">
                <%= t("onboarding.steps.template.templates.#{tpl[:key]}.name") %>
              </p>
              <p class="mt-0.5 text-xs text-muted-foreground">
                <%= t("onboarding.steps.template.templates.#{tpl[:key]}.description") %>
              </p>
            </div>
          </div>
        <% end %>
      </div>

      <% if @applied_tags.any? || @applied_types.any? %>
        <div class="mt-4 space-y-2">
          <% if @applied_tags.any? %>
            <div>
              <p class="text-xs font-medium text-muted-foreground mb-1.5"><%= t(".tags_added") %></p>
              <div class="flex flex-wrap gap-1.5">
                <% @applied_tags.each do |tag| %>
                  <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset ring-ink/10 dark:ring-white/10">
                    <span class="h-2 w-2 rounded-full shrink-0" style="background-color: <%= tag.color %>"></span>
                    <%= tag.name.titleize %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @applied_types.any? %>
            <div>
              <p class="text-xs font-medium text-muted-foreground mb-1.5"><%= t(".doc_types_added") %></p>
              <div class="flex flex-wrap gap-1.5">
                <% @applied_types.each do |dt| %>
                  <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset ring-ink/10 dark:ring-white/10">
                    <span class="h-2 w-2 rounded-full shrink-0" style="background-color: <%= dt.color %>"></span>
                    <%= dt.name.titleize %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p class="mt-3 text-sm text-muted-foreground"><%= t(".no_template") %></p>
    <% end %>
  </div>

  <%# ── Add / switch templates (multi-select, additive) ─── %>
  <div class="rounded-xl border border-border bg-card p-6">
    <h2 class="text-sm font-semibold text-foreground"><%= t(".switch_heading") %></h2>
    <p class="mt-1 text-xs text-muted-foreground"><%= t(".switch_hint") %></p>

    <%= form_with url: settings_setup_template_path, method: :patch, class: "mt-4",
                  data: { controller: "template-picker" } do |f| %>
      <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
        <% @templates.each do |tpl| %>
          <%
            key    = tpl[:key]
            active = @chosen_keys.include?(key)
            is_exclusive = (key == "just_exploring")
          %>
          <label class="group relative flex cursor-pointer items-start gap-3 rounded-xl border p-3.5 transition-all has-[:checked]:border-accent-500 has-[:checked]:bg-accent-50/60 dark:has-[:checked]:bg-accent-900/20 <%= active ? 'border-accent-500 bg-accent-50/60 dark:bg-accent-900/20' : 'border-border hover:border-gray-300 dark:hover:border-gray-600' %>">
            <input type="checkbox" name="template_keys[]" value="<%= key %>"
                   <%= "checked" if active %>
                   data-exclusive="<%= is_exclusive %>"
                   data-action="change->template-picker#toggle"
                   class="sr-only">

            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-ink/[.06] dark:bg-white/10 transition-colors group-has-[:checked]:bg-accent-100 group-has-[:checked]:text-accent-700 dark:group-has-[:checked]:bg-accent-900/30 dark:group-has-[:checked]:text-accent-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                <path d="<%= tpl[:icon] %>"/>
              </svg>
            </span>

            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-foreground leading-snug">
                <%= t("onboarding.steps.template.templates.#{key}.name") %>
              </p>
              <p class="text-xs text-muted-foreground mt-0.5 line-clamp-2 leading-relaxed">
                <%= t("onboarding.steps.template.templates.#{key}.description") %>
              </p>
            </div>

            <%# Checkmark badge when selected %>
            <span class="pointer-events-none hidden h-5 w-5 shrink-0 items-center justify-center rounded-full bg-accent-600 text-white group-has-[:checked]:flex">
              <svg viewBox="0 0 12 12" fill="none" class="h-3 w-3" aria-hidden="true">
                <path d="M2.5 6L5 8.5L9.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </label>
        <% end %>
      </div>

      <div class="mt-4 flex items-center justify-between gap-3">
        <%= render(Campbooks::Button.new(variant: :primary, type: :submit)) { t(".apply_button") } %>
        <p class="text-xs text-muted-foreground max-w-xs"><%= t(".non_destructive_note") %></p>
      </div>
    <% end %>
  </div>

  <%# ── Module visibility ────────────────────────────────── %>
  <div class="rounded-xl border border-border bg-card p-6">
    <h2 class="text-sm font-semibold text-foreground"><%= t(".modules_heading") %></h2>
    <p class="mt-1 text-xs text-muted-foreground"><%= t(".modules_hint") %></p>

    <%= form_with url: update_modules_settings_setup_template_path, method: :patch, class: "mt-4 space-y-2" do |f| %>
      <% @module_keys.each do |key| %>
        <%
          visible = @workspace.module_visible?(key)
          label   = t("navigation.settings.module_visibility.#{key}", default: key.titleize)
        %>
        <label class="flex cursor-pointer items-center justify-between gap-4 rounded-lg border border-border px-4 py-3 transition-colors hover:bg-muted/40">
          <span class="text-sm font-medium text-foreground"><%= label %></span>
          <input type="checkbox" name="module_visibility[<%= key %>]"
                 value="1" <%= "checked" if visible %>
                 class="h-4 w-4 rounded border-border accent-accent-600">
        </label>
      <% end %>

      <div class="pt-2">
        <%= render(Campbooks::Button.new(variant: :secondary, type: :submit, size: :sm)) { t(".save_modules") } %>
      </div>
    <% end %>
  </div>

</div>
