<%# Unified settings navigation: one grouped list, always fully visible, so
    every section stays reachable. The groups come from `settings_nav_groups`
    (NavigationHelper) so this sidebar and the topbar user menu stay in sync.
    Each item is [path, active_keys, label, icon_path]; a link is active when
    current_section is in its key list.
    Note: inbox-specific settings (Tags, Filtering, Labels, Signatures, Accounts,
    Display, …) live under the "Inbox" section, which opens the same panels as the
    inbox gear-icon modal. Contacts is now its own primary-nav page. %>
<nav class="w-full lg:w-56 lg:flex-shrink-0" aria-label="<%= t(".aria_label") %>">
  <% settings_nav_groups.each_with_index do |(heading, items), group_index| %>
    <div class="<%= "mt-6" unless group_index.zero? %>">
      <p class="px-3 pb-1 text-[11px] font-semibold uppercase tracking-wider text-gray-400"><%= heading %></p>
      <div class="space-y-0.5">
        <% items.each do |path, active_keys, label, icon_path| %>
          <% active = active_keys.include?(current_section) %>
          <%= link_to path,
                "aria-current": (active ? "page" : nil),
                class: "flex items-center gap-2.5 px-3 py-2 text-sm rounded-md #{active ? 'bg-accent-50 text-accent-700 font-medium' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= icon_path %>"/></svg>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# App version — single source of truth is the VERSION file (Campbooks::VERSION).
      Links to the changelog so self-hosters can see what they're running / what's new.
      Brand name + version number, so no translation needed. %>
  <p class="mt-8 px-3 text-[11px] text-gray-400">
    <a href="https://github.com/notacamp/campbooks/blob/main/CHANGELOG.md"
       target="_blank" rel="noopener"
       class="transition-colors hover:text-gray-600">Campbooks v<%= Campbooks::VERSION %></a>
  </p>
</nav>
