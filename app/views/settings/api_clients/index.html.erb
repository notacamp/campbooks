<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"))) do %>
  <%= render(Campbooks::Button.new(variant: :outline, size: :md, href: api_docs_url, target: "_blank", rel: "noopener")) { t(".read_docs") } %>
  <%= render(Campbooks::Button.new(variant: :primary, size: :md, href: new_settings_api_client_path)) { t(".new_client") } %>
<% end %>

<%= render(Campbooks::Card.new(padding: :lg)) do %>
  <% if @applications.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b text-left text-xs font-medium text-gray-500">
            <th class="py-2 pr-4"><%= t(".col_name") %></th>
            <th class="py-2 pr-4"><%= t(".col_client_id") %></th>
            <th class="py-2 pr-4"><%= t(".col_scopes") %></th>
            <th class="py-2 pr-4"><%= t(".col_created") %></th>
            <th class="py-2"></th>
          </tr>
        </thead>
        <tbody>
          <% @applications.each do |application| %>
            <tr class="border-b last:border-0 align-top">
              <td class="py-3 pr-4 font-medium text-gray-900 whitespace-nowrap"><%= application.name %></td>
              <td class="py-3 pr-4 whitespace-nowrap">
                <span class="inline-flex items-center gap-1.5" data-controller="clipboard">
                  <span class="font-mono text-xs text-gray-500" title="<%= application.uid %>"><%= application.uid.first(8) %>…</span>
                  <input type="hidden" value="<%= application.uid %>" data-clipboard-target="source">
                  <button type="button" data-clipboard-target="button" data-action="clipboard#copy"
                          class="text-xs text-gray-400 hover:text-gray-700 cursor-pointer"><%= t(".copy") %></button>
                </span>
              </td>
              <td class="py-3 pr-4">
                <% scopes = application.scopes.to_a
                   families = scopes.map { |s| Api::Scopes.family_of(s) }.uniq %>
                <div class="flex flex-wrap items-center gap-1" title="<%= scopes.join(" ") %>">
                  <% if scopes.sort == Api::Scopes.all.sort %>
                    <%= render(Campbooks::Badge.new(variant: :neutral, size: :sm)) { t(".all_scopes") } %>
                  <% else %>
                    <% families.first(4).each do |family| %>
                      <%= render(Campbooks::Badge.new(variant: :neutral, size: :sm)) { t("settings.api_clients.scope_families.#{family}") } %>
                    <% end %>
                    <% if families.size > 4 %>
                      <span class="text-xs text-gray-500"><%= t(".more_families", count: families.size - 4) %></span>
                    <% end %>
                  <% end %>
                </div>
              </td>
              <td class="py-3 pr-4 text-gray-500 whitespace-nowrap"><%= l(application.created_at.to_date) %></td>
              <td class="py-3 text-right whitespace-nowrap">
                <%= button_to t(".regenerate"), regenerate_secret_settings_api_client_path(application),
                      class: "inline px-2 py-1 text-xs text-gray-600 hover:text-gray-900 cursor-pointer",
                      form: { class: "inline", data: { turbo_confirm: t(".regenerate_confirm") } } %>
                <%= button_to t(".revoke"), revoke_settings_api_client_path(application),
                      class: "inline px-2 py-1 text-xs text-gray-600 hover:text-gray-900 cursor-pointer",
                      form: { class: "inline", data: { turbo_confirm: t(".revoke_confirm") } } %>
                <%= button_to t(".delete"), settings_api_client_path(application), method: :delete,
                      class: "inline px-2 py-1 text-xs text-red-600 hover:text-red-700 cursor-pointer",
                      form: { class: "inline", data: { turbo_confirm: t(".delete_confirm", name: application.name) } } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render(Campbooks::EmptyState.new(variant: :card, title: t(".no_clients_title"), description: t(".no_clients_desc"))) %>
  <% end %>
<% end %>
