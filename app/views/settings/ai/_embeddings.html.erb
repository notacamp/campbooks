<%# ── Embedding Model ──────────────────────────────────────── %>
<div>
  <h2 class="text-base font-semibold text-gray-900 mb-1"><%= t(".embeddings_heading") %></h2>
  <p class="text-sm text-gray-500 mb-4"><%= t(".embeddings_desc") %></p>

  <% if @embedding_stale > 0 && @embedding_total > 0 && @embedding_available %>
    <%= render(Campbooks::Alert.new(variant: :info)) do %>
      <%= t(".reindex_progress", done: @embedding_total - @embedding_stale, total: @embedding_total) %>
    <% end %>
  <% end %>

  <%= form_with url: embeddings_settings_ai_path, method: :patch do |f| %>
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-3 mb-4">
      <% Ai::EmbeddingModels.all.each do |entry| %>
        <%
          checked   = @org.embedding_model == entry.key ||
                      (@org.embedding_model.nil? && entry.default?)
          region_ok = @org.region_allows?(entry.provider)
          available = region_ok && EmbeddingService.available_for?(@org, entry: entry)
          disabled  = !region_ok || !available
          provider_name = human_enum(AiAdapter, :provider, entry.provider)
        %>
        <%# has-checked: keeps the highlight in sync as the user picks a card
            client-side (the input is sr-only, so the label carries all the
            visible selection state). %>
        <label class="<%= class_names("relative flex flex-col gap-2 bg-card rounded-xl border p-3 cursor-pointer transition-colors",
                                       "border-gray-200 hover:border-gray-300 has-checked:border-accent-500 has-checked:ring-1 has-checked:ring-accent-500",
                                       disabled ? "opacity-60 cursor-not-allowed" : "") %>">
          <input type="radio"
                 name="embedding_model"
                 value="<%= entry.key %>"
                 <%= "checked" if checked %>
                 <%= "disabled" if disabled %>
                 class="sr-only peer">

          <div class="flex items-center justify-between gap-2 flex-wrap">
            <span class="text-sm font-semibold font-mono text-gray-900"><%= entry.model %></span>
            <div class="flex items-center gap-1.5 flex-wrap">
              <%= render(Campbooks::AiRegionBadge.new(provider: entry.provider)) %>
              <% if entry.default? %>
                <%= render(Campbooks::Badge.new(variant: :neutral)) { t(".default_model") } %>
              <% end %>
              <%= render(Campbooks::Badge.new(variant: :neutral)) { "#{entry.dimensions}d" } %>
            </div>
          </div>

          <span class="text-xs text-gray-500"><%= provider_name %></span>

          <% unless region_ok %>
            <p class="text-xs text-amber-700 dark:text-amber-400"><%= t(".region_blocked_hint") %></p>
          <% end %>
          <% if region_ok && !available %>
            <p class="text-xs text-gray-500">
              <%= t(".configure_provider_hint", provider: provider_name) %>
            </p>
          <% end %>
        </label>
      <% end %>
    </div>

    <%= render(Campbooks::Button.new(
          variant: :primary,
          size: :sm,
          type: :submit,
          data: { turbo_confirm: t(".change_confirm") })) do %>
      <%= t(".save_embedding_model") %>
    <% end %>
  <% end %>
</div>
