<% content_for :sidebar do %><%= render "settings/sidebar" %><% end %>
<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: t(".subtitle"))) do %>
  <button onclick="document.getElementById('invite-modal').classList.remove('hidden')"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-accent-600 text-white rounded-lg hover:bg-accent-700 transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    <%= t(".invite_button") %>
  </button>
<% end %>

<%# ── Invite Modal ──────────────────────────────────────────── %>
<div id="invite-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/30" onclick="if (event.target === this) this.classList.add('hidden')">
  <div class="bg-card rounded-xl shadow-xl border border-gray-200 w-full max-w-sm mx-4" role="dialog" aria-modal="true">
    <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-gray-900"><%= t(".invite_modal_heading") %></h3>
      <button onclick="document.getElementById('invite-modal').classList.add('hidden')"
              class="w-5 h-5 flex items-center justify-center rounded text-gray-400 hover:text-gray-600 hover:bg-gray-100">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <%= form_with model: [:settings, @invitation], class: "px-5 py-4 space-y-4" do |f| %>
      <div>
        <label for="invitation_email" class="block text-sm font-medium text-gray-700 mb-1.5"><%= t(".email_label") %></label>
        <%= f.email_field :email, id: "invitation_email", required: true,
              placeholder: t(".email_placeholder"),
              class: "block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500" %>
      </div>

      <div class="flex items-center justify-between pt-2 border-t border-gray-100">
        <button type="button" onclick="document.getElementById('invite-modal').classList.add('hidden')"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors">
          <%= t("shared.actions.cancel") %>
        </button>
        <%= render(Campbooks::Button.new(variant: :primary, size: :xs, type: :submit)) { t(".send_invitation") } %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Current Members ───────────────────────────────────────── %>
<div class="bg-card rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-8">
  <div class="px-5 py-3 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-900"><%= t(".current_members_heading", count: @members.count) %></h2>
  </div>
  <% if @members.any? %>
    <div class="divide-y divide-gray-100">
      <% @members.each do |member| %>
        <div class="flex flex-wrap items-center justify-between gap-2 px-5 py-3">
          <div class="flex min-w-0 items-center gap-3">
            <%= render(Campbooks::Avatar.new(name: member.name, size: :sm)) %>
            <div class="min-w-0">
              <p class="truncate text-sm font-medium text-gray-900"><%= member.name %></p>
              <p class="truncate text-xs text-gray-500"><%= member.email_address %></p>
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <% if member == Current.user %>
              <%= render(Campbooks::Badge.new(variant: :accent, size: :sm)) { t(".you_badge") } %>
            <% end %>
            <%= render(Campbooks::Badge.new(variant: member.admin? ? :accent : :neutral, size: :sm)) { human_enum(User, :role, member.role) } %>
            <%# Workspace admins hand the admin role to teammates (never themselves). %>
            <% if Current.user.admin? && member != Current.user %>
              <% if member.admin? %>
                <%= button_to t(".make_member"), settings_member_path(member, role: "member"), method: :patch,
                      class: "text-xs text-gray-500 hover:text-gray-700 font-medium cursor-pointer" %>
              <% else %>
                <%= button_to t(".make_admin"), settings_member_path(member, role: "admin"), method: :patch,
                      class: "text-xs text-accent-600 hover:text-accent-700 font-medium cursor-pointer" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render(Campbooks::EmptyState.new(variant: :inline, title: t(".no_members"))) %>
  <% end %>
</div>

<%# ── Pending Invitations ───────────────────────────────────── %>
<% pending_invites = @invitations.select(&:pending?) %>
<% if pending_invites.any? %>
  <div class="bg-card rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-900"><%= t(".pending_heading") %></h2>
    </div>
    <div class="divide-y divide-gray-100">
      <% pending_invites.each do |invitation| %>
        <div class="flex flex-wrap items-center justify-between gap-2 px-5 py-3">
          <div class="min-w-0">
            <p class="truncate text-sm font-medium text-gray-900"><%= invitation.email %></p>
            <p class="text-xs text-gray-500">
              <%= t(".invited_by", name: invitation.invited_by.name) %>
              &middot; <%= t(".expires_in", time: time_ago_in_words(invitation.expires_at)) %>
            </p>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <%# Cloud: a member's invitation waits for a workspace admin to release it. %>
            <% unless invitation.admin_approved? %>
              <%= render(Campbooks::Badge.new(variant: :warning, size: :sm)) { t(".awaiting_approval") } %>
              <% if Current.user.admin? %>
                <%= button_to t(".approve"), approve_settings_invitation_path(invitation), method: :post,
                      class: "text-xs text-accent-600 hover:text-accent-700 font-medium cursor-pointer" %>
              <% end %>
            <% end %>
            <%= button_to t(".resend"), resend_settings_invitation_path(invitation), method: :post,
                  class: "text-xs text-accent-600 hover:text-accent-700 font-medium cursor-pointer" %>
            <%= button_to t(".cancel_invitation"), settings_invitation_path(invitation), method: :delete,
                  form: { data: { turbo_confirm: t(".cancel_confirm") } },
                  class: "text-xs text-red-600 hover:text-red-700 font-medium cursor-pointer dark:text-red-400 dark:hover:text-red-300" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Past Invitations ──────────────────────────────────────── %>
<% past_invites = @invitations.reject(&:pending?) %>
<% if past_invites.any? %>
  <details class="mt-6">
    <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700"><%= t(".past_heading", count: past_invites.count) %></summary>
    <div class="mt-2 space-y-1">
      <% past_invites.each do |invitation| %>
        <div class="flex items-center justify-between px-4 py-2 text-sm bg-card rounded-lg border border-gray-100">
          <span class="text-gray-700"><%= invitation.email %></span>
          <%= render(Campbooks::Badge.new(variant: invitation.accepted? ? :success : :neutral, size: :sm)) { human_enum(Invitation, :status, invitation.status) } %>
        </div>
      <% end %>
    </div>
  </details>
<% end %>

