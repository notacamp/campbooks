<%# Variables fill form, loaded into the email_template_picker_frame turbo-frame.
    The Insert button is wired to the email-template-picker controller, which
    collects [data-template-var] inputs and POSTs them to the apply endpoint. %>
<% frame_id = request.headers["Turbo-Frame"].presence || "email_template_picker_frame" %>
<%= turbo_frame_tag frame_id do %>
  <div class="space-y-4">
    <div class="flex items-center gap-2">
      <%= link_to email_templates_path(to_address: params[:to_address]), class: "text-gray-400 hover:text-gray-600", aria: { label: t(".back") } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <% end %>
      <h3 class="text-sm font-semibold text-gray-900"><%= t(".title", name: @template.name) %></h3>
    </div>

    <% if @variables.any? %>
      <p class="text-xs text-gray-500"><%= t(".subtitle") %></p>
      <div class="space-y-3">
        <% @variables.each do |v| %>
          <% key = v["key"] %>
          <% val = @prefilled[key] || v["default"] || "" %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1"><%= v["label"] || key %><% if v["required"] %><span class="text-red-500"> *</span><% end %></label>
            <% case v["type"] %>
            <% when "text" %>
              <textarea data-template-var="<%= key %>" rows="3" class="block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500"><%= val %></textarea>
            <% when "date" %>
              <input type="date" data-template-var="<%= key %>" value="<%= val %>" class="block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500">
            <% when "number" %>
              <input type="number" data-template-var="<%= key %>" value="<%= val %>" class="block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500">
            <% when "email" %>
              <input type="email" data-template-var="<%= key %>" value="<%= val %>" class="block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500">
            <% else %>
              <input type="text" data-template-var="<%= key %>" value="<%= val %>" class="block w-full rounded-lg border-gray-300 shadow-sm text-sm focus:border-accent-500 focus:ring-accent-500">
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500"><%= t(".no_variables") %></p>
    <% end %>

    <% if @template.document_templates.any? %>
      <p class="text-xs text-gray-500 flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
        <%= t(".attachments_note", count: @template.document_templates.size) %>
      </p>
    <% end %>

    <div class="flex items-center justify-end gap-2 pt-2 border-t border-gray-100">
      <button type="button"
              data-action="email-template-picker#apply"
              data-email-template-picker-url-param="<%= apply_email_template_path(@template) %>"
              class="inline-flex items-center px-4 py-2 text-sm font-medium bg-accent-600 hover:bg-accent-700 text-white rounded-lg shadow-sm transition-colors cursor-pointer">
        <%= t(".insert") %>
      </button>
    </div>
  </div>
<% end %>
