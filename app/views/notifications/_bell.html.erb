<span id="notification_bell" data-controller="notification-bell">
  <button type="button" data-action="notification-bell#toggle" aria-label="<%= t(".heading") %>" class="relative inline-flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground cursor-pointer">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
    </svg>
    <% count = unread_count.to_i %>
    <% if count > 0 %>
      <%= render(Campbooks::Badge.new(variant: :danger, size: :sm, class: "absolute -top-1 -right-1")) { count > 9 ? "9+" : count } %>
    <% end %>
  </button>

  <div data-notification-bell-target="panel" class="hidden absolute right-0 mt-2 w-80 bg-popover text-popover-foreground rounded-lg shadow-lg ring-1 ring-border z-50">
    <div class="p-2 border-b border-border flex items-center justify-between">
      <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider"><%= t(".heading") %></h3>
      <% if unread_count.to_i > 0 %>
        <%= button_to t(".mark_all_read"), mark_all_read_notifications_path, method: :post,
            class: "text-xs text-accent-600 hover:text-accent-700 bg-transparent border-0 cursor-pointer p-0",
            form: { data: { turbo_stream: true } } %>
      <% end %>
    </div>
    <div class="max-h-80 overflow-y-auto" id="notification_dropdown">
      <% notifications_list = local_assigns.fetch(:notifications, current_user&.notifications&.active&.recent&.limit(10) || []) %>
      <%= render "notifications/dropdown_list", notifications: notifications_list %>
    </div>
    <div class="p-2 border-t border-border">
      <%= link_to t(".view_all"), notifications_path, class: "block text-center text-xs text-accent-600 hover:text-accent-700 font-medium" %>
    </div>
  </div>
</span>
