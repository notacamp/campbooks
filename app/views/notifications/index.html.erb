<%= content_for :title, t(".title") %>

<%= render(Campbooks::PageHeader.new(title: t(".title"), subtitle: current_user.unread_notifications_count.positive? ? t(".subtitle", count: current_user.unread_notifications_count) : nil)) do |header| %>
  <% header.with_actions do %>
    <% if current_user.unread_notifications_count.positive? %>
      <%= button_to t(".mark_all_read"), mark_all_read_notifications_path, method: :post,
          class: "text-sm text-muted-foreground hover:text-foreground underline bg-transparent border-0 cursor-pointer p-0" %>
    <% end %>
    <% if current_user.notifications.active.read.exists? %>
      <%= button_to t(".archive_read"), archive_all_notifications_path, method: :post,
          class: "text-sm text-muted-foreground hover:text-foreground underline bg-transparent border-0 cursor-pointer p-0" %>
    <% end %>
  <% end %>
<% end %>

<%# Filter tabs %>
<div class="flex items-center gap-1 border-b border-border mb-4 overflow-x-auto">
  <% [["all", t(".filters.all")], ["needs_action", t(".filters.needs_action")], ["unread", t(".filters.unread")], ["archived", t(".filters.archived")]].each do |key, label| %>
    <% active = @filter == key %>
    <%= link_to label, notifications_path(filter: key),
        class: "px-3 py-2 text-sm font-medium border-b-2 -mb-px transition-colors whitespace-nowrap flex-shrink-0 #{active ? 'border-accent-600 text-foreground' : 'border-transparent text-muted-foreground hover:text-foreground'}" %>
  <% end %>
</div>

<% if @notifications.any? %>
  <div class="bg-card shadow-sm rounded-lg border border-border divide-y divide-border/60">
    <% @notifications.each do |n| %>
      <%= render(Campbooks::NotificationItem.new(notification: n, compact: false)) %>
    <% end %>
  </div>

  <% if @pagy.next %>
    <div class="mt-4 flex justify-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
<% else %>
  <div class="bg-card shadow-sm rounded-lg border border-border">
    <%= render(Campbooks::EmptyState.new(variant: :card)) do |state| %>
      <% state.with_icon(svg: '<svg class="w-6 h-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>') %>
      <p class="text-sm text-muted-foreground"><%= @filter == "archived" ? t(".empty_archived") : t(".all_caught_up") %></p>
    <% end %>
  </div>
<% end %>

<div class="mt-8 text-center">
  <p class="text-sm text-muted-foreground">
    <%= t(".manage_preferences_html", link: link_to(t(".preferences_link"), settings_notifications_path, class: "text-accent-600 hover:text-accent-700 underline")) %>
  </p>
</div>
