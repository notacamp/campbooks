<div class="mb-6">
  <div class="flex items-center space-x-2 mb-4">
    <%= link_to t(".breadcrumb_scans"), email_messages_path(inbox_settings: "accounts"), class: "text-sm text-accent-600 hover:text-accent-700" %>
    <span class="text-sm text-gray-400">/</span>
    <h1 class="text-2xl font-bold text-gray-900"><%= t(".page_heading", id: @scan_log.id) %></h1>
  </div>

  <%= render(Campbooks::Card.new(padding: :lg)) do %>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <dt class="text-sm text-gray-500"><%= t(".account_label") %></dt>
        <dd class="text-sm font-medium text-gray-900"><%= @scan_log.email_account.display_name %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t(".status_label") %></dt>
        <dd><%= status_badge(@scan_log.status) %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t(".started_label") %></dt>
        <dd class="text-sm text-gray-900"><%= @scan_log.started_at ? l(@scan_log.started_at, format: :at) : "-" %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t(".completed_label") %></dt>
        <dd class="text-sm text-gray-900"><%= @scan_log.completed_at ? l(@scan_log.completed_at, format: :at) : "-" %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t(".emails_found_label") %></dt>
        <dd class="text-sm text-gray-900"><%= @scan_log.emails_found %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t(".emails_processed_label") %></dt>
        <dd class="text-sm text-gray-900"><%= @scan_log.emails_processed %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t(".documents_created_label") %></dt>
        <dd class="text-sm text-gray-900"><%= @scan_log.documents_created %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500"><%= t(".errors_label") %></dt>
        <dd class="text-sm text-gray-900"><%= @scan_log.errors_count %></dd>
      </div>
    </dl>

    <% if @scan_log.error_messages.present? %>
      <div class="mt-6">
        <h3 class="text-sm font-medium text-gray-900 mb-2"><%= t(".error_details_heading") %></h3>
        <%= render(Campbooks::Alert.new(variant: :error)) do %>
          <pre class="text-xs"><%= JSON.pretty_generate(@scan_log.error_messages) %></pre>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

<% if @email_messages.any? %>
  <div class="mt-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4"><%= t(".emails_in_scan_heading") %></h3>
    <div class="bg-card shadow rounded-lg overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".table_from") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".table_subject") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".table_received") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".table_status") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @email_messages.each do |msg| %>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900"><%= msg.from_address || "-" %></td>
              <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate"><%= msg.subject || t(".no_subject") %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= msg.received_at ? l(msg.received_at, format: :day_month) : "-" %></td>
              <td class="px-6 py-4"><%= status_badge(msg.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
