<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
  <header class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-3">
      <h1 class="text-xl font-semibold tracking-tight text-foreground"><%= t("tasks.index.title") %></h1>
      <%= render "view_toggle", current: :board %>
    </div>
    <div class="flex items-center gap-2">
      <%= render "shared/customize_ai_button", purpose: "task_extraction" %>
      <%= render Campbooks::Button.new(href: new_task_path, variant: :primary, size: :sm) { t("tasks.index.new") } %>
    </div>
  </header>

  <%= render Campbooks::Tasks::Board.new(columns: @columns) %>
</div>
