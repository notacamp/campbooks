<div class="mx-auto max-w-2xl px-4 py-6 sm:px-6 lg:px-8">
  <header class="mb-6 flex items-start justify-between gap-3">
    <div>
      <h1 class="text-xl font-semibold tracking-tight text-foreground"><%= t(".title") %></h1>
      <p class="mt-1 text-sm text-muted-foreground"><%= t(".subtitle") %></p>
    </div>
    <%= link_to t(".all_tasks"), tasks_path, class: "shrink-0 text-sm font-medium text-muted-foreground transition hover:text-foreground" %>
  </header>

  <% if @tasks.empty? %>
    <%= render Campbooks::EmptyState.new(title: t(".empty_title"), description: t(".empty_body")) %>
  <% else %>
    <div class="divide-y divide-hair">
      <% @tasks.each do |task| %>
        <article class="py-5 first:pt-0">
          <div class="flex items-start justify-between gap-3">
            <%= link_to task.title, task_path(task), class: "text-sm font-semibold text-foreground transition hover:text-foreground/70" %>
            <% if task.due_at %>
              <span class="shrink-0 text-xs <%= task.due_at < Time.current ? "font-medium text-red-600 dark:text-red-400" : "text-muted-foreground" %>"><%= l(task.due_at, format: :at) %></span>
            <% end %>
          </div>

          <% if task.description.present? %>
            <p class="mt-1.5 text-sm leading-relaxed text-foreground/80"><%= strip_tags(task.description) %></p>
          <% end %>

          <% if task.source_email.present? %>
            <%= link_to email_message_path(task.source_email), class: "mt-2 inline-flex max-w-full items-center gap-1.5 text-xs text-muted-foreground transition hover:text-foreground" do %>
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
              <span class="truncate"><%= t(".from_email", subject: task.source_email.subject.presence || task.source_email.from_address) %></span>
            <% end %>
          <% elsif task.source_type == "Document" && task.source.present? %>
            <%= link_to document_path(task.source), class: "mt-2 inline-flex max-w-full items-center gap-1.5 text-xs text-muted-foreground transition hover:text-foreground" do %>
              <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/></svg>
              <span class="truncate"><%= t(".from_document", title: task.source.display_title) %></span>
            <% end %>
          <% end %>

          <% if task.justification.present? %>
            <p class="mt-2 flex items-start gap-1.5 text-xs text-muted-foreground">
              <svg class="mt-px h-3.5 w-3.5 shrink-0 text-ember" viewBox="0 0 24 24" fill="currentColor"><path d="M12 5l1.7 5.6L19.5 12l-5.8 1.4L12 19l-1.7-5.6L4.5 12l5.8-1.4z"/></svg>
              <span><span class="font-medium text-foreground/70"><%= t(".why") %></span> <%= task.justification %></span>
            </p>
          <% end %>

          <div class="mt-3.5 flex flex-wrap items-center gap-2">
            <%= button_to t(".accept"), accept_task_path(task), method: :patch, data: { turbo: false }, class: task_btn(:primary) %>
            <%= button_to t(".complete"), complete_task_path(task), method: :patch, data: { turbo: false }, class: task_btn(:outline) %>
            <%= button_to t(".dismiss"), dismiss_task_path(task), method: :patch, data: { turbo: false }, class: task_btn(:ghost) %>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>
</div>
