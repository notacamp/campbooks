<% thread = local_assigns[:thread] || @thread %>
<% threads = local_assigns[:threads] || @threads %>
<% messages = local_assigns[:messages] || @messages %>

<%= turbo_stream_from "agent_chat_#{current_user.id}" %>

<div class="flex h-[calc(100vh-4rem)] bg-card" data-controller="email-mobile">
  <!-- Thread sidebar (mobile: shown in list mode via the Chats button; desktop: always shown) -->
  <div class="hidden sm:flex w-full sm:w-64 sm:flex-shrink-0 border-r border-border flex-col bg-sidebar" data-email-mobile-target="list">
    <div class="p-3">
      <%= button_to scout_threads_path,
            method: :post,
            class: "w-full inline-flex items-center justify-center gap-2 rounded-lg border border-border bg-card text-sm font-medium text-foreground px-3 py-2 hover:border-accent-300 hover:bg-accent-50 hover:text-accent-700 transition-colors duration-150 cursor-pointer",
            data: { action: "email-mobile#showDetail" } do %>
        <svg class="w-4 h-4 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        <%= t(".new_chat") %>
      <% end %>
    </div>
    <div class="flex-1 overflow-y-auto min-h-0 px-2 pb-2" id="thread_list">
      <% if threads.empty? %>
        <p class="text-xs text-muted-foreground text-center py-8"><%= t(".no_chats") %></p>
      <% else %>
        <% groups = threads.group_by { |t|
             d = t.updated_at
             if d >= Time.current.beginning_of_day then :today
             elsif d >= 7.days.ago then :this_week
             else :earlier end
           } %>
        <% [:today, :this_week, :earlier].each do |group_key| %>
          <% next unless groups[group_key]&.any? %>
          <div class="px-3 pt-3 pb-1 text-[11px] font-semibold uppercase tracking-wide text-muted-foreground"><%= t(".#{group_key}") %></div>
          <div class="space-y-0.5">
            <% groups[group_key].each do |t| %>
              <%= render "agent_chat/thread_item", thread: t, active: t == thread %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Chat panel -->
  <div class="flex-1 flex flex-col min-w-0" data-email-mobile-target="detail">
    <!-- Header -->
    <div class="px-4 sm:px-6 py-3 border-b border-border flex items-center gap-2.5 flex-shrink-0">
      <button type="button" data-action="click->email-mobile#showList" aria-label="<%= t(".show_chats_aria") %>"
              class="sm:hidden inline-flex items-center justify-center w-8 h-8 -ml-1 rounded-lg text-muted-foreground hover:bg-accent hover:text-foreground transition-colors cursor-pointer flex-shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <%= render(Campbooks::ScoutAvatar.new(size: :sm)) %>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <div id="thread_header_title" class="min-w-0 flex-1">
            <%= render "agent_chat/thread_title", thread: thread %>
          </div>
          <% if thread.context_label %>
            <span class="text-[11px] text-accent-700 dark:text-accent-300 bg-accent-50 dark:bg-accent-500/10 rounded px-1.5 py-0.5 flex-shrink-0"><%= thread.context_label %></span>
          <% end %>
          <%= button_to scout_thread_path(thread),
                method: :delete,
                class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-muted-foreground hover:text-destructive hover:bg-destructive/10 transition-colors flex-shrink-0 cursor-pointer",
                title: t(".delete_chat"),
                aria: { label: t(".delete_chat_aria") },
                form: { data: { turbo: false, turbo_confirm: t(".delete_confirm") } } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          <% end %>
        </div>
        <% if thread.email_chat? && (url = thread.context_url) %>
          <%= link_to url, class: "text-[11px] text-accent-600 dark:text-accent-300 hover:text-accent-700 mt-0.5 inline-block" do %>
            <svg class="w-3 h-3 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            <%= t(".open_email") %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Messages + Form -->
    <div id="agent_messages_wrapper" class="flex-1 flex flex-col min-h-0">
      <%= render "agent_chat/messages_panel", thread: thread, messages: messages, briefing: local_assigns[:briefing] || @briefing %>
    </div>
  </div>
</div>
