<div id="<%= dom_id(email_message, :draft_questions) %>" class="px-4 py-3">
  <div class="flex items-start gap-3 ">
    <div class="w-6 h-6 rounded-full bg-blue-100 dark:bg-blue-500/15 text-blue-500 dark:text-blue-400 flex items-center justify-center flex-shrink-0 mt-0.5">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
        <path fill-rule="evenodd" d="M9 4.5a.75.75 0 01.721.544l.813 2.846a3.75 3.75 0 002.576 2.576l2.846.813a.75.75 0 010 1.442l-2.846.813a3.75 3.75 0 00-2.576 2.576l-.813 2.846a.75.75 0 01-1.442 0l-.813-2.846a3.75 3.75 0 00-2.576-2.576l-2.846-.813a.75.75 0 010-1.442l2.846-.813A3.75 3.75 0 007.466 7.89l.813-2.846A.75.75 0 019 4.5zM18 1.5a.75.75 0 01.728.568l.258 1.036c.236.94.88 1.584 1.82 1.82l1.036.258a.75.75 0 010 1.456l-1.036.258c-.94.236-1.584.88-1.82 1.82l-.258 1.036a.75.75 0 01-1.456 0l-.258-1.036a2.625 2.625 0 00-1.82-1.82l-1.036-.258a.75.75 0 010-1.456l1.036-.258a2.625 2.625 0 001.82-1.82l.258-1.036A.75.75 0 0118 1.5zM16.5 15a.75.75 0 01.712.513l.394 1.183c.15.447.5.799.948.948l1.183.395a.75.75 0 010 1.422l-1.183.395c-.447.15-.799.5-.948.948l-.395 1.183a.75.75 0 01-1.422 0l-.395-1.183a1.5 1.5 0 00-.948-.948l-1.183-.395a.75.75 0 010-1.422l1.183-.395a1.5 1.5 0 00.948-.948l.395-1.183A.75.75 0 0116.5 15z" clip-rule="evenodd"/>
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1 ">
        <span class="text-[12px] font-semibold text-gray-900">Scout</span>
        <span class="text-[10px] text-gray-400"><%= t(".needs_details") %></span>
      </div>

      <% questions.each do |q| %>
        <div class="mt-2 bg-gray-50 dark:bg-gray-500/10 rounded-lg px-3 py-2">
          <p class="text-[12px] font-medium text-gray-700 mb-1.5"><%= q["question"] %></p>
          <div class="flex items-center gap-1.5 flex-wrap">
            <% (q["options"] || []).each do |option| %>
              <%= form_with url: tool_email_message_path(email_message), method: :post,
                    html: { data: { turbo: true } }, class: "inline" do |f| %>
                <%= f.hidden_field :tool, value: "draft_reply" %>
                <%= f.hidden_field :args, value: { "answers" => { q["variable"] => option } }.to_json %>
                <%= f.submit option,
                      class: "inline-flex items-center font-medium transition-colors text-gray-600 bg-card hover:bg-gray-100 border border-gray-300 rounded-full px-2.5 py-0.5 cursor-pointer text-[11px]" %>
              <% end %>
            <% end %>
            <% if q["options"].empty? %>
              <div class="flex items-center gap-1.5 w-full">
                <%= form_with url: tool_email_message_path(email_message), method: :post,
                      html: { data: { turbo: true } }, class: "flex items-center gap-1.5 flex-1" do |f| %>
                  <%= f.hidden_field :tool, value: "draft_reply" %>
                  <%= f.hidden_field :args, value: "{}" %>
                  <%= f.text_field "answers[#{q['variable']}]", placeholder: t(".answer_placeholder"),
                        class: "flex-1 text-[12px] border border-gray-300 rounded-lg px-2.5 py-1 focus:ring-1 focus:ring-blue-400 dark:focus:ring-blue-500/40 focus:border-blue-400 dark:focus:border-blue-500/40 focus:outline-none" %>
                  <%= f.submit t("shared.actions.send"),
                        class: "inline-flex items-center font-medium transition-colors bg-blue-600 text-white hover:bg-blue-700 rounded-lg px-3 py-1 text-[11px] cursor-pointer border-0" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
