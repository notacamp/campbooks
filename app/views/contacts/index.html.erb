<%= render(Campbooks::PageHeader.new(
  title: t(".heading"),
  subtitle: t(".subheading"),
  spacing: :lg
)) do |header| %>
  <% header.with_actions do %>
    <span class="text-sm text-muted-foreground whitespace-nowrap"><%= t(".people_count", count: @pagy.count) %></span>
  <% end %>
<% end %>

<div class="space-y-5">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
    <%= form_with url: contacts_path, method: :get, data: { turbo_frame: "isc_list" }, class: "flex-1 min-w-0" do %>
      <input type="search" name="q" value="<%= params[:q] %>" placeholder="<%= t(".search_placeholder") %>"
             class="block w-full rounded-lg border border-border bg-card shadow-sm text-sm px-3 py-2 focus:border-accent-500 focus:ring-accent-500">
    <% end %>
    <%= button_to t(".find_duplicates"), scan_dedup_contacts_path, method: :post,
          class: "whitespace-nowrap rounded-lg border border-border px-3 py-2 text-sm font-medium text-muted-foreground hover:bg-muted cursor-pointer transition-colors" %>
  </div>

  <% unless @searching %>
    <% if @pending_count.to_i > 0 %>
      <%= link_to skim_contacts_path,
            class: "flex items-center justify-between gap-3 rounded-xl border border-accent-200 bg-accent-50 dark:bg-accent-500/10 dark:border-accent-500/25 px-4 py-3 hover:bg-accent-100 dark:hover:bg-accent-500/15 transition-colors" do %>
        <div class="flex items-center gap-3 min-w-0">
          <span class="flex size-9 items-center justify-center rounded-lg bg-ember-gradient text-white flex-shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5l1.7 5.6L19.5 12l-5.8 1.4L12 19l-1.7-5.6L4.5 12l5.8-1.4z"/></svg>
          </span>
          <div class="min-w-0">
            <p class="text-sm font-semibold text-foreground"><%= t(".skim_cta_title") %></p>
            <p class="text-xs text-muted-foreground"><%= t(".skim_cta_subtitle", count: @pending_count) %></p>
          </div>
        </div>
        <span class="text-sm font-medium text-accent-700 dark:text-accent-300 flex-shrink-0" aria-hidden="true">→</span>
      <% end %>
    <% end %>

    <%= render "contacts/dedup", flagged: @flagged %>

    <% if @starred_contacts.any? %>
      <section>
        <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2 px-1"><%= t(".starred_heading") %></h2>
        <div class="divide-y divide-border rounded-xl border border-border bg-card overflow-hidden">
          <% @starred_contacts.each do |c| %><%= render "contacts/contact_row", contact: c %><% end %>
        </div>
      </section>
    <% end %>
  <% end %>

  <section>
    <% if !@searching && @starred_contacts.any? %>
      <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2 px-1"><%= t(".all_heading") %></h2>
    <% end %>
    <%= turbo_frame_tag "isc_list" do %>
      <%= render "contacts/list", people: @people_with_contacts, pagy: @pagy %>
    <% end %>
  </section>

  <% if !@searching && @blocked_count.to_i > 0 %>
    <details class="group rounded-xl border border-border bg-card overflow-hidden" <%= "open" if @show_blocked %>>
      <summary class="flex items-center justify-between gap-2 px-4 py-3 cursor-pointer text-sm font-medium text-muted-foreground hover:bg-muted/40 select-none">
        <span><%= t(".blocked_heading") %> <span class="text-xs text-muted-foreground/70">(<%= @blocked_count %>)</span></span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
      </summary>
      <div class="divide-y divide-border border-t border-border">
        <% @blocked_contacts.each do |c| %><%= render "contacts/contact_row", contact: c %><% end %>
      </div>
    </details>
  <% end %>
</div>
