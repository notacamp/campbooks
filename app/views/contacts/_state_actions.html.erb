<%# locals: contact — star/block controls for the profile header (re-rendered in
    place by set_state.turbo_stream after each change). %>
<div id="contact_state_actions_<%= contact.id %>" class="flex items-center gap-2">
  <%= button_to set_state_contact_path(contact, state: contact.starred? ? "unstar" : "star"),
        form: { class: "contents" },
        class: class_names(
          "inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium transition-colors cursor-pointer border",
          contact.starred? ? "border-amber-300 bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:border-amber-500/30 dark:text-amber-300" : "border-border text-muted-foreground hover:bg-muted"
        ) do %>
    <%= contact_star_icon(filled: contact.starred?) %>
    <%= contact.starred? ? t("contacts.state.starred") : t("contacts.state.star") %>
  <% end %>

  <% if contact.blocked? %>
    <%= button_to set_state_contact_path(contact, state: "unblock"),
          form: { class: "contents" },
          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium border border-border text-muted-foreground hover:bg-muted transition-colors cursor-pointer" do %>
      <%= contact_unblock_icon %>
      <%= t("contacts.state.unblock") %>
    <% end %>
  <% else %>
    <%= button_to set_state_contact_path(contact, state: "block"),
          form: { class: "contents", data: { turbo_confirm: t("contacts.state.block_confirm") } },
          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium border border-border text-muted-foreground hover:bg-red-50 hover:text-red-600 hover:border-red-200 dark:hover:bg-red-500/10 transition-colors cursor-pointer" do %>
      <%= contact_block_icon %>
      <%= t("contacts.state.block") %>
    <% end %>
  <% end %>
</div>
