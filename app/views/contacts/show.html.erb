<div class="mb-4">
  <%= link_to contacts_path, class: "inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <%= t(".back_aria") %>
  <% end %>
</div>

<%= render(Campbooks::PageHeader.new(
  title: @contact.display_name,
  subtitle: @contact.email,
  spacing: :lg
)) do |header| %>
  <% header.with_actions do %>
    <%= render "contacts/state_actions", contact: @contact %>
    <div data-controller="re-analyze" class="flex-shrink-0">
      <div data-re-analyze-target="button">
        <button type="button" data-action="click->re-analyze#toggle"
                class="rounded-lg bg-accent-600 text-white px-3 py-2 text-sm font-medium hover:bg-accent-700 transition-colors cursor-pointer">
          <%= @contact.analyzed_at.present? ? t(".re_analyze") : t(".analyze") %>
        </button>
      </div>
      <div data-re-analyze-target="form" class="hidden">
        <%= form_tag analyze_contact_path(@contact), method: :post,
              data: { action: "turbo:submit-start->re-analyze#submitting" }, class: "flex items-start gap-2" do %>
          <%= text_area_tag :prompt, nil, rows: 2, placeholder: t(".analyze_prompt_placeholder"),
                data: { re_analyze_target: "input" },
                class: "w-48 text-sm border border-border rounded-lg px-2 py-1.5 focus:ring-accent-500 focus:border-accent-500 resize-none" %>
          <button type="submit" class="rounded-lg bg-accent-600 text-white px-2.5 py-2 text-sm font-medium hover:bg-accent-700 cursor-pointer flex-shrink-0"><%= t(".go") %></button>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<div class="max-w-3xl space-y-6">
  <section class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 rounded-xl border border-border bg-card p-5">
    <div>
      <p class="text-xs font-medium text-muted-foreground mb-1"><%= t(".name_label") %></p>
      <%= render "contacts/name_field", contact: @contact, person: @person %>
    </div>
    <div>
      <p class="text-xs font-medium text-muted-foreground mb-1"><%= t(".relationship_label") %></p>
      <%= render "contacts/relationship_field", contact: @contact, person: @person %>
    </div>
    <div>
      <p class="text-xs font-medium text-muted-foreground mb-1"><%= t(".emails_exchanged_label") %></p>
      <p class="text-sm text-foreground"><%= @contact.email_count %></p>
    </div>
    <div>
      <p class="text-xs font-medium text-muted-foreground mb-1"><%= t(".last_contact_label") %></p>
      <p class="text-sm text-foreground"><%= @contact.last_email_at ? t(".last_contact_ago", time: time_ago_in_words(@contact.last_email_at)) : "—" %></p>
    </div>
    <% if Features.organizations? %>
      <div>
        <p class="text-xs font-medium text-muted-foreground mb-1"><%= t(".organization_label") %></p>
        <% org = @contact.person&.primary_organization %>
        <% if org %>
          <%= render(Campbooks::OrganizationBadge.new(organization: org)) %>
        <% elsif @contact.organization.present? %>
          <p class="text-sm text-muted-foreground"><%= @contact.organization %></p>
        <% else %>
          <p class="text-sm text-muted-foreground">—</p>
        <% end %>
      </div>
    <% end %>
  </section>

  <div id="contact_analysis_section">
    <% if @contact.context_summary.present? %>
      <div class="rounded-xl border border-amber-200 bg-amber-50 dark:bg-amber-500/10 dark:border-amber-500/25 p-4">
        <p class="text-[11px] font-semibold text-amber-700 dark:text-amber-300 mb-1.5"><%= t(".scouts_analysis") %></p>
        <p class="text-sm text-foreground leading-relaxed"><%= @contact.context_summary %></p>
      </div>
    <% elsif @contact.analyzed_at.nil? %>
      <p class="text-sm text-muted-foreground"><%= t(".run_analysis_prompt") %></p>
    <% end %>
  </div>

  <section>
    <h2 class="text-sm font-semibold text-foreground mb-3"><%= t(".email_history_heading") %></h2>
    <% if @email_messages.any? %>
      <div class="divide-y divide-border rounded-xl border border-border bg-card overflow-hidden">
        <% @email_messages.each do |msg| %>
          <%= link_to email_message_path(msg), class: "block px-4 py-3 hover:bg-muted/40 transition-colors min-w-0" do %>
            <p class="text-sm text-foreground truncate"><%= msg.subject.presence || t(".no_subject") %></p>
            <p class="text-xs text-muted-foreground truncate"><%= msg.from_address %> &middot; <%= msg.received_at ? l(msg.received_at, format: :full) : "—" %></p>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-muted-foreground"><%= t(".no_email_history") %></p>
    <% end %>
  </section>

  <% if @documents.any? %>
    <section>
      <h2 class="text-sm font-semibold text-foreground mb-3"><%= t(".documents_heading") %></h2>
      <div class="divide-y divide-border rounded-xl border border-border bg-card overflow-hidden">
        <% @documents.each do |doc| %>
          <%= link_to document_path(doc), class: "block px-4 py-3 hover:bg-muted/40 transition-colors min-w-0" do %>
            <p class="text-sm text-foreground truncate"><%= doc.display_title %></p>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
