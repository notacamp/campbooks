<%# locals: flagged %>
<div id="isc_dedup">
  <% if flagged.any? %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 dark:bg-amber-500/10 dark:border-amber-500/25 p-4">
      <p class="text-xs font-semibold text-amber-700 dark:text-amber-300 mb-2"><%= t(".possible_duplicates", count: flagged.size) %></p>
      <ul class="space-y-1.5">
        <% flagged.each do |contact| %>
          <li class="flex items-center justify-between gap-2 text-sm">
            <span class="min-w-0 truncate text-foreground">
              <%= contact.display_name %>
              <span class="text-muted-foreground">→ <%= contact.suggested_person&.display_name %> <%= t(".confidence", pct: (contact.suggested_confidence.to_f * 100).round) %></span>
            </span>
            <span class="flex items-center gap-1 flex-shrink-0">
              <%= button_to t(".merge"), resolve_duplicate_contact_path(contact, approve: true), method: :post,
                    class: "px-2 py-0.5 text-xs font-medium text-white bg-green-600 hover:bg-green-700 rounded cursor-pointer" %>
              <%= button_to t(".dismiss"), resolve_duplicate_contact_path(contact, approve: false), method: :post,
                    class: "px-2 py-0.5 text-xs font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 dark:bg-white/10 dark:text-gray-300 rounded cursor-pointer" %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
