<% render "admin/sidebar" %>

<%# Return to the call log with whatever filters the row link carried over. %>
<% back_params = { service: params[:service].presence, status: params[:status].presence, window: params[:window].presence }.compact %>
<div class="mb-4">
  <%= link_to admin_system_health_path(back_params) + "#call-log",
        class: "inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <%= t(".back") %>
  <% end %>
</div>

<%= render(Campbooks::PageHeader.new(
      title: @call.operation.presence || t(".title_fallback"),
      subtitle: l(@call.created_at, format: :at))) %>

<%# ── Summary ── %>
<%= render(Campbooks::Card.new) do %>
  <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">

    <div>
      <dt class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-0.5"><%= t(".summary.service") %></dt>
      <dd class="font-medium"><%= t("system_health.services.#{@call.service}", default: @call.service.humanize) %></dd>
    </div>

    <div>
      <dt class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-0.5"><%= t(".summary.status") %></dt>
      <dd class="flex items-center gap-2">
        <% if @call.status_success? %>
          <%= render(Campbooks::Badge.new(variant: :success, size: :md)) { @call.http_status ? @call.http_status.to_s : "OK" } %>
        <% else %>
          <%= render(Campbooks::Badge.new(variant: :danger, size: :md)) { @call.http_status ? @call.http_status.to_s : "error" } %>
        <% end %>
      </dd>
    </div>

    <div>
      <dt class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-0.5"><%= t(".summary.duration") %></dt>
      <dd><%= @call.duration_ms ? "#{number_with_delimiter(@call.duration_ms)} ms" : "—" %></dd>
    </div>

    <% if @call.workspace.present? %>
      <div>
        <dt class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-0.5"><%= t(".summary.workspace") %></dt>
        <dd><%= @call.workspace.name %></dd>
      </div>
    <% end %>

    <% if @call.error_class.present? || @call.error_message.present? %>
      <div class="sm:col-span-2">
        <dt class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-0.5"><%= t(".summary.error") %></dt>
        <dd class="font-mono text-xs break-all">
          <% if @call.error_class.present? %><span class="font-medium"><%= @call.error_class %></span><% end %>
          <% if @call.error_class.present? && @call.error_message.present? %>: <% end %>
          <%= @call.error_message %>
        </dd>
      </div>
    <% end %>

    <% model = @call.metadata&.dig("model") %>
    <% tokens_in = @call.metadata&.dig("tokens_in") %>
    <% tokens_out = @call.metadata&.dig("tokens_out") %>
    <% if model.present? || tokens_in || tokens_out %>
      <div class="sm:col-span-2">
        <dt class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-0.5"><%= t(".summary.ai_metadata") %></dt>
        <dd class="text-xs font-mono space-x-3">
          <% if model.present? %><span><%= model %></span><% end %>
          <% if tokens_in %><span><%= t(".summary.tokens_in", count: number_with_delimiter(tokens_in)) %></span><% end %>
          <% if tokens_out %><span><%= t(".summary.tokens_out", count: number_with_delimiter(tokens_out)) %></span><% end %>
        </dd>
      </div>
    <% end %>

  </dl>
<% end %>

<%# ── Request headers ── %>
<div class="mt-8">
  <%= render(Campbooks::SectionHeader.new) { t(".request_headers") } %>
  <%= render(Campbooks::Card.new(class: "mt-3")) do %>
    <% if @call.request_headers.present? %>
      <dl class="divide-y divide-border">
        <% @call.request_headers.each do |name, value| %>
          <div class="flex gap-4 py-2 text-xs">
            <dt class="font-mono font-medium shrink-0 w-40 truncate"><%= name %></dt>
            <dd class="font-mono text-muted-foreground break-all"><%= value %></dd>
          </div>
        <% end %>
      </dl>
    <% else %>
      <p class="text-sm text-muted-foreground"><%= t(".not_captured") %></p>
    <% end %>
  <% end %>
</div>

<%# ── Request body ── %>
<div class="mt-6">
  <%= render(Campbooks::SectionHeader.new) { t(".request_body") } %>
  <%= render(Campbooks::Card.new(padding: :none, class: "mt-3")) do %>
    <% if @call.request_body.present? %>
      <pre class="font-mono text-xs whitespace-pre-wrap break-all overflow-x-auto max-h-96 overflow-y-auto p-4"><%= pretty_body(@call.request_body) %></pre>
    <% else %>
      <p class="text-sm text-muted-foreground p-5"><%= t(".not_captured") %></p>
    <% end %>
  <% end %>
</div>

<%# ── Response headers ── %>
<div class="mt-6">
  <%= render(Campbooks::SectionHeader.new) { t(".response_headers") } %>
  <%= render(Campbooks::Card.new(class: "mt-3")) do %>
    <% if @call.response_headers.present? %>
      <dl class="divide-y divide-border">
        <% @call.response_headers.each do |name, value| %>
          <div class="flex gap-4 py-2 text-xs">
            <dt class="font-mono font-medium shrink-0 w-40 truncate"><%= name %></dt>
            <dd class="font-mono text-muted-foreground break-all"><%= value %></dd>
          </div>
        <% end %>
      </dl>
    <% else %>
      <p class="text-sm text-muted-foreground"><%= t(".not_captured") %></p>
    <% end %>
  <% end %>
</div>

<%# ── Response body ── %>
<div class="mt-6 mb-10">
  <%= render(Campbooks::SectionHeader.new) { t(".response_body") } %>
  <%= render(Campbooks::Card.new(padding: :none, class: "mt-3")) do %>
    <% if @call.response_body.present? %>
      <pre class="font-mono text-xs whitespace-pre-wrap break-all overflow-x-auto max-h-96 overflow-y-auto p-4"><%= pretty_body(@call.response_body) %></pre>
    <% else %>
      <p class="text-sm text-muted-foreground p-5"><%= t(".not_captured") %></p>
    <% end %>
  <% end %>
</div>
