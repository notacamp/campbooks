<%# Rendered into the calendar's event modal via the `calendar_event_modal` Turbo
    Frame. RSVP, the editable form, and delete all live inside the modal. %>
<% writable = @event.calendar.is_writable && @event.calendar_account.writable_by?(Current.user) %>
<%= turbo_frame_tag "calendar_event_modal" do %>
  <%= render "modal_header", title: t(".title") %>
  <div class="px-5 py-4 space-y-4">
    <% if @event.rsvp_status.present? %>
      <div class="rounded-lg border border-border bg-muted/40 p-3">
        <p class="text-sm text-gray-700 mb-2"><%= t(".rsvp_prompt") %></p>
        <div class="flex flex-wrap gap-2">
          <% %w[accepted tentative declined].each do |status| %>
            <% active = (status == @event.rsvp_status) %>
            <%= button_to rsvp_calendar_event_path(@event, rsvp_status: status, view: params[:view]), method: :post,
                  class: "px-3 py-1.5 rounded-lg text-sm font-medium cursor-pointer #{active ? 'bg-primary text-primary-foreground' : 'border border-border text-gray-700 hover:bg-muted'}" do %>
              <%= t("calendar_events.form.rsvp_#{status}") %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if writable %>
      <%= render "form" %>

      <div class="border-t border-border pt-3">
        <%= button_to t("calendar_events.form.delete"), calendar_event_path(@event, view: params[:view]), method: :delete,
              params: { recurrence_scope: "this" },
              data: { turbo_confirm: t("calendar_events.form.delete_confirm") },
              class: "text-sm text-red-600 hover:text-red-700 cursor-pointer" %>
      </div>
    <% else %>
      <%# Read-only view for events on calendars the user can't write to %>
      <div>
        <h3 class="text-base font-semibold text-foreground"><%= @event.title.presence || t("calendar_events.form.title_placeholder") %></h3>
        <p class="text-sm text-gray-500 mt-1"><%= l(@event.start_at, format: :at) %><% if @event.location.present? %> &middot; <%= @event.location %><% end %></p>
        <% if @event.description.present? %><p class="text-sm text-gray-700 mt-3 whitespace-pre-wrap"><%= @event.description %></p><% end %>
      </div>
    <% end %>
  </div>
<% end %>
