<%# Rendered into the calendar's event modal via the `calendar_event_modal` Turbo
    Frame. RSVP, the editable form, and delete all live inside the modal. %>
<% writable = @event.calendar.is_writable && @event.calendar_account.writable_by?(Current.user) %>
<%= turbo_frame_tag "calendar_event_modal" do %>
  <%= render "modal_header", title: writable ? t(".title") : t(".view_title") %>
  <div class="px-5 pt-4 pb-5">
    <% if writable %>
      <%# RSVP segmented control — only when the current user is an attendee %>
      <% if @event.rsvp_status.present? %>
        <div class="flex items-center justify-between gap-3 bg-muted rounded-xl p-3 mb-4 flex-wrap">
          <p class="text-[13.5px] font-medium text-foreground"><%= t(".rsvp_prompt") %></p>
          <div class="inline-flex bg-card border border-border rounded-[10px] p-0.5 gap-0.5">
            <% %w[accepted tentative declined].each do |status| %>
              <% active = (status == @event.rsvp_status) %>
              <%= button_to rsvp_calendar_event_path(@event, rsvp_status: status, view: params[:view]),
                    method: :post,
                    form: { class: "contents" },
                    class: "rounded-lg px-3 py-1.5 text-[13px] font-semibold border-0 cursor-pointer #{active ? 'bg-primary text-primary-foreground' : 'text-muted-foreground hover:text-foreground bg-transparent'}" do %>
                <%= t("calendar_events.form.rsvp_#{status}") %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Standalone delete form — the footer Delete button inside _form targets this via form=.
          No visible markup; the main form's submit button handles save. %>
      <%= form_with url: calendar_event_path(@event, view: params[:view]), method: :delete, id: "delete_calendar_event_form", data: { turbo: true } do %>
        <input type="hidden" name="recurrence_scope" value="this">
      <% end %>

      <%= render "form" %>
    <% else %>
      <%# Read-only view for events the user cannot edit (spec specimen 3) %>

      <div class="grid grid-cols-[30px_1fr] items-start pb-1">
        <div></div>
        <h3 class="text-[17px] font-semibold tracking-tight text-foreground pt-0.5">
          <%= @event.title.presence || t("calendar_events.form.title_placeholder") %>
        </h3>
      </div>

      <div class="grid grid-cols-[30px_1fr] items-start py-1.5">
        <div class="pt-2 text-muted-foreground">
          <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <p class="text-sm text-foreground pt-1.5">
          <%= l(@event.start_at, format: :at) %><% unless @event.all_day? %> &ndash; <%= @event.end_at.strftime("%H:%M") %><% end %>
        </p>
      </div>

      <% if @event.join_url.present? %>
        <div class="grid grid-cols-[30px_1fr] items-start py-1.5">
          <div class="pt-2 text-muted-foreground">
            <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/>
            </svg>
          </div>
          <div class="pt-1">
            <%= link_to @event.join_url,
                  target: "_blank",
                  rel: "noopener noreferrer",
                  class: "inline-flex items-center gap-1.5 border border-border bg-transparent rounded-[9px] px-2.5 py-1.5 text-[13px] font-medium text-foreground hover:bg-muted" do %>
              <%= t(".join_video") %>
              <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @event.location.present? %>
        <div class="grid grid-cols-[30px_1fr] items-start py-1.5">
          <div class="pt-2 text-muted-foreground">
            <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
          </div>
          <p class="text-sm text-foreground pt-1.5"><%= @event.location %></p>
        </div>
      <% end %>

      <% if @event.guests.any? %>
        <div class="grid grid-cols-[30px_1fr] items-start py-1.5">
          <div class="pt-2 text-muted-foreground">
            <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
            </svg>
          </div>
          <%= render Campbooks::Calendar::GuestList.new(guests: @event.guests, editable: false) %>
        </div>
      <% end %>

      <% if @event.description.present? %>
        <div class="grid grid-cols-[30px_1fr] items-start py-1.5">
          <div class="pt-2 text-muted-foreground">
            <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"/>
            </svg>
          </div>
          <p class="text-[13.5px] text-foreground whitespace-pre-wrap pt-1.5"><%= @event.description %></p>
        </div>
      <% end %>

      <% if @event.calendar %>
        <div class="flex items-center gap-2 text-[12.5px] text-muted-foreground pt-3 mt-3 border-t border-border">
          <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= @event.calendar.display_color %>"></span>
          <%= @event.calendar.name %> &middot; <%= @event.calendar.calendar_account.display_name %>
          &middot; <%= t(".view_only") %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
