<% content_for :cp_context, "calendar" %>
<% period_label =
     case @view
     when "month" then l(@date, format: :section)
     when "day"   then l(@date, format: :full)
     when "week"  then "#{l(@range.begin.to_date, format: :day_month)} – #{l(@range.end.to_date, format: :day_month)}"
     else t(".upcoming")
     end %>

<div class="mx-auto max-w-5xl px-4 py-6 sm:px-6 lg:px-8" data-controller="calendar-nav">
  <!-- Header: period + navigation -->
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-4">
    <h1 class="text-xl font-semibold text-foreground"><%= period_label %></h1>

    <div class="flex items-center gap-2">
      <div class="inline-flex items-center rounded-lg border border-border overflow-hidden">
        <%= link_to calendar_path(view: @view, date: @prev_date.iso8601),
              class: "px-2 py-1.5 text-gray-600 hover:bg-muted transition-colors", "aria-label": t(".previous"),
              data: { "calendar-prev": "" } do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        <% end %>
        <%= link_to t(".today"), calendar_path(view: @view, date: Date.current.iso8601),
              class: "px-3 py-1.5 text-sm text-gray-700 border-x border-border hover:bg-muted transition-colors",
              data: { "calendar-today": "" } %>
        <%= link_to calendar_path(view: @view, date: @next_date.iso8601),
              class: "px-2 py-1.5 text-gray-600 hover:bg-muted transition-colors", "aria-label": t(".next"),
              data: { "calendar-next": "" } do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        <% end %>
      </div>
      <% if @has_calendars %>
        <%= render(Campbooks::Button.new(variant: :primary, size: :sm,
              href: new_calendar_event_path(view: @view),
              data: { "calendar-event-modal-open": new_calendar_event_path(view: @view) })) { t(".new_event") } %>
      <% end %>
    </div>
  </div>

  <div class="mb-5"><%= render(Campbooks::Calendar::ViewTabs.new(current: @view, date: @date)) %></div>

  <% if @has_calendars %>
    <% case @view %>
    <% when "month" %>
      <%= render(Campbooks::Calendar::MonthGrid.new(date: @date, events: @events, reminders: @reminders)) %>
    <% when "day" %>
      <%= render(Campbooks::Calendar::DayGrid.new(date: @date, events: @events, reminders: @reminders)) %>
    <% when "week" %>
      <div class="hidden md:block"><%= render(Campbooks::Calendar::WeekTimeGrid.new(date: @date, events: @events, reminders: @reminders)) %></div>
      <div class="md:hidden"><%= render(Campbooks::Calendar::WeekGrid.new(date: @date, events: @events, reminders: @reminders)) %></div>
    <% else %>
      <%= render(Campbooks::Calendar::AgendaList.new(events: @events, reminders: @reminders)) %>
    <% end %>

    <%= render(Campbooks::Calendar::EventModal.new) %>
  <% else %>
    <%= render(Campbooks::EmptyState.new(variant: :standalone, title: t(".empty_title"), description: t(".empty_desc"))) do |es| %>
      <% es.with_actions do %>
        <%= link_to t(".connect_cta"), settings_integrations_calendars_path,
              class: "inline-flex items-center rounded-lg bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 no-underline" %>
      <% end %>
    <% end %>
  <% end %>
</div>
