<%# Loaded into the inbox overlay's turbo-frame (layout:false) and also visitable
    directly at /skim (full layout, @standalone). Either way the viewer fills its
    container: the frame in the overlay, the viewport when standalone. %>
<%= turbo_frame_tag "skim_content", class: "block #{@standalone ? 'fixed inset-0 z-50' : 'h-full'} w-full" do %>
  <% if @rings.any? %>
    <%# Live-swap channel: Emails::SkimSummaryJob replaces a cluster card's summary
        <p> by id the moment its AI summary is ready. Shares the inbox's per-user
        Skim stream (distinct target ids), and disconnects when this frame closes. %>
    <%= turbo_stream_from "skim_#{current_user.id}" %>
    <%= render Campbooks::SkimStack.new(rings: @rings, standalone: @standalone, start_theme: @start_theme, show_intro: !current_user&.tour_dismissed?("skim_intro"), class: @standalone ? "min-h-dvh" : "h-full") %>
  <% else %>
    <div class="flex <%= @standalone ? "min-h-dvh" : "h-full" %> w-full flex-col items-center justify-center bg-background px-6 text-center">
      <div class="text-3xl">✨</div>
      <p class="mt-3 text-lg font-semibold text-foreground"><%= t(".inbox_calm") %></p>
      <p class="mt-1 text-sm text-muted-foreground"><%= t(".nothing_to_skim") %></p>
      <% if @standalone %>
        <a href="/" data-controller="history-back" data-action="click->history-back#back" class="mt-5 text-xs font-medium text-muted-foreground underline-offset-2 hover:underline"><%= t(".back_to_inbox") %></a>
      <% else %>
        <button type="button" data-action="click->skim-overlay#close" class="mt-5 text-xs font-medium text-muted-foreground underline-offset-2 hover:underline"><%= t(".close") %></button>
      <% end %>
    </div>
  <% end %>
<% end %>
