<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= render(Campbooks::Logo.new(size: :lg)) %>
      <p class="text-sm text-gray-600 mt-4"><%= t(".tagline") %></p>
    </div>

    <%= render(Campbooks::Card.new) do %>
      <p class="text-sm text-gray-600 mb-6">
        <strong class="text-gray-900"><%= @state["email"] %></strong> <%= t(".verified_prose") %>
      </p>

      <%= form_with url: complete_registration_path, method: :patch, class: "space-y-5" do |form| %>
        <%= render(Campbooks::Input.new(:password, type: :password, label: t(".password_label"), placeholder: t(".password_placeholder"), required: true, autofocus: true, autocomplete: "new-password")) %>

        <div class="pt-1">
          <%= render(Campbooks::Button.new(variant: :primary, type: "submit", class: "w-full justify-center")) { t(".submit") } %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
