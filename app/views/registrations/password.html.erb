<% content_for :main_class, "mx-auto flex w-full max-w-[26.5rem] flex-col justify-center px-5 py-10 min-h-svh" %>

<%= render "shared/auth_header",
      title: t(".title"),
      subtitle: t(".verified_prose_html", email: content_tag(:strong, @state["email"], class: "font-semibold text-foreground")) %>

<%= form_with url: complete_registration_path, method: :patch, class: "mt-9 space-y-5 animate-stage-in", html: { style: "--stage-delay: .16s" } do |form| %>
  <%= render(Campbooks::Input.new(:password, type: :password, label: t(".password_label"), placeholder: t(".password_placeholder"), required: true, autofocus: true, autocomplete: "new-password", hint: t(".password_hint"))) %>

  <div class="pt-1">
    <%= render(Campbooks::Button.new(variant: :primary, type: "submit", size: :lg, class: "w-full justify-center")) { t(".submit") } %>
  </div>
<% end %>
