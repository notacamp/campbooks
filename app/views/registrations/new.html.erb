<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= render(Campbooks::Logo.new(size: :lg)) %>
      <% unless self_hosted? %>
        <div class="mt-3 flex justify-center">
          <%= render(Campbooks::Badge.new(variant: :accent, size: :md, class: "uppercase tracking-wide")) { t(".beta_badge") } %>
        </div>
      <% end %>
      <p class="text-sm text-gray-600 mt-4"><%= t(".tagline") %></p>
    </div>

    <%= render(Campbooks::Card.new) do %>
      <%= form_with url: registration_path, class: "space-y-5" do |form| %>
        <%= render(Campbooks::Input.new(:name, type: :text, label: t(".name_label"), placeholder: t(".name_placeholder"), required: true, value: params[:name], autofocus: true, autocomplete: "name")) %>

        <%= render(Campbooks::Input.new(:email_address, type: :email, label: t(".email_label"), placeholder: t(".email_placeholder"), required: true, value: params[:email_address], autocomplete: "email")) %>

        <% if beta_code_required? %>
          <%= render(Campbooks::Input.new(:beta_code, type: :text, label: t(".beta_code_label"), placeholder: t(".beta_code_placeholder"), required: true, value: params[:beta_code], hint: t(".beta_code_hint"), autocomplete: "off")) %>
        <% end %>

        <label class="flex items-start gap-2 text-xs text-gray-600">
          <input type="checkbox" name="terms_accepted" value="1" required
                 class="mt-0.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500">
          <span><%= t(".terms_consent_html",
                      terms: link_to(t(".terms"), marketing_url("/terms"), target: "_blank", rel: "noopener", class: "text-accent-600 hover:text-accent-700 underline"),
                      privacy: link_to(t(".privacy"), marketing_url("/privacy"), target: "_blank", rel: "noopener", class: "text-accent-600 hover:text-accent-700 underline")) %></span>
        </label>

        <div class="pt-1">
          <%= render(Campbooks::Button.new(variant: :primary, type: "submit", class: "w-full justify-center")) { t(".submit") } %>
        </div>

        <p class="text-center text-sm">
          <%= t(".have_account") %>
          <%= link_to t(".sign_in"), new_session_path, class: "text-accent-600 hover:text-accent-700 font-medium" %>
        </p>
      <% end %>
    <% end %>
  </div>
</div>
