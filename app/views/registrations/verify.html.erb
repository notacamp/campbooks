<% content_for :main_class, "mx-auto flex w-full max-w-[26.5rem] flex-col justify-center px-5 py-10 min-h-svh" %>

<%= render "shared/auth_header",
      title: t(".title"),
      subtitle: t(".code_sent_html", email: content_tag(:strong, @state["email"], class: "font-semibold text-foreground")) %>

<%# One code, six boxes: the otp-input controller keeps the hidden `code` field
    (what the server reads) in sync, and submits itself on the sixth digit. %>
<%= form_with url: check_code_registration_path, method: :post,
      class: "mt-9 animate-stage-in", html: { style: "--stage-delay: .16s", data: { controller: "otp-input" } } do |form| %>
  <%= form.hidden_field :code, data: { otp_input_target: "code" } %>
  <div class="flex justify-center gap-2" data-action="paste->otp-input#paste">
    <% 6.times do |i| %>
      <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" required aria-label="<%= t(".digit_label", position: i + 1) %>"
             autocomplete="<%= i.zero? ? "one-time-code" : "off" %>" name="otp_box_<%= i %>"
             data-otp-input-target="box" data-action="input->otp-input#input keydown->otp-input#keydown"
             class="h-13 w-11 rounded-xl border border-border bg-card text-center text-xl font-semibold tabular-nums text-foreground transition-colors focus:border-accent-500 focus:ring-accent-500">
    <% end %>
  </div>

  <div class="mt-6">
    <%= render(Campbooks::Button.new(variant: :primary, type: "submit", size: :lg, class: "w-full justify-center")) { t(".submit") } %>
  </div>
<% end %>

<%# Resend is its OWN action: button_to renders a <form>, so it must live
    OUTSIDE the verify form above. Nesting <form>s is invalid HTML — the
    browser drops the inner one, which silently broke "Resend". %>
<div class="mt-6 flex flex-col items-center gap-2 animate-stage-in" style="--stage-delay: .2s">
  <%= button_to t(".resend"), resend_code_registration_path, method: :post,
      class: "cursor-pointer border-0 bg-transparent p-0 text-sm font-medium text-foreground hover:text-accent-700" %>
  <%= link_to t(".start_over"), new_registration_path, class: "text-xs font-medium text-muted-foreground hover:text-foreground" %>
</div>
