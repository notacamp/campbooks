<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= render(Campbooks::Logo.new(size: :lg)) %>
      <p class="text-sm text-gray-600 mt-4"><%= t(".tagline") %></p>
    </div>

    <%= render(Campbooks::Card.new) do %>
      <p class="text-sm text-gray-600 mb-6">
        <%= t(".code_sent_html", email: content_tag(:strong, @state["email"], class: "text-gray-900")) %>
      </p>

      <%= form_with url: check_code_registration_path, method: :post, class: "space-y-5" do |form| %>
        <div>
          <%= form.label :code, t(".code_label"), class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.text_field :code, required: true, autofocus: true, autocomplete: "one-time-code",
              placeholder: "000000", maxlength: 6, inputmode: "numeric", pattern: "[0-9]*",
              class: "block w-full rounded-lg border-gray-300 shadow-sm text-lg text-center tracking-[0.25em] font-mono focus:border-accent-500 focus:ring-accent-500" %>
        </div>

        <div class="pt-1">
          <%= render(Campbooks::Button.new(variant: :primary, type: "submit", class: "w-full justify-center")) { t(".submit") } %>
        </div>
      <% end %>

      <%# Resend is its OWN action: button_to renders a <form>, so it must live
          OUTSIDE the verify form above. Nesting <form>s is invalid HTML — the
          browser drops the inner one, which silently broke "Resend" (and left it
          unclickable after a failed verify re-render). %>
      <div class="text-center space-y-2 mt-5">
        <%= button_to t(".resend"), resend_code_registration_path, method: :post,
            class: "text-accent-600 hover:text-accent-700 font-medium text-sm bg-transparent border-0 cursor-pointer p-0" %>
        <%= link_to t(".start_over"), new_registration_path, class: "text-gray-400 hover:text-gray-600 text-xs font-medium" %>
      </div>
    <% end %>
  </div>
</div>
