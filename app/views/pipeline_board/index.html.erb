<%= turbo_frame_tag "pipeline_board" do %>
  <div class="flex flex-col h-full"
       data-controller="pipeline-board"
       data-pipeline-board-move-url-value="<%= move_pipeline_path(@pipeline) %>">
    <div class="flex items-center justify-between gap-3 px-4 py-3 border-b border-border flex-shrink-0">
      <div class="flex items-center gap-3 min-w-0">
        <%= link_to settings_pipelines_path, class: "text-muted-foreground hover:text-foreground flex-shrink-0" do %>
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
          </svg>
        <% end %>
        <div class="min-w-0">
          <h2 class="text-sm font-semibold text-foreground truncate"><%= @pipeline.name %></h2>
        </div>
      </div>
      <span class="text-[11px] text-muted-foreground flex-shrink-0"><%= t(".drag_hint") %></span>
    </div>

    <div class="flex-1 overflow-x-auto overflow-y-hidden p-4">
      <div class="flex gap-4 h-full min-h-[20rem]">
        <% @columns.each do |column| %>
          <div class="flex w-72 sm:w-80 flex-shrink-0 flex-col rounded-xl border border-border bg-muted/40 max-h-full"
               data-pipeline-board-target="column">
            <div class="flex items-center gap-2 border-b border-border px-3 py-2.5 flex-shrink-0">
              <span class="inline-flex h-5 min-w-[1.25rem] items-center justify-center rounded-full px-1.5 text-[11px] font-semibold tabular-nums"
                    style="background-color: <%= column[:stage].color %>20; color: <%= column[:stage].color %>">
                <%= column[:has_more] ? "#{column[:memberships].size}+" : column[:memberships].size %>
              </span>
              <span class="text-[13px] font-semibold text-foreground"><%= column[:stage].name %></span>
              <% if column[:stage].is_terminal? %>
                <svg class="h-3.5 w-3.5 ml-auto text-muted-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" title="<%= t(".terminal_hint") %>">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              <% end %>
            </div>
            <div class="flex-1 space-y-2 overflow-y-auto p-2 min-h-[4rem]"
                 data-pipeline-board-target="dropzone"
                 data-stage-id="<%= column[:stage].id %>"
                 data-droppable="<%= column[:draggable].to_s %>">
              <% if column[:memberships].empty? %>
                <p class="px-2 py-6 text-center text-[11px] text-muted-foreground"><%= t(".empty_stage") %></p>
              <% else %>
                <% column[:memberships].each do |membership| %>
                  <% item = membership.item %>
                  <% next unless item %>
                  <%= link_to item.is_a?(Document) ? document_path(item) : email_message_path(item),
                        class: class_names("group block rounded-lg border border-border bg-card p-2.5 shadow-sm transition hover:border-accent-300 hover:shadow-md", column[:draggable] ? "cursor-grab active:cursor-grabbing" : "cursor-pointer"),
                        draggable: column[:draggable].to_s,
                        data: { pipeline_board_target: "card", membership_id: membership.id, stage_id: column[:stage].id } do %>
                    <div class="flex items-start justify-between gap-1.5">
                      <span class="truncate text-[12px] font-semibold leading-snug text-foreground">
                        <%= item.is_a?(Document) ? item.display_title : (item.subject.presence || t(".no_subject")) %>
                      </span>
                      <span class="flex-shrink-0 text-[10px] text-muted-foreground">
                        <%= time_ago_in_words(item.is_a?(Document) ? item.created_at : item.received_at) %>
                      </span>
                    </div>
                    <span class="mt-0.5 block truncate text-[11px] text-muted-foreground">
                      <%= item.is_a?(Document) ? item.classification&.name : item.from_address.to_s.split("@").first %>
                    </span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
