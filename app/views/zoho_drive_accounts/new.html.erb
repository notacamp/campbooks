<% content_for :main_class, "px-4 sm:px-6 lg:px-8 py-6" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-xl font-bold text-gray-900 mb-6"><%= t(".title") %></h1>

  <div class="bg-card shadow rounded-lg p-6">
    <p class="text-sm text-gray-600 mb-4">
      <%= t(".description") %>
    </p>

    <%= button_to t(".connect_button"), zoho_drive_accounts_path,
        method: :post,
        data: { turbo: false },
        class: "w-full py-2 px-4 bg-accent-600 text-white text-sm font-medium rounded-md hover:bg-accent-700 cursor-pointer" %>

    <p class="text-xs text-gray-400 mt-4">
      <%= t(".permissions_note") %>
    </p>
  </div>
</div>
