<div data-controller="upload new-folder folder-edit doc-skim-overlay files-layout">
  <%= render Campbooks::PageHeader.new(title: @folder ? @folder.name : t(".title"), subtitle: @folder ? nil : t(".subtitle")) do |header| %>
    <% header.with_actions do %>
      <%= render "shared/customize_ai_button", purpose: "document_analysis" %>
      <% if @needs_review_count.to_i > 0 %>
        <button type="button" data-action="click->doc-skim-overlay#open"
            class="inline-flex items-center gap-1.5 rounded-md border border-accent-200 bg-accent-50 px-3 py-2 text-sm font-medium text-accent-700 hover:bg-accent-100 cursor-pointer dark:border-accent-500/30 dark:bg-accent-500/10 dark:text-accent-300">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <%= t(".review_n", count: @needs_review_count) %>
        </button>
      <% end %>
      <%= render Campbooks::Button.new(variant: :outline, size: :sm, href: new_written_document_path) { t(".new_internal_document") } %>
      <%= render Campbooks::Button.new(variant: :outline, size: :sm, data: { action: "new-folder#open" }) { t(".new_folder") } %>
      <% if @folder&.manageable_by?(Current.user) %>
        <%= render Campbooks::Button.new(variant: :outline, size: :sm,
              data: { action: "folder-edit#open", folder_edit_dialog_param: "folder-share-dialog" }) do %>
          <%= @folder.restricted? ? t(".manage_access_locked") : t(".manage_access") %>
        <% end %>
      <% end %>
      <button type="button" data-action="click->upload#toggle"
          class="inline-flex items-center px-4 py-2 bg-accent-600 text-white text-sm font-medium rounded-md hover:bg-accent-700 cursor-pointer">
        <%= t(".upload") %>
      </button>
    <% end %>
  <% end %>

  <% if @folder %>
    <nav class="mb-4 flex items-center gap-1.5 text-sm text-muted-foreground" aria-label="<%= t(".breadcrumb") %>">
      <%= link_to t(".all_files"), files_path, class: "hover:text-foreground" %>
      <span aria-hidden="true">/</span>
      <span class="font-medium text-foreground"><%= @folder.name %></span>
    </nav>
  <% end %>

  <!-- Upload panel (collapsed by default; the Upload button toggles it) -->
  <div data-upload-target="container" class="bg-card rounded-xl shadow-sm border border-gray-200 p-6 mb-6 hidden dark:border-white/10">
    <%= form_tag files_uploads_path, multipart: true, class: "space-y-6" do %>
      <% if @folder %><%= hidden_field_tag :folder_id, @folder.id %><% end %>
      <div class="border-2 border-dashed border-gray-300 rounded-lg p-12 text-center hover:border-accent-200 transition-colors dark:border-white/15"
           data-upload-target="dropzone"
           data-action="dragover->upload#dragover dragenter->upload#dragover dragleave->upload#dragleave drop->upload#drop">
        <div class="space-y-2">
          <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div class="text-sm text-gray-600 dark:text-gray-300">
            <label class="cursor-pointer text-accent-600 hover:text-accent-500 font-medium">
              <%= t(".click_to_upload") %>
              <%= file_field_tag :files, multiple: true, class: "sr-only",
                  data: { upload_target: "input", action: "change->upload#handleFiles" } %>
            </label>
            <%= t(".drag_and_drop") %>
          </div>
          <p class="text-xs text-gray-500"><%= t(".upload_hint") %></p>
        </div>
      </div>

      <div data-upload-target="fileList" class="hidden">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-200 mb-2"><%= t(".selected_files") %></h3>
        <ul data-upload-target="fileListItems" class="space-y-2"></ul>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <label class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-200">
          <%= check_box_tag :analyze, "1", true, class: "mt-0.5 rounded border-gray-300 text-accent-600 focus:ring-accent-500" %>
          <span>
            <%= t(".ai_analyze") %>
            <span class="block text-xs text-gray-500"><%= t(".ai_analyze_hint") %></span>
          </span>
        </label>
        <%= render Campbooks::Button.new(variant: :primary, size: :lg, type: :submit, data: { upload_target: "submit" }) { t(".upload_submit") } %>
      </div>
    <% end %>
  </div>

  <%# Document Skim — the review-queue ring tray + full-screen review overlay %>
  <%= turbo_stream_from "doc_skim_#{Current.workspace.id}" %>
  <%= turbo_frame_tag "doc_skim_tray", src: document_skim_tray_path, loading: :lazy, class: "block" %>
  <%= render "shared/doc_skim_overlay" %>

  <% if @has_any_files %>
    <div class="flex gap-6">
      <aside class="hidden lg:block">
        <%= render Campbooks::Files::Sidebar.new(folders: @folders, current_folder: @folder, counts: @folder_counts) %>
      </aside>

      <div class="min-w-0 flex-1">
        <%# Search bar — embeds the filter panel; live-submits into `files_results`.
            The box always shows the RAW query — modifiers included — never the
            stripped text (that would erase the user's modifiers on reload). %>
        <%= render Campbooks::Files::SearchBar.new(
              q: params[:q],
              folder: @folder,
              filters: @filters,
              document_types: @document_types,
              folders: @folders,
              categories: @categories) %>

        <%# Toolbar — slim row below the bar, outside the results frame so it
            doesn't re-render on filter change. Bulk actions (all-files view
            only) + the grid-mode sort menu + the List/Grid switcher. %>
        <div class="flex flex-wrap items-center justify-end gap-2 mt-2 mb-2">
          <% if @folder.nil? %>
            <% if @reprocessable_count.to_i > 0 %>
              <%= form_tag reprocess_all_documents_path, method: :post, class: "inline" do %>
                <%= render "files/filter_hidden_fields", filters: @filters, q: params[:q] %>
                <%= render Campbooks::Button.new(variant: :outline, size: :sm, type: :submit) { t(".reanalyze_all", count: @reprocessable_count) } %>
              <% end %>
            <% end %>
            <%= form_tag export_documents_path, method: :post, class: "inline" do %>
              <%= render "files/filter_hidden_fields", filters: @filters, q: params[:q] %>
              <%= render Campbooks::Button.new(variant: :outline, size: :sm, type: :submit, data: { turbo_confirm: t(".export_confirm") }) { t(".export") } %>
            <% end %>
          <% end %>
          <%= render Campbooks::Files::SortMenu.new(sorter: @sorter, filters: @filters, q: params[:q], folder: @folder, field_columns: @field_columns) %>
          <%= render Campbooks::Files::ViewSwitcher.new %>
        </div>

        <%# Results frame: chips + count + sections + table + pagination.
            The mobile folder strip and exports history stay outside this frame. %>
        <%= turbo_frame_tag "files_results" do %>
          <%# Active-filter chips (panel filters only, not modifier text). Remove
              links carry the RAW query so modifiers survive chip removal. %>
          <%= render Campbooks::Files::FilterChips.new(
                filters: @filters,
                q: params[:q],
                folder: @folder,
                document_types: @document_types,
                folders: @folders,
                single_type: @single_type) %>

          <% if @search_query.present? %>
            <p class="px-2.5 py-1.5 text-sm text-muted-foreground" role="status">
              <%= t(".search_results", count: @files.size, q: @search_query) %>
            </p>
          <% end %>

          <!-- Internal (authored) documents -->
          <% if @internal_docs.any? %>
            <section class="mb-6">
              <h2 class="mb-2 text-xs font-semibold uppercase tracking-wide text-muted-foreground"><%= t(".internal_documents") %></h2>
              <div class="space-y-2">
                <% @internal_docs.each do |doc| %>
                  <%= render Campbooks::Files::DocRow.new(doc: doc, folders: @folders, current_folder: @folder) %>
                <% end %>
              </div>
            </section>
          <% end %>

          <!-- Filed emails (shown inside a folder) -->
          <% if @filed_emails.any? %>
            <section class="mb-6">
              <h2 class="mb-2 text-xs font-semibold uppercase tracking-wide text-muted-foreground"><%= t(".emails") %></h2>
              <div class="space-y-2">
                <% @filed_emails.each do |email| %>
                  <%= render Campbooks::Files::EmailRow.new(email: email, current_folder: @folder) %>
                <% end %>
              </div>
            </section>
          <% end %>

          <% if @files.any? %>
            <% if @internal_docs.any? || @filed_emails.any? %>
              <h2 class="mb-2 text-xs font-semibold uppercase tracking-wide text-muted-foreground"><%= t(".files_section") %></h2>
            <% end %>
            <!-- Files table (md+, list mode) -->
            <div data-files-pane="table" class="hidden md:block bg-card rounded-xl shadow-sm border border-gray-200 overflow-x-auto dark:border-white/10">
              <%# Width budget (table-fixed): name + N×2/12 fields + 2/12 added + w-12 actions ≤ 12/12. %>
              <% name_width = @field_columns.any? ? (%w[w-5/12 w-5/12 w-4/12 w-3/12][@field_columns.size] || "w-3/12") : "w-5/12" %>
              <table class="min-w-full table-fixed divide-y divide-gray-200 dark:divide-white/10">
                <thead class="bg-warm-ash-bg">
                  <tr>
                    <%= render Campbooks::Files::SortableHeader.new(
                          label: t(".col_name"),
                          sort_key: "name",
                          sorter: @sorter,
                          filters: @filters,
                          q: params[:q],
                          folder: @folder,
                          width_class: name_width) %>
                    <% if @field_columns.any? %>
                      <% @field_columns.each do |field| %>
                        <%= render Campbooks::Files::SortableHeader.new(
                              label: field.label,
                              sort_key: field.key,
                              sorter: @sorter,
                              filters: @filters,
                              q: params[:q],
                              folder: @folder,
                              width_class: "w-2/12") %>
                      <% end %>
                    <% else %>
                      <th class="w-2/12 px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_kind") %></th>
                      <th class="w-2/12 px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".col_size") %></th>
                    <% end %>
                    <%= render Campbooks::Files::SortableHeader.new(
                          label: t(".col_added"),
                          sort_key: "added",
                          sorter: @sorter,
                          filters: @filters,
                          q: params[:q],
                          folder: @folder,
                          width_class: "w-2/12") %>
                    <th class="w-12 px-3 py-3"><span class="sr-only"><%= t(".col_actions") %></span></th>
                  </tr>
                </thead>
                <tbody id="files_tbody" class="bg-card divide-y divide-gray-200 dark:divide-white/10">
                  <% @files.each do |file| %>
                    <%= render Campbooks::Files::FileRow.new(doc: file, folders: @folders, current_folder: @folder, field_columns: @field_columns) %>
                  <% end %>
                </tbody>
              </table>
            </div>

            <!-- Files cards (mobile, list mode) -->
            <div id="files_cards" data-files-pane="cards" class="md:hidden space-y-3">
              <% @files.each do |file| %>
                <%= render Campbooks::Files::FileCard.new(doc: file, folders: @folders, current_folder: @folder, field_columns: @field_columns) %>
              <% end %>
            </div>

            <!-- Files tiles (grid mode; hidden in list mode via application.css) -->
            <div id="files_grid" data-files-pane="grid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 xl:grid-cols-5">
              <% @files.each do |file| %>
                <%= render Campbooks::Files::FileTile.new(doc: file, folders: @folders, current_folder: @folder, field_columns: @field_columns) %>
              <% end %>
            </div>
          <% elsif params[:q].present? || @filters.narrowing? %>
            <div class="bg-card rounded-xl shadow-sm border border-gray-200 px-6 py-10 text-center text-sm text-gray-500 dark:border-white/10">
              <%= t(".search_empty") %>
            </div>
          <% elsif @internal_docs.empty? && @filed_emails.empty? %>
            <div class="bg-card rounded-xl shadow-sm border border-gray-200 px-6 py-8 text-center text-sm text-gray-500 dark:border-white/10">
              <%= t(".empty_folder") %>
            </div>
          <% end %>

          <% if @pagy&.next %>
            <%= turbo_frame_tag "files_pagination",
                  src: (@folder ? files_folder_path(@folder, files_filter_params(@filters, q: params[:q], sorter: @sorter).merge(page: @pagy.next, format: :turbo_stream)) : files_path(files_filter_params(@filters, q: params[:q], sorter: @sorter).merge(page: @pagy.next, format: :turbo_stream))),
                  loading: :lazy do %>
              <div class="flex items-center justify-center py-6">
                <%= render Campbooks::Spinner.new(size: :md) %>
              </div>
            <% end %>
          <% end %>
          <noscript>
            <% if @pagy&.pages.to_i > 1 %>
              <div class="mt-4"><%== pagy_nav(@pagy) %></div>
            <% end %>
          </noscript>
        <% end %>

        <!-- Mobile folder strip (outside the results frame) -->
        <% if @folders.any? %>
          <div class="lg:hidden -mx-4 mb-4 flex gap-2 overflow-x-auto px-4 pb-1 sm:mx-0 sm:px-0">
            <%= link_to t(".all_files"), files_path,
                  class: class_names("whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium",
                    @folder.nil? ? "bg-accent-600 text-white" : "bg-muted text-muted-foreground") %>
            <% @folders.each do |folder| %>
              <%= link_to folder.name, files_folder_path(folder),
                    class: class_names("whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium",
                      @folder&.id == folder.id ? "bg-accent-600 text-white" : "bg-muted text-muted-foreground") %>
            <% end %>
          </div>
        <% end %>

        <%# Recent exports (all-files view only) — outside the frame. %>
        <% if @folder.nil? && @exports.present? %>
          <details class="group/exports mt-8 bg-card rounded-xl shadow-sm border border-gray-200 dark:border-white/10">
            <summary class="flex items-center justify-between gap-2 p-4 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <span class="text-sm font-medium text-gray-700 dark:text-gray-200"><%= t(".exports_heading") %></span>
              <svg class="w-4 h-4 text-gray-400 group-open/exports:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="overflow-x-auto border-t border-gray-200 dark:border-white/10">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-white/10">
                <thead class="bg-warm-ash-bg">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_date") %></th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_status") %></th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_documents") %></th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t(".exports_col_download") %></th>
                  </tr>
                </thead>
                <tbody class="bg-card divide-y divide-gray-200 dark:divide-white/10">
                  <% @exports.each do |export| %>
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100"><%= l(export.created_at, format: :at) %></td>
                      <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(export.status) %></td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right"><%= export.documents_count %></td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm">
                        <% if export.zip_file.attached? %>
                          <%= link_to t(".download_zip"), url_for(export.zip_file), class: "text-accent-600 hover:text-accent-700 font-medium" %>
                        <% elsif export.failed? %>
                          <span class="text-red-500 dark:text-red-400"><%= t(".export_failed") %></span>
                        <% else %>
                          <span class="text-gray-400"><%= human_enum(Export, :status, export.status) %></span>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </details>
        <% end %>
      </div>
    </div>
  <% else %>
    <%# files_results frame must always be present in the DOM so Turbo can target it. %>
    <%= turbo_frame_tag "files_results" do %>
      <%= render(Campbooks::EmptyState.new(variant: :standalone, title: t(".empty_title"), description: t(".empty_description"))) do |state| %>
        <% state.with_icon do %>
          <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7a2 2 0 012-2h4l2 2.5h8a2 2 0 012 2V18a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          </svg>
        <% end %>
        <% state.with_actions do %>
          <%= render(Campbooks::Button.new(variant: :primary, data: { action: "click->upload#toggle" })) { t(".empty_upload") } %>
          <%= render(Campbooks::Button.new(variant: :outline, data: { action: "new-folder#open" })) { t(".new_folder") } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Campbooks::NewFolderModal.new(turbo: false, subtitle: t(".new_folder_hint"), hidden_fields: { provision: false, return_to: "files" }) %>

  <% if @folder&.manageable_by?(Current.user) %>
    <dialog id="folder-share-dialog"
        class="m-auto w-[calc(100vw-2rem)] max-w-md overflow-hidden rounded-2xl border border-border bg-card p-0 text-card-foreground shadow-2xl backdrop:bg-black/40"
        data-action="click->folder-edit#backdropClose">
      <div class="flex items-start justify-between gap-3 border-b border-border px-5 py-4">
        <div>
          <h2 class="text-base font-semibold text-foreground"><%= t(".manage_access") %></h2>
          <p class="mt-0.5 text-xs text-muted-foreground"><%= @folder.name %></p>
        </div>
        <button type="button" data-action="folder-edit#close" aria-label="<%= t('shared.actions.close') %>"
            class="-mr-1 cursor-pointer rounded border-0 bg-transparent p-1 text-gray-400 hover:bg-gray-200/70 hover:text-gray-600 dark:hover:bg-white/10">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="px-5 py-5">
        <%= turbo_frame_tag dom_id(@folder, :share), src: files_folder_share_path(@folder), loading: :lazy do %>
          <div class="py-6 text-center"><%= render Campbooks::Spinner.new(size: :md) %></div>
        <% end %>
      </div>
    </dialog>
  <% end %>
</div>
