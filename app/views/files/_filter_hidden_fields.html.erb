<%# Renders hidden fields for all active panel filters + optional q.
    Locals: filters (Documents::Filters), q (String or nil).
    Used by the bulk-action forms (Reanalyze / Export) to carry the current
    filter state through. Array-valued params (type[], or a category/source/…
    that accumulated several values) must submit with [] — repeated bare names
    would collapse to the last value in Rack's params parsing. %>
<% (local_assigns[:filters] || Documents::Filters.new).to_h.each do |key, value| %>
  <% if value.is_a?(Array) %>
    <% value.each do |v| %>
      <%= hidden_field_tag "#{key}[]", v %>
    <% end %>
  <% else %>
    <%= hidden_field_tag key.to_s, value %>
  <% end %>
<% end %>
<% if local_assigns[:q].present? %>
  <%= hidden_field_tag :q, local_assigns[:q] %>
<% end %>
