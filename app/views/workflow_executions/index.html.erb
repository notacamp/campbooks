<%= render(Campbooks::PageHeader.new(
  title: t(".title", name: @workflow.name),
  subtitle: t(".subtitle"),
  spacing: :md
)) do |header| %>
  <% header.with_actions do %>
    <%= link_to t(".back_to_workflow"), edit_workflow_path(@workflow), class: "text-sm text-muted-foreground hover:text-foreground" %>
  <% end %>
<% end %>

<% if @executions.any? %>
  <div class="space-y-2">
    <% @executions.each do |execution| %>
      <%= link_to workflow_execution_path(@workflow, execution),
            class: "block bg-card rounded-xl shadow-sm border border-border p-4 hover:border-foreground/30 transition-colors" do %>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-3 min-w-0">
            <%= render(Campbooks::Badge.new(variant: execution_badge_variant(execution), size: :md)) { human_enum(WorkflowExecution, :status, execution.status) } %>
            <span class="text-sm text-foreground truncate">
              <%= execution.trigger_data["subject"].presence || execution.trigger_data["type"]&.humanize || t(".triggered") %>
            </span>
          </div>
          <div class="flex items-center gap-4 text-xs text-muted-foreground flex-shrink-0">
            <span><%= t(".steps", count: execution.execution_steps.size) %></span>
            <span><%= l(execution.created_at, format: :at) %></span>
          </div>
        </div>
        <% if execution.error_message.present? %>
          <p class="mt-2 text-xs text-destructive truncate"><%= execution.error_message %></p>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render(Campbooks::EmptyState.new(
    variant: :card,
    title: t(".empty_title"),
    description: t(".empty_description")
  )) %>
<% end %>
