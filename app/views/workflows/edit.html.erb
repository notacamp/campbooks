<%= render(Campbooks::PageHeader.new(
  title: @workflow.name.presence || t(".new_workflow"),
  subtitle: t(".subtitle"),
  spacing: :md
)) do |header| %>
  <% header.with_actions do %>
    <%= link_to t(".back_to_workflows"), workflows_path, class: "text-sm text-muted-foreground hover:text-foreground" %>
  <% end %>
<% end %>

<div class="flex flex-col gap-8 lg:flex-row" data-controller="step-picker">
  <div class="flex-1 max-w-2xl min-w-0">
    <%= form_with model: @workflow, local: true, class: "space-y-6" do |f| %>
      <%= render(Campbooks::Card.new(padding: :md)) do %>
        <div class="space-y-4">
          <div>
            <label for="workflow_name" class="block text-sm font-medium text-foreground mb-1"><%= t(".name_label") %></label>
            <%= f.text_field :name, class: "block w-full rounded-lg shadow-sm text-sm", placeholder: t(".name_placeholder") %>
          </div>
          <div>
            <label for="workflow_description" class="block text-sm font-medium text-foreground mb-1"><%= t(".description_label") %></label>
            <%= f.text_area :description, rows: 2, class: "block w-full rounded-lg shadow-sm text-sm", placeholder: t(".description_placeholder") %>
          </div>
        </div>
      <% end %>

      <div class="mt-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide"><%= t(".when_label") %></span>
        </div>

        <%= render(Campbooks::WorkflowStepCard.new(
          step_type: :trigger,
          label: @workflow.webhook? ? t(".trigger_webhook") : (@workflow.event_trigger? ? t(".trigger_event") : t(".trigger_email_received")),
          summary: trigger_summary(@workflow),
          expanded: @workflow.webhook? || @workflow.event_trigger? || params[:expand_trigger].present? || @workflow.trigger_config.blank?
        )) do %>
          <%= render(Campbooks::WorkflowStepForm.new(
            step_type: :trigger,
            config: @workflow.trigger_config || {},
            trigger_type: @workflow.trigger_type,
            type_field_name: "workflow[trigger_type]",
            field_prefix: "workflow[trigger_config]",
            webhook_url: @webhook_url
          )) %>
        <% end %>
      </div>

      <% if @steps.any? %>
        <div class="mt-2">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide"><%= t(".then_label") %></span>
          </div>

          <% @steps.each_with_index do |step, idx| %>
            <% if idx > 0 %>
              <%= render(Campbooks::WorkflowStepConnector.new) %>
            <% end %>

            <% base = "workflow[steps_attributes][#{idx}]" %>
            <%= hidden_field_tag "#{base}[id]", step.id %>
            <%= hidden_field_tag "#{base}[position]", step.position %>
            <%= hidden_field_tag "#{base}[step_type]", step.step_type %>

            <%= render(Campbooks::WorkflowStepCard.new(
              step_type: step.step_type.to_sym,
              label: step_label(step),
              summary: step_summary(step),
              expanded: step.config.blank? || step.config == {},
              delete_url: step_workflow_path(@workflow, step)
            )) do %>
              <%= render(Campbooks::WorkflowStepForm.new(
                step_type: step.step_type.to_sym,
                config: step.config || {},
                type_value: step.action_type,
                type_field_name: step.step_type == "action" ? "#{base}[action_type]" : nil,
                field_prefix: "#{base}[config]",
                trigger_type: @workflow.trigger_type,
                email_accounts: @email_accounts,
                connections: @connections,
                document_types: @document_types,
                notion_integrations: @notion_integrations,
                liquid_variables: @liquid_variables
              )) %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="mt-6 pt-6 border-t border-border">
        <div class="flex flex-wrap items-center gap-3">
          <%= f.submit t("shared.actions.save_changes"), class: "px-4 py-2 bg-primary text-primary-foreground text-sm font-medium rounded-lg hover:bg-primary/90 transition-colors cursor-pointer" %>
          <%= link_to t("shared.actions.cancel"), workflows_path, class: "text-sm text-muted-foreground hover:text-foreground" %>
        </div>
      </div>
    <% end %>

    <div class="mt-4">
      <%= render(Campbooks::WorkflowStepConnector.new) %>
    </div>
  </div>

  <div class="w-full lg:w-72 lg:flex-shrink-0">
    <div class="lg:sticky lg:top-20 space-y-4">
      <% if @workflow.webhook? %>
        <%= render(Campbooks::Card.new(padding: :md)) do %>
          <h3 class="text-sm font-medium text-foreground mb-1"><%= t(".webhook_url_heading") %></h3>
          <p class="text-xs text-muted-foreground mb-3"><%= t(".webhook_url_description") %></p>
          <%= render(Campbooks::WebhookUrlField.new(url: @webhook_url, label: "")) %>
          <% if @webhook_url.present? %>
            <%= button_to t(".regenerate_url"), regenerate_webhook_workflow_path(@workflow),
                  method: :post,
                  form: { data: { turbo_confirm: t(".regenerate_url_confirm") } },
                  class: "mt-3 text-xs text-destructive hover:text-destructive/80 cursor-pointer" %>
          <% end %>
        <% end %>
      <% end %>

      <%= render(Campbooks::Card.new(padding: :md)) do %>
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-medium text-foreground"><%= t(".recent_runs_heading") %></h3>
          <%= link_to t(".view_all"), workflow_executions_path(@workflow), class: "text-xs text-muted-foreground hover:text-foreground" %>
        </div>
        <% if @recent_executions.any? %>
          <div class="space-y-1.5">
            <% @recent_executions.each do |execution| %>
              <%= link_to workflow_execution_path(@workflow, execution), class: "flex items-center justify-between gap-2 py-1.5 px-2 -mx-2 rounded-md hover:bg-accent" do %>
                <span class="flex items-center gap-2 min-w-0">
                  <%= render(Campbooks::Badge.new(variant: execution_badge_variant(execution), size: :md)) { human_enum(WorkflowExecution, :status, execution.status) } %>
                  <span class="text-xs text-muted-foreground truncate"><%= t(".time_ago", time: time_ago_in_words(execution.created_at)) %></span>
                </span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-xs text-muted-foreground"><%= t(".no_runs_yet") %></p>
        <% end %>
      <% end %>

      <%= render(Campbooks::Card.new(padding: :md)) do %>
        <h3 class="text-sm font-medium text-foreground mb-3"><%= t(".template_variables_heading") %></h3>
        <div class="space-y-2">
          <% @liquid_variables.each do |var, desc| %>
            <div>
              <code class="text-xs text-foreground font-mono bg-muted px-1.5 py-0.5 rounded"><%= "{{ #{var} }}" %></code>
              <p class="text-xs text-muted-foreground mt-0.5"><%= desc %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%= render(Campbooks::StepPicker.new(workflow: @workflow)) %>
</div>
