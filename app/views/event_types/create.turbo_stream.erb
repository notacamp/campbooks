<%= turbo_stream.prepend "event_type_rows" do %>
  <%= render "event_types/event_type", type: @type %>
<% end %>
<%= turbo_stream.remove "event_types_empty" %>
<%= turbo_stream.update "event_type_form", "" %>
<%= turbo_stream.append "action_toasts" do %>
  <%= render "shared/action_toast", message: t(".success"), variant: :success %>
<% end %>
