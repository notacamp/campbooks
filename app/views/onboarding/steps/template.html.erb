<%# Setup template picker — the very first question for a new workspace.
    Multi-select persona cards. "Just exploring" is exclusive (clears others
    when tapped; tapping any other card clears it). A Continue button applies
    all selected templates; Skip proceeds without applying any.
    Card hierarchy: icon + name prominent → description in full → compact
    item summary at foot. Just Exploring is visually softer. %>
<% content_for :main_class, "mx-auto flex w-full max-w-[48rem] flex-col justify-center px-5 py-10 min-h-svh" %>

<div class="flex flex-col items-center text-center animate-stage-in">
  <h1 class="text-[1.6rem] font-semibold leading-tight tracking-[-0.02em] text-foreground text-balance">
    <%= t(".heading") %>
  </h1>
  <p class="mt-2 max-w-sm text-[15px] leading-relaxed text-muted-foreground text-pretty">
    <%= t(".subheading") %>
  </p>
</div>

<%= form_with url: onboarding_path, method: :patch,
              class: "mt-8 w-full animate-stage-in flex flex-col",
              style: "--stage-delay: .08s",
              id: "template-form",
              data: { controller: "template-picker" } do |f| %>
  <%= hidden_field_tag :step, "template" %>

  <%# 3-col grid on desktop, 2-col on tablet, 1-col on mobile. %>
  <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
    <% @templates.each_with_index do |tpl, i| %>
      <%
        key          = tpl[:key]
        chosen       = @chosen_keys.include?(key)
        is_exclusive = (key == "just_exploring")
        # Count total items for the compact summary
        all_items    = tpl[:tags] + tpl[:document_types]
        shown_items  = all_items.first(4)
        extra_count  = [all_items.size - shown_items.size, 0].max
        delay        = "#{(i * 0.04).round(2)}s"
      %>
      <label class="group relative flex cursor-pointer flex-col rounded-2xl border p-4 transition-all has-[:checked]:border-accent-500 has-[:checked]:bg-accent-50/60 dark:has-[:checked]:bg-accent-900/20 animate-stage-in <%= is_exclusive ? 'border-dashed' : '' %> <%= chosen ? 'border-accent-500 bg-accent-50/60 dark:bg-accent-900/20' : 'border-border bg-card hover:border-gray-300 dark:hover:border-gray-600' %>"
             style="--stage-delay: <%= delay %>"
             data-template-picker-target="card">
        <input type="checkbox" name="template_keys[]" value="<%= key %>"
               <%= "checked" if chosen %>
               class="sr-only"
               data-exclusive="<%= is_exclusive %>"
               data-action="change->template-picker#toggle">

        <%# Header row: icon + name + checkmark badge %>
        <div class="flex items-start gap-3">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl <%= is_exclusive ? 'bg-ink/[.04] dark:bg-white/[.06]' : 'bg-ink/[.06] dark:bg-white/10' %> text-ink/70 dark:text-white/70 group-has-[:checked]:bg-accent-100 group-has-[:checked]:text-accent-700 dark:group-has-[:checked]:bg-accent-900/30 dark:group-has-[:checked]:text-accent-400 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-[18px] w-[18px]" aria-hidden="true">
              <path d="<%= tpl[:icon] %>"/>
            </svg>
          </span>

          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold <%= is_exclusive ? 'text-muted-foreground' : 'text-foreground' %> group-has-[:checked]:text-foreground leading-snug">
              <%= t(".templates.#{key}.name") %>
            </p>
          </div>

          <%# Checkmark badge when selected %>
          <span class="pointer-events-none hidden h-5 w-5 shrink-0 items-center justify-center rounded-full bg-accent-600 text-white group-has-[:checked]:flex mt-0.5">
            <svg viewBox="0 0 12 12" fill="none" class="h-3 w-3" aria-hidden="true">
              <path d="M2.5 6L5 8.5L9.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>

        <%# Description — full text, no clamp %>
        <p class="mt-2 text-xs leading-relaxed <%= is_exclusive ? 'text-muted-foreground/70' : 'text-muted-foreground' %> pl-12">
          <%= t(".templates.#{key}.description") %>
        </p>

        <%# Compact item summary at foot (one muted line with dots + overflow count) %>
        <% if all_items.any? %>
          <div class="mt-3 pl-12 flex items-center gap-x-2 min-w-0 overflow-hidden">
            <% shown_items.each do |item| %>
              <span class="flex items-center gap-1 shrink-0 text-[11px] text-muted-foreground/70">
                <span class="h-1.5 w-1.5 rounded-full shrink-0" style="background-color: <%= item[:color] %>"></span>
                <span class="truncate max-w-[5rem]"><%= item[:name].titleize %></span>
              </span>
            <% end %>
            <% if extra_count > 0 %>
              <span class="text-[11px] text-muted-foreground/50 shrink-0">+<%= extra_count %></span>
            <% end %>
          </div>
        <% end %>
      </label>
    <% end %>
  </div>

  <div class="mt-6 flex items-center gap-4">
    <%= render(Campbooks::Button.new(variant: :primary, type: :submit,
                                    class: "px-8 justify-center")) do %>
      <%= t(".continue") %>
    <% end %>

    <%# Skip — posts with no template_keys — update_template is a no-op %>
    <%= form_with url: onboarding_path, method: :patch, class: "inline" do |sf| %>
      <%= hidden_field_tag :step, "template" %>
      <%= render(Campbooks::Button.new(variant: :ghost, type: :submit, class: "text-muted-foreground")) { t(".skip") } %>
    <% end %>
  </div>

  <p class="mt-3 text-xs text-muted-foreground/60 text-center">
    <%= t(".skip_hint") %>
  </p>
<% end %>
