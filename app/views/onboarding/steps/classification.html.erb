<%= render(Campbooks::OnboardingProgress.new(current_step: @step, previous_step: @previous_step)) %>

<div class="mb-6">
  <h1 class="text-lg font-semibold text-gray-900"><%= t(".heading") %></h1>
  <p class="text-sm text-gray-500 mt-1"><%= t(".subheading") %></p>
</div>

<%= render(Campbooks::Card.new(padding: :none)) do %>
  <div data-controller="tabs">
  <!-- Tab nav -->
  <div class="flex border-b border-gray-200" role="tablist">
    <button class="flex-1 px-4 py-3 text-sm font-medium text-accent-600 border-b-2 border-accent-600 bg-accent-50/50 rounded-tl-xl" data-tabs-target="tab" data-action="click->tabs#select" data-tabs-panel="panel-doctypes" role="tab" aria-selected="true">
      <%= t(".tab_document_types") %> <span class="text-xs text-gray-400 font-normal"><%= t(".tab_document_types_count", count: @template_document_types.size) %></span>
    </button>
    <button class="flex-1 px-4 py-3 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 hover:border-gray-300 rounded-tr-xl" data-tabs-target="tab" data-action="click->tabs#select" data-tabs-panel="panel-tags" role="tab" aria-selected="false">
      <%= t(".tab_email_tags") %> <span class="text-xs text-gray-400 font-normal"><%= t(".tab_email_tags_count", count: @template_tags.size) %></span>
    </button>
  </div>

  <%= form_with url: onboarding_path(step: :classification), method: :patch, class: "space-y-0" do |form| %>
    <!-- Document Types Panel -->
    <div id="panel-doctypes" data-tabs-target="panel" class="p-6">
      <!-- Template Selection -->
      <div class="mb-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-3"><%= t(".template_section_title") %></h3>
        <div class="flex items-center gap-4 flex-wrap">
          <% @templates.each do |template| %>
            <label class="flex items-center gap-2 cursor-pointer">
              <%= radio_button_tag :template_id, template.id, template.id == @default_template&.id,
                  class: "rounded-full border-gray-300 text-accent-600 focus:ring-accent-500" %>
              <span class="text-sm text-gray-700"><%= template.name %></span>
            </label>
          <% end %>
          <label class="flex items-center gap-2 cursor-pointer">
            <%= radio_button_tag :template_id, "", false,
                class: "rounded-full border-gray-300 text-accent-600 focus:ring-accent-500" %>
            <span class="text-sm text-gray-700"><%= t(".start_from_scratch") %></span>
          </label>
        </div>
      </div>

      <!-- Template Document Types -->
      <div id="template_document_types" class="mb-4">
        <p class="text-xs text-gray-500 mb-3"><%= t(".doc_types_hint") %></p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <% @template_document_types.each do |type| %>
            <%= render(Campbooks::CheckableCard.new(
                  name: "selected_template_types[]", value: type["name"], checked: true,
                  title: type["name"].humanize, description: type["prompt"], color: type["color"],
                  variant: :horizontal,
                  id: "selected_template_types_#{type["name"]}")) %>
          <% end %>
        </div>
      </div>

      <!-- AI Suggestions for Doc Types -->
      <div class="mb-4 p-4 rounded-lg bg-gray-50">
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-xs font-semibold text-gray-600"><%= t(".ai_suggestions_title") %></h4>
          <%= form.button t(".suggest_doc_types_button"), formmethod: "post", formaction: suggest_document_types_onboarding_path,
              data: { turbo_method: :post },
              class: "px-3 py-1 text-xs font-medium text-accent-700 bg-card rounded-md hover:bg-accent-50 border border-accent-200 cursor-pointer transition-colors" %>
        </div>
        <div id="ai_suggestions_document_types">
          <p class="text-xs text-gray-400 italic"><%= t(".suggest_doc_types_placeholder") %></p>
        </div>
      </div>

      <!-- Custom Doc Type -->
      <details class="group">
        <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700"><%= t(".add_custom_doc_type") %></summary>
        <div class="mt-3 space-y-2">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
            <%= render(Campbooks::Input.new("custom_document_types[0][name]", type: :text, label: nil, placeholder: t(".custom_type_name_placeholder"), rounded: :md)) %>
            <%= render(Campbooks::Input.new("custom_document_types[0][color]", type: :text, label: nil, placeholder: t(".custom_type_color_placeholder"), rounded: :md)) %>
            <%= render(Campbooks::Input.new("custom_document_types[0][extraction_schema]", type: :text, label: nil, placeholder: t(".custom_type_schema_placeholder"), rounded: :md)) %>
          </div>
          <%= render(Campbooks::MarkdownEditor.new("custom_document_types[0][prompt]", placeholder: t(".custom_type_prompt_placeholder"), rows: 3)) %>
        </div>
      </details>
    </div>

    <!-- Tags Panel -->
    <div id="panel-tags" data-tabs-target="panel" class="hidden p-6">
      <!-- Template Tags -->
      <div class="mb-4">
        <p class="text-xs text-gray-500 mb-3"><%= t(".tags_hint") %></p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
          <% @template_tags.each do |tag| %>
            <%= render(Campbooks::CheckableCard.new(
                  name: "selected_template_tags[]", value: tag["name"], checked: true,
                  title: tag["name"].humanize, color: tag["color"],
                  variant: :compact,
                  id: "selected_template_tags_#{tag["name"]}")) %>
          <% end %>
        </div>
      </div>

      <!-- AI Suggestions for Tags -->
      <div class="mb-4 p-4 rounded-lg bg-gray-50">
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-xs font-semibold text-gray-600"><%= t(".ai_suggestions_title") %></h4>
          <%= form.button t(".suggest_tags_button"), formmethod: "post", formaction: suggest_tags_onboarding_path,
              data: { turbo_method: :post },
              class: "px-3 py-1 text-xs font-medium text-accent-700 bg-card rounded-md hover:bg-accent-50 border border-accent-200 cursor-pointer transition-colors" %>
        </div>
        <div id="ai_suggestions_tags">
          <p class="text-xs text-gray-400 italic"><%= t(".suggest_tags_placeholder") %></p>
        </div>
      </div>

      <!-- Custom Tag -->
      <details class="group">
        <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700"><%= t(".add_custom_tag") %></summary>
        <div class="mt-3 space-y-2">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <%= render(Campbooks::Input.new("custom_tags[0][name]", type: :text, label: nil, placeholder: t(".custom_tag_name_placeholder"), rounded: :md)) %>
            <%= render(Campbooks::Input.new("custom_tags[0][color]", type: :text, label: nil, placeholder: t(".custom_tag_color_placeholder"), rounded: :md)) %>
          </div>
          <%= render(Campbooks::MarkdownEditor.new("custom_tags[0][prompt]", placeholder: t(".custom_tag_prompt_placeholder"), rows: 3)) %>
        </div>
      </details>
    </div>

    <!-- Why this matters -->
    <div class="px-6 pb-4">
      <%= render(Campbooks::Alert.new(variant: :warning)) do %>
        <%= t(".alert_html") %>
      <% end %>
    </div>

    <div class="px-6 pb-6 pt-2">
      <%= form.submit t(".save_and_continue"),
          class: "w-full py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-accent-600 hover:bg-accent-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent-500 cursor-pointer transition-colors" %>
    </div>
  <% end %>
<% end %>
