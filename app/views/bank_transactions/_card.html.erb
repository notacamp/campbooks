<div id="<%= dom_id(transaction, :card) %>" class="bg-card rounded-lg border border-border px-4 py-3">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <p class="text-sm text-foreground truncate" title="<%= transaction.description %>"><%= transaction.description %></p>
      <p class="text-xs text-muted-foreground mt-0.5">
        <%= l(transaction.booked_on, format: :date) %>
        <% if transaction.counterparty.present? %>
          &middot; <%= transaction.counterparty %>
        <% end %>
      </p>
    </div>
    <div class="text-right shrink-0">
      <p class="text-sm font-medium tabular-nums
                <%= transaction.debit? ? 'text-red-600 dark:text-red-400' : 'text-green-700 dark:text-green-400' %>">
        <%= transaction.debit? ? "−" : "+" %><%= number_to_currency(transaction.amount_cents.abs / 100.0, unit: "", precision: 2) %>
        <span class="text-xs font-normal text-muted-foreground"><%= transaction.currency %></span>
      </p>
      <% if transaction.matched? %>
        <%= render Campbooks::Badge.new(variant: :success, size: :sm) { human_enum(BankTransaction, :status, transaction.status) } %>
      <% elsif transaction.excluded? %>
        <%= render Campbooks::Badge.new(variant: :neutral, size: :sm) { human_enum(BankTransaction, :status, transaction.status) } %>
      <% end %>
    </div>
  </div>
</div>
