<%# Peak-end: a quiet, Scout-voiced sign-off at the very bottom of the timeline,
    so the feed ends on reassurance rather than an administrative last card. %>
<div id="feed_end" class="flex flex-col items-center gap-2 pt-10 pb-4 text-center">
  <span class="flex h-9 w-9 items-center justify-center rounded-full" style="background-image: var(--ember); box-shadow: var(--ember-glow)">
    <svg viewBox="0 0 24 24" fill="white" class="h-[18px] w-[18px]" aria-hidden="true"><path d="M12 2l1.7 5.6L19.5 9l-5.8 1.4L12 16l-1.7-5.6L4.5 9l5.8-1.4z"/></svg>
  </span>
  <p class="max-w-xs text-[13px] leading-relaxed text-muted-foreground"><%= t("home.index.feed_end") %></p>
</div>
